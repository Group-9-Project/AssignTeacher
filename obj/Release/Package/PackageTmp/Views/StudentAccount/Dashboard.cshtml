@{
    Layout = null; // Explicitly disabling layout
    ViewBag.Title = "Student Resource Center";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - DGSS</title>

    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --dg-navy: #002147;
            --dg-navy-light: #003366;
            --dg-white: #ffffff;
            --dg-bg: #f4f7f9;
            --dg-border: #d1d9e6;
            --dg-text: #002147;
            --dg-text-muted: #4a5568;
        }

        body {
            background-color: var(--dg-bg);
            color: var(--dg-text);
            font-family: 'Inter', sans-serif;
            margin: 0;
            padding: 0;
        }

        .dashboard-container {
            max-width: 1100px;
            margin: 6rem auto;
            padding: 0 1.5rem;
        }

        /* --- Header Section --- */
        .page-header {
            text-align: center;
            margin-bottom: 5rem;
            position: relative;
            border-bottom: 2px solid var(--dg-navy);
            padding-bottom: 2rem;
        }

        .btn-back-nav {
            position: absolute;
            left: 0;
            top: -40px;
            color: var(--dg-navy);
            text-decoration: none !important;
            font-size: 0.85rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: 0.2s;
        }

            .btn-back-nav:hover {
                opacity: 0.7;
            }

        .page-title {
            font-family: 'Playfair Display', serif;
            font-size: 3.5rem;
            color: var(--dg-navy);
            margin: 0;
            font-weight: 700;
        }

        .school-tag {
            font-weight: 600;
            color: var(--dg-text-muted);
            text-transform: uppercase;
            letter-spacing: 0.3em;
            font-size: 0.75rem;
            margin-top: 0.5rem;
        }

        /* --- Grid & Cards --- */
        .resource-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 2.5rem;
        }

        .resource-card {
            background: var(--dg-white);
            border: 2px solid var(--dg-navy);
            border-radius: 0; /* Sharp corners for a formal look */
            padding: 3.5rem 2rem;
            text-align: center;
            transition: all 0.3s ease;
            text-decoration: none !important;
            display: flex;
            flex-direction: column;
            align-items: center;
            position: relative;
            overflow: hidden;
        }

            .resource-card::before {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 5px;
                background: var(--dg-navy);
            }

            .resource-card:hover {
                background: var(--dg-navy);
                transform: translateY(-5px);
                box-shadow: 0 15px 30px rgba(0, 33, 71, 0.15);
            }

                .resource-card:hover .card-name,
                .resource-card:hover .card-desc,
                .resource-card:hover .icon-box {
                    color: var(--dg-white) !important;
                }

                .resource-card:hover .btn-outline-custom {
                    border-color: var(--dg-white);
                    color: var(--dg-white);
                }

        .icon-box {
            font-size: 2.5rem;
            margin-bottom: 1.5rem;
            color: var(--dg-navy);
            transition: 0.3s;
        }

        .card-name {
            font-size: 1.6rem;
            font-weight: 700;
            color: var(--dg-navy);
            margin-bottom: 1rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: 0.3s;
        }

        .card-desc {
            color: var(--dg-text-muted);
            font-size: 0.95rem;
            line-height: 1.6;
            margin-bottom: 2rem;
            transition: 0.3s;
        }

        .btn-outline-custom {
            padding: 0.7rem 2rem;
            border: 2px solid var(--dg-navy);
            background: transparent;
            color: var(--dg-navy);
            font-weight: 700;
            font-size: 0.8rem;
            text-transform: uppercase;
            transition: 0.2s;
        }
    </style>
</head>
<body>

    <div class="dashboard-container">

        <header class="page-header">
            <a href="@Url.Action("Index")" class="btn-back-nav">
                &larr; Return to Profile
            </a>
            <p class="school-tag">Durban Girls Secondary School</p>
        </header>

        <div class="resource-grid">

            <a href="@Url.Action("Announcement")" class="resource-card">
                <div class="icon-box">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
                </div>
                <h3 class="card-name">Announcements</h3>
                <p class="card-desc">
                    Official school communications, upcoming events, and daily notices for all students.
                </p>
                <span class="btn-outline-custom">View Notices</span>
            </a>

            <a href="@Url.Action("LearningMaterials")" class="resource-card">
                <div class="icon-box">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
                </div>
                <h3 class="card-name">Academic Vault</h3>
                <p class="card-desc">
                    Digital library containing study guides, past papers, and teacher-uploaded materials.
                </p>
                <span class="btn-outline-custom">Download Files</span>
            </a>

            <a href="@Url.Action("MyTimetable")" class="resource-card">
                <div class="icon-box">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                        <line x1="16" y1="2" x2="16" y2="6"></line>
                        <line x1="8" y1="2" x2="8" y2="6"></line>
                        <line x1="3" y1="10" x2="21" y2="10"></line>
                    </svg>
                </div>
                <h3 class="card-name">Class Timetable</h3>
                <p class="card-desc">
                    View your weekly schedule, assigned subjects, classroom locations, and teachers for 2026.
                </p>
                <span class="btn-outline-custom">View Schedule</span>
            </a>

        </div>

    </div>

</body>
</html>