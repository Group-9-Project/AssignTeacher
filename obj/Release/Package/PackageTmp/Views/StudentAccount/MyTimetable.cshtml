@model IEnumerable<SchoolTimetable.Models.TimetableSlot>
@{
    Layout = null;
    ViewBag.Title = "My Timetable";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - DGSS</title>
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800&family=Barlow:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        :root {
            --navy-deep: #050c18;
            --navy-card: rgba(10, 25, 47, 0.9);
            --navy-accent: #112240;
            --gold-accent: #c5a059;
            --white-bright: #e6f1ff;
            --white-muted: #8892b0;
        }

        body {
            font-family: 'Barlow', sans-serif;
            background: var(--navy-deep);
            color: var(--white-muted);
            margin: 0;
            padding: 40px 5%;
            min-height: 120vh; /* Ensures scrollability */
            text-align: left;
        }

        /* Background Overlay */
        .page-bg-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, rgba(5, 12, 24, 0.98), rgba(5, 12, 24, 0.9)), url('/Content/Images/tp-image-3986.jpg');
            background-size: cover;
            background-position: center;
            z-index: -1;
        }

        .page-title {
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 3.5rem;
            color: var(--white-bright);
            text-transform: uppercase;
            font-weight: 800;
            margin-bottom: 2rem;
            letter-spacing: 1px;
        }

        .table-container {
            background: var(--navy-card);
            padding: 2rem;
            border-radius: 4px;
            border: 1px solid var(--navy-accent);
            overflow-x: auto; /* Scroll table on small screens */
            max-width: 1200px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 2rem;
            background: transparent;
        }

        th {
            background-color: var(--navy-accent);
            color: var(--gold-accent);
            font-family: 'Barlow Condensed', sans-serif;
            text-transform: uppercase;
            letter-spacing: 2px;
            padding: 1.2rem;
            border: 1px solid rgba(255,255,255,0.05);
            font-size: 1.1rem;
        }

        td {
            padding: 1.5rem 1rem;
            border: 1px solid rgba(255,255,255,0.05);
            vertical-align: top;
            transition: 0.3s;
        }

        tr:hover td {
            background: rgba(255, 255, 255, 0.02);
        }

        .period-number {
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 800;
            color: var(--gold-accent);
            font-size: 1.2rem;
            background: rgba(17, 34, 64, 0.5);
        }

        .subject-name {
            color: var(--white-bright);
            font-weight: 600;
            font-size: 1rem;
            margin-bottom: 4px;
            text-transform: uppercase;
        }

        .room-tag {
            color: var(--gold-accent);
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 1px;
        }

        .teacher-name {
            font-size: 0.8rem;
            font-style: italic;
            color: var(--white-muted);
            margin-top: 5px;
        }

        .btn-back {
            display: inline-block;
            margin-top: 2rem;
            padding: 1rem 2.5rem;
            border: 1px solid var(--gold-accent);
            color: var(--gold-accent);
            text-decoration: none;
            text-transform: uppercase;
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 700;
            letter-spacing: 2px;
            transition: 0.3s;
        }

            .btn-back:hover {
                background: rgba(197, 160, 89, 0.1);
                transform: translateX(5px);
            }

        empty-slot {
            opacity: 0.2;
            font-weight: 300;
        }
    </style>
</head>
<body>

    <div class="page-bg-overlay"></div>

    <h2 class="page-title">Weekly Schedule</h2>

    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>Period</th>
                    <th>Monday</th>
                    <th>Tuesday</th>
                    <th>Wednesday</th>
                    <th>Thursday</th>
                    <th>Friday</th>
                </tr>
            </thead>
            <tbody>
                @for (int p = 1; p <= 8; p++)
                {
                    <tr>
                        <td class="period-number">@p</td>
                        @for (int d = 1; d <= 5; d++)
                        {
                            var slot = Model.FirstOrDefault(s => s.DayOfWeek == d && s.Period == p);
                            <td>
                                @if (slot != null)
                                {
                                    <div class="subject-name">@slot.Subject.Name</div>
                                    <div class="teacher-name">@slot.Teacher.FullName</div>
                                }
                                else
                                {
                                    <span class="empty-slot">—</span>
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <a href="@Url.Action("Dashboard")" class="btn-back">
        <i class="fas fa-arrow-left"></i> Back to Resources
    </a>

</body>
</html>