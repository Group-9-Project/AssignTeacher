@model SchoolTimetable.ViewModels.BookFormViewModel
@{
    Layout = null;
    ViewBag.Title = "Edit Book";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - DGSS Library</title>

    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@800&family=Barlow:wght@400;500;600;700&display=swap');

        :root {
            --navy-deep: #0a192f;
            --navy-accent: #233554;
            --white-bright: #ffffff;
            --light-gray: #f8f9fa;
            --border-color: #e2e8f0;
            --text-main: #1a202c;
            --text-muted: #718096;
            --gold-highlight: #b08d48;
            --danger-red: #ef4444;
        }

        body {
            background-color: var(--navy-deep); /* Keeping the outer background dark for consistency with other pages */
            color: var(--text-main);
            margin: 0;
            padding: 0;
            font-family: 'Barlow', sans-serif;
            line-height: 1.6;
        }

        .form-page {
            max-width: 900px;
            margin: 3rem auto;
            padding: 0 1.5rem;
        }

        .page-header {
            text-align: center;
            margin-bottom: 2.5rem;
        }

        .page-title {
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 3.5rem;
            text-transform: uppercase;
            color: var(--white-bright);
            margin-bottom: 0.5rem;
            letter-spacing: 1px;
        }

        .page-subtitle {
            font-size: 1.1rem;
            color: var(--white-muted);
            opacity: 0.8;
            letter-spacing: 0.05em;
        }

        /* Light Theme Card */
        .card {
            background: var(--white-bright);
            border-radius: 8px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
            padding: 3.5rem;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
            margin-bottom: 1rem;
        }

        .form-group {
            margin-bottom: 1.8rem;
            display: flex;
            flex-direction: column;
        }

        .form-label {
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            font-size: 0.85rem;
            color: var(--navy-deep);
            margin-bottom: 0.6rem;
        }

        .form-control {
            width: 100%;
            padding: 1rem;
            font-size: 1rem;
            background: var(--light-gray);
            color: var(--text-main);
            border: 2px solid var(--border-color);
            border-radius: 4px;
            transition: all 0.2s ease;
            font-family: inherit;
        }

            .form-control:focus {
                border-color: var(--navy-deep);
                background: var(--white-bright);
                outline: none;
                box-shadow: 0 0 0 3px rgba(10, 25, 47, 0.05);
            }

        textarea.form-control {
            resize: vertical;
        }

        .form-text {
            font-size: 0.8rem;
            color: var(--text-muted);
            margin-top: 0.5rem;
            font-style: italic;
        }

        .form-actions {
            margin-top: 2.5rem;
            display: flex;
            gap: 1rem;
            padding-top: 2rem;
            border-top: 1px solid var(--border-color);
        }

        /* Button Styling */
        .btn {
            padding: 1.2rem 2rem;
            font-family: 'Barlow Condensed', sans-serif;
            text-transform: uppercase;
            font-weight: 800;
            letter-spacing: 0.1em;
            border-radius: 4px;
            cursor: pointer;
            transition: 0.3s;
            text-decoration: none;
            font-size: 1rem;
            border: none;
            flex: 1;
            text-align: center;
        }

        .btn-primary {
            background: var(--navy-deep);
            color: var(--white-bright);
        }

            .btn-primary:hover {
                background: var(--navy-accent);
                transform: translateY(-2px);
            }

        .btn-secondary {
            background: var(--light-gray);
            color: var(--text-muted);
            border: 1px solid var(--border-color);
        }

            .btn-secondary:hover {
                background: #edf2f7;
                color: var(--navy-deep);
            }

        .text-danger {
            font-size: 0.8rem;
            font-weight: 700;
            color: var(--danger-red);
            margin-top: 0.4rem;
        }

        @@media (max-width: 768px) {
            .form-row {
                grid-template-columns: 1fr;
                gap: 0;
            }

            .card {
                padding: 2rem 1.5rem;
            }

            .form-actions {
                flex-direction: column;
            }

            .page-title {
                font-size: 2.5rem;
            }
        }
    </style>
</head>
<body>

    <div class="form-page">
        <div class="page-header">
            <h1 class="page-title">Modify Catalogue</h1>
            <p class="page-subtitle">Updating: @Model.Title</p>
        </div>

        <div class="card">
            @using (Html.BeginForm("Edit", "Books", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.Id)
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                <div class="form-row">
                    <div class="form-group">
                        @Html.LabelFor(m => m.Title, "Book Title *", new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.Title, new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.Title, "", new { @class = "text-danger" })
                    </div>
                    <div class="form-group">
                        @Html.LabelFor(m => m.Author, "Author *", new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.Author, new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.Author, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        @Html.LabelFor(m => m.ISBN, "ISBN Number", new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.ISBN, new { @class = "form-control", placeholder = "978..." })
                    </div>
                    <div class="form-group">
                        @Html.LabelFor(m => m.Genre, "Genre / Category", new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.Genre, new { @class = "form-control" })
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        @Html.LabelFor(m => m.Publisher, "Publisher", new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.Publisher, new { @class = "form-control" })
                    </div>
                    <div class="form-group">
                        @Html.LabelFor(m => m.PublicationYear, "Year of Publication", new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.PublicationYear, new { @class = "form-control", type = "number" })
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        @Html.LabelFor(m => m.TotalCopies, "Total Inventory *", new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.TotalCopies, new { @class = "form-control", type = "number", min = "0" })
                        <span class="form-text">System tracks availability automatically.</span>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Grade Suitability</label>
                        <div style="display:flex; gap:.5rem; align-items:center">
                            @Html.DropDownListFor(m => m.MinGrade,
                                new SelectList(Enumerable.Range(8, 5).Select(g => new SelectListItem { Value = g.ToString(), Text = "Gr " + g }), "Value", "Text"),
                                "Min", new { @class = "form-control" })

                            <span style="color: var(--text-muted); font-weight: bold; font-family: 'Barlow Condensed';">TO</span>

                            @Html.DropDownListFor(m => m.MaxGrade,
                                new SelectList(Enumerable.Range(8, 5).Select(g => new SelectListItem { Value = g.ToString(), Text = "Gr " + g }), "Value", "Text"),
                                "Max", new { @class = "form-control" })
                        </div>
                    </div>
                </div>

                <div class="form-group" style="margin-bottom: 0;">
                    @Html.LabelFor(m => m.Description, "Book Summary", new { @class = "form-label" })
                    @Html.TextAreaFor(m => m.Description, new { @class = "form-control", rows = "4" })
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    <a href="@Url.Action("Details", new { id = Model.Id })" class="btn btn-secondary">Discard & Return</a>
                </div>
            }
        </div>
    </div>

</body>
</html>