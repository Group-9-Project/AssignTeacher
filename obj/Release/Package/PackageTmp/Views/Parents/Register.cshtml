@{
    ViewBag.Title = "Parent Registration";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>

    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800&family=Barlow:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        :root {
            --navy-deep: #0a192f;
            --navy-muted: #112240;
            --navy-accent: #233554;
            --white-bright: #ffffff;
            --white-off: #f8f9fa;
            --gray-text: #555555;
            --status-red: #d32f2f;
        }

        body {
            margin: 0;
            padding: 20px;
            background-color: var(--white-off);
            color: var(--navy-deep);
            font-family: 'Barlow', sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            box-sizing: border-box;
        }

        .registration-container {
            width: 100%;
            max-width: 450px;
            padding: 40px;
            background: var(--white-bright);
            border: 1px solid #e0e0e0;
            border-top: 4px solid var(--navy-deep); /* Navy signature bar */
            border-radius: 4px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        }

        .header-section {
            text-align: center;
            margin-bottom: 35px;
        }

            .header-section h2 {
                font-family: 'Barlow Condensed', sans-serif;
                font-weight: 800;
                font-size: 2.2rem;
                color: var(--navy-deep);
                margin: 0;
                text-transform: uppercase;
                letter-spacing: 2px;
            }

            .header-section p {
                color: var(--gray-text);
                font-size: 0.8rem;
                text-transform: uppercase;
                letter-spacing: 3px;
                margin-top: 10px;
                font-weight: 600;
                opacity: 0.8;
            }

        .form-group {
            margin-bottom: 22px;
        }

            .form-group label {
                display: block;
                font-family: 'Barlow Condensed', sans-serif;
                font-size: 0.85rem;
                font-weight: 700;
                color: var(--navy-deep);
                margin-bottom: 8px;
                text-transform: uppercase;
                letter-spacing: 1.5px;
            }

        .form-input {
            width: 100%;
            padding: 14px 16px;
            background: var(--white-bright);
            border: 1px solid #ccc;
            border-radius: 2px;
            color: var(--navy-deep);
            font-family: 'Barlow', sans-serif;
            font-size: 0.95rem;
            box-sizing: border-box;
            transition: all 0.3s ease;
        }

            .form-input:focus {
                outline: none;
                border-color: var(--navy-deep);
                box-shadow: 0 0 0 2px rgba(10, 25, 47, 0.05);
            }

        .btn-submit {
            width: 100%;
            padding: 16px;
            background: var(--navy-deep);
            color: var(--white-bright);
            border: none;
            border-radius: 2px;
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 800;
            text-transform: uppercase;
            font-size: 1.1rem;
            cursor: pointer;
            letter-spacing: 2px;
            transition: all 0.3s ease;
            margin-top: 15px;
        }

            .btn-submit:hover {
                background: var(--navy-muted);
                transform: translateY(-1px);
                box-shadow: 0 5px 15px rgba(10, 25, 47, 0.2);
            }

        .footer-link {
            text-align: center;
            margin-top: 30px;
            font-size: 0.85rem;
            color: var(--gray-text);
            border-top: 1px solid #eee;
            padding-top: 20px;
        }

            .footer-link a {
                color: var(--navy-deep);
                font-weight: 700;
                text-decoration: none;
                text-transform: uppercase;
                font-family: 'Barlow Condensed', sans-serif;
                letter-spacing: 1px;
                border-bottom: 1px solid transparent;
                transition: border-color 0.3s ease;
            }

                .footer-link a:hover {
                    border-color: var(--navy-deep);
                }

        .error-alert {
            background: #fff5f5;
            color: var(--status-red);
            padding: 15px;
            border-radius: 2px;
            margin-bottom: 25px;
            font-size: 0.85rem;
            border-left: 4px solid var(--status-red);
            font-family: 'Barlow Condensed', sans-serif;
            letter-spacing: 1px;
        }
    </style>
</head>
<body>

    <div class="registration-container">
        <div class="header-section">
            <h2>Portal Access</h2>
            <p>Durban Girls Secondary School</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="error-alert">
                REGISTRATION ERROR: @ViewBag.Error
            </div>
        }

        @using (Html.BeginForm("Register", "Parents", FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label>Parent Full Name</label>
                <input type="text" name="FullName" class="form-input" placeholder="E.G. JANE DOE" required />
            </div>

            <div class="form-group">
                <label>Email Address</label>
                <input type="email" name="Email" class="form-input" placeholder="NAME@EXAMPLE.COM" required />
            </div>

            <div class="form-group">
                <label>Secure Password</label>
                <input type="password" name="Password" class="form-input" placeholder="••••••••" required />
            </div>

            <div class="form-group">
                <label>Verify Password</label>
                <input type="password" name="ConfirmPassword" class="form-input" placeholder="••••••••" required />
            </div>

            <button type="submit" class="btn-submit">
                Register Account
            </button>

            <div class="footer-link">
                Already registered? <a href="@Url.Action("Login", "Teachers")">Sign In</a>
            </div>
        }
    </div>

</body>
</html>