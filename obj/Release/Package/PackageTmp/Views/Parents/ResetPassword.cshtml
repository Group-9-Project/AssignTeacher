@{
    ViewBag.Title = "Reset Password";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>

    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800&family=Barlow:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        :root {
            --navy-deep: #0a192f;
            --navy-muted: #112240;
            --navy-accent: #233554;
            --white-bright: #ffffff;
            --white-muted: #ccd6f6;
            --gold-accent: #c5a059;
            --status-red: #ff4d4d;
        }

        body {
            margin: 0;
            padding: 0;
            background-color: var(--navy-deep);
            color: var(--white-muted);
            font-family: 'Barlow', sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }

        .reset-container {
            width: 100%;
            max-width: 420px;
            padding: 40px;
            background: var(--navy-muted);
            border: 1px solid var(--navy-accent);
            border-radius: 4px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
            text-align: center;
        }

        .header-section h2 {
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 800;
            font-size: 2.2rem;
            color: var(--white-bright);
            margin: 0;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .header-section p {
            color: var(--gold-accent);
            font-size: 0.9rem;
            margin: 10px 0 30px 0;
            line-height: 1.4;
        }

        /* Verification Code Input */
        .otp-group {
            margin-bottom: 30px;
            background: var(--navy-deep);
            padding: 20px;
            border-radius: 4px;
            border: 1px solid var(--navy-accent);
        }

        .otp-input {
            width: 100%;
            background: transparent;
            border: none;
            color: var(--gold-accent);
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 2.5rem;
            font-weight: 800;
            text-align: center;
            letter-spacing: 12px;
            outline: none;
            box-sizing: border-box;
        }

        /* Standard Inputs */
        .form-group {
            margin-bottom: 20px;
            text-align: left;
        }

            .form-group label {
                display: block;
                font-family: 'Barlow Condensed', sans-serif;
                font-size: 0.75rem;
                font-weight: 800;
                color: var(--gold-accent);
                margin-bottom: 8px;
                text-transform: uppercase;
                letter-spacing: 1.5px;
            }

        .form-input {
            width: 100%;
            padding: 12px 15px;
            background: var(--navy-deep);
            border: 1px solid var(--navy-accent);
            border-radius: 2px;
            color: var(--white-bright);
            font-family: 'Barlow', sans-serif;
            font-size: 1rem;
            box-sizing: border-box;
            transition: border-color 0.3s ease;
        }

            .form-input:focus {
                border-color: var(--gold-accent);
                outline: none;
            }

        /* Alert */
        .error-msg {
            color: var(--status-red);
            font-size: 0.85rem;
            font-weight: 700;
            margin-bottom: 20px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* Button */
        .btn-update {
            width: 100%;
            padding: 15px;
            background: var(--white-bright);
            color: var(--navy-deep);
            border: none;
            border-radius: 2px;
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 800;
            text-transform: uppercase;
            font-size: 1.1rem;
            cursor: pointer;
            letter-spacing: 1px;
            transition: all 0.3s ease;
            margin-top: 10px;
        }

            .btn-update:hover {
                background: var(--gold-accent);
                color: var(--white-bright);
            }
    </style>
</head>
<body>

    <div class="reset-container">
        <div class="header-section">
            <h2>Identity Verification</h2>
            <p>Verification code transmitted to<br /><strong>@ViewBag.TargetEmail</strong></p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="error-msg">@ViewBag.Error</div>
        }

        @using (Html.BeginForm())
        {
            <input type="hidden" name="email" value="@ViewBag.TargetEmail" />

            <div class="otp-group">
                <label style="font-family:'Barlow Condensed'; font-weight:800; font-size:0.7rem; color:var(--white-muted); letter-spacing:2px; display:block; margin-bottom:10px;">AUTHORIZATION CODE</label>
                <input type="text" name="code" maxlength="6" class="otp-input" placeholder="000000" autocomplete="off" required />
            </div>

            <div class="form-group">
                <label>Define New Password</label>
                <input type="password" name="newPassword" class="form-input" required />
            </div>

            <div class="form-group">
                <label>Confirm Identity String</label>
                <input type="password" name="confirmNewPassword" class="form-input" required />
            </div>

            <button type="submit" class="btn-update">
                Finalize Override
            </button>
        }
    </div>

</body>
</html>