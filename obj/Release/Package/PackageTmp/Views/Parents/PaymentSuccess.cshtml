@model dynamic
@{
    Layout = null;
    ViewBag.Title = "Payment Successful | DGSS";
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800&family=Barlow:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        :root {
            --navy-deep: #0a192f;
            --navy-muted: #112240;
            --navy-accent: #233554;
            --white-bright: #ffffff;
            --white-muted: #ccd6f6;
            --gold-accent: #c5a059;
            --status-green: #64ffda;
        }

        body {
            background-color: var(--navy-deep);
            color: var(--white-muted);
            font-family: 'Barlow', sans-serif;
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }

        .success-container {
            max-width: 700px;
            width: 90%;
            text-align: center;
            background: var(--navy-muted);
            border: 1px solid var(--navy-accent);
            padding: 60px 40px;
            border-radius: 4px;
            box-shadow: 0 20px 40px rgba(2, 12, 27, 0.7);
        }

        .icon-box {
            color: var(--status-green);
            margin-bottom: 30px;
        }

        h1 {
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 3.5rem;
            color: var(--white-bright);
            text-transform: uppercase;
            margin: 0 0 15px 0;
            letter-spacing: 1px;
        }

        .lead {
            font-size: 1.25rem;
            color: var(--gold-accent);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 30px;
        }

        hr {
            border: 0;
            border-top: 1px solid var(--navy-accent);
            margin: 30px auto;
            width: 50%;
        }

        p {
            line-height: 1.6;
            margin-bottom: 40px;
            font-size: 1.1rem;
        }

        .btn-return {
            background: var(--white-bright);
            color: var(--navy-deep);
            padding: 16px 32px;
            text-decoration: none;
            font-weight: 800;
            text-transform: uppercase;
            font-size: 0.9rem;
            letter-spacing: 2px;
            display: inline-block;
            transition: all 0.3s ease;
            border: 2px solid var(--white-bright);
        }

        .btn-return:hover {
            background: transparent;
            color: var(--white-bright);
            transform: translateY(-3px);
        }

        
    </style>
</head>
<body>

    <div class="success-container">
        <div class="icon-box">
            <i class="fa-solid fa-circle-check fa-6x"></i>
        </div>

        <h1>Payment Received</h1>
        <p class="lead">Registration Finalized</p>

        <hr>

        <p>
            Thank you for completing the registration process for <strong>Durban Girls Secondary School</strong>.
            A confirmation email and a digital receipt have been dispatched to your registered email address.
        </p>

        <div class="action-area">
            <a href="@Url.Action("Index", "Parents")" class="btn-return">
                Return to Dashboard
            </a>
        </div>
    </div>

</body>
</html>