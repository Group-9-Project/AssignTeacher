@model SchoolTimetable.Models.Application

@{
    ViewBag.Title = "Registration Payment";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Registration Payment - DGSS</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css">

    <style>
        body {
            background-color: #f8f9fa;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .card {
            border-radius: 15px;
            margin-top: 50px;
        }

        .btn-lg {
            border-radius: 10px;
            padding: 15px;
            font-weight: bold;
            transition: all 0.3s ease;
        }

        .btn-success:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(40, 167, 69, 0.3);
        }

        .list-group-item {
            border-left: none;
            border-right: none;
        }

        .school-header {
            background-color: #007bff;
            color: white;
            border-radius: 15px 15px 0 0;
        }

        /* Loading Overlay */
        #loading-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(255, 255, 255, 0.8);
            z-index: 9999;
            justify-content: center;
            align-items: center;
            flex-direction: column;
        }
    </style>
</head>
<body>

    <div id="loading-overlay">
        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;"></div>
        <p class="mt-3 font-weight-bold">Connecting to Secure Payment Gateway...</p>
    </div>

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-sm-10">

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger mt-4 shadow-sm">
                        <i class="fa fa-exclamation-triangle"></i> @TempData["Error"]
                    </div>
                }

                <div class="card shadow-lg border-0">
                    <div class="card-header school-header text-center py-4">
                        <h3 class="font-weight-light my-1 text-uppercase">Registration Payment</h3>
                        <p class="mb-0">Durban Girls Secondary School</p>
                    </div>

                    <div class="card-body p-5">
                        <div class="text-center mb-4">
                            <i class="fa fa-shield-alt fa-3x text-primary border p-3 rounded-circle"></i>
                        </div>

                        <div class="alert alert-info small text-center">
                            Please review the application details before proceeding.
                        </div>

                        <ul class="list-group list-group-flush mb-4">
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                Student Name:
                                <span class="font-weight-bold">@Model.FirstName @Model.LastName</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                Application ID:
                                <span>#@Model.Id.ToString("D5")</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center bg-light">
                                <span class="h5 mb-0 font-weight-bold">Total Amount:</span>
                                <span class="h5 mb-0 text-success font-weight-bold">R1,000.00</span>
                            </li>
                        </ul>

                        <p class="text-muted small text-center mb-4">
                            Clicking the button below will redirect you to <strong>Stripe</strong>.
                        </p>

                        @using (Html.BeginForm("CreateCheckoutSession", "Parents", FormMethod.Post, new { id = "payment-form" }))
                        {
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="applicationId" value="@Model.Id" />
                            <button type="submit" class="btn btn-success btn-lg btn-block shadow-sm" id="pay-button">
                                <i class="fa fa-lock"></i> Secure Checkout
                            </button>
                        }
                    </div>

                    <div class="card-footer text-center py-3 bg-white border-top-0">
                        <a href="@Url.Action("MyApplications", "Parents")" class="text-muted small">
                            <i class="fa fa-arrow-left"></i> Cancel and Return
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#payment-form').on('submit', function () {
                // Show loading overlay
                $('#loading-overlay').css('display', 'flex');
                // Disable button to prevent double submission
                $('#pay-button').prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i> Processing...');
            });
        });
    </script>
</body>
</html>