@model SchoolTimetable.Models.Entrance_test

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Setup Entrance Test - DGSS</title>

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">

    <style>
        html, body {
            height: auto;
            min-height: 100%;
            overflow-y: auto;
            background: #0f0f10;
            color: #e6e6e9;
            font-family: 'Inter', sans-serif;
            margin: 0;
            padding: 0;
        }

        .container {
            max-width: 1000px;
            margin: 0 auto;
            padding: 60px 20px;
        }

        .page-header {
            margin-bottom: 30px;
        }

        .page-title {
            font-size: 36px;
            font-weight: 700;
            margin: 0;
            letter-spacing: -1px;
        }

        .page-sub {
            color: #bdbdc1;
            margin-top: 8px;
            font-size: 16px;
        }

        .card-panel {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: 12px;
            padding: 35px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
            margin-bottom: 50px;
        }

        .card-title {
            font-size: 22px;
            font-weight: 700;
            margin-bottom: 25px;
            color: #fff;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .form-row {
            display: flex;
            gap: 25px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .col-main {
            flex: 2;
            min-width: 300px;
        }

        .col-side {
            flex: 1;
            min-width: 150px;
        }

        label {
            display: block;
            color: #cfcfd3;
            margin-bottom: 8px;
            font-weight: 600;
            font-size: 14px;
        }

        input[type="text"], input[type="number"], textarea {
            width: 100%;
            padding: 14px;
            background: rgba(0, 0, 0, 0.4);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #fff;
            border-radius: 10px;
            box-sizing: border-box;
            font-size: 15px;
            transition: 0.2s;
        }

            input:focus, textarea:focus {
                border-color: #6b4bff;
                background: rgba(0, 0, 0, 0.6);
                outline: none;
            }

        .controls {
            display: flex;
            gap: 15px;
            margin-top: 25px;
            padding-bottom: 20px;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .btn-primary {
            background: linear-gradient(90deg, #6b4bff, #8b5cff);
            color: #fff;
            border: none;
            padding: 12px 24px;
            border-radius: 10px;
            font-weight: 700;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: 0.3s;
        }

            .btn-primary:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 20px rgba(107, 75, 255, 0.4);
            }

        .btn-outline {
            background: transparent;
            border: 1px solid rgba(255, 255, 255, 0.15);
            color: #ddd;
            padding: 12px 24px;
            border-radius: 10px;
            cursor: pointer;
            font-weight: 600;
            text-decoration: none;
            display: inline-block;
        }

        summary {
            cursor: pointer;
            color: #8b5cff;
            font-weight: 700;
            font-size: 18px;
            padding: 15px 0;
            list-style: none;
            display: flex;
            align-items: center;
            gap: 10px;
            outline: none;
        }

            summary::-webkit-details-marker {
                display: none;
            }

        fieldset.question-block {
            background: rgba(255, 255, 255, 0.02);
            padding: 25px;
            border-radius: 12px;
            margin-bottom: 20px;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        legend {
            font-weight: 800;
            color: #fff;
            padding: 0 10px;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .options-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin: 15px 0;
        }

        .correct-selection {
            background: rgba(107, 75, 255, 0.05);
            padding: 15px;
            border-radius: 8px;
            display: flex;
            gap: 20px;
            align-items: center;
        }

        .radio-label {
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            font-weight: 700;
        }

        .small-muted {
            color: #9b9b9f;
            font-size: 12px;
            margin-top: 6px;
        }

        .finalize-area {
            text-align: right;
            margin-top: 40px;
            padding-top: 25px;
            border-top: 1px solid rgba(255,255,255,0.1);
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="page-header">
            <h1 class="page-title">Manage Tests</h1>
            <p class="page-sub">Create and configure entrance examinations for Durban Girls Secondary School.</p>
        </div>

        <div class="card-panel">
            <div class="card-title">
                <i class="fa-solid fa-file-signature" style="color: #6b4bff;"></i>
                Test Configuration
            </div>

            @using (Html.BeginForm("Create", "Entrance_test", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                @* This summary will now show errors if the mapping fails *@
                @Html.ValidationSummary(false, "", new { style = "color: #ff4d4d; margin-bottom: 20px; font-weight: bold;" })

                <div class="form-row">
                    <div class="col-main">
                        <label for="Title">Test Title</label>
                        @Html.TextBoxFor(m => m.Title, new { placeholder = "e.g., Grade Intake: English Proficiency", required = "required" })
                    </div>

                    <div class="col-side">
                        <label for="DurationMinutes">Duration (minutes)</label>
                        @Html.TextBoxFor(m => m.DurationMinutes, new { type = "number", min = "1", @value = "60" })
                        <div class="small-muted">Countdown shown to candidates</div>
                    </div>
                </div>

                <div style="margin-bottom:20px;">
                    <label for="Description">Admin Instructions / Description</label>
                    @Html.TextAreaFor(m => m.Description, new { placeholder = "Provide details about the test scope...", rows = 3 })
                </div>

                <div class="controls">
                    <button type="button" class="btn-primary" onclick="document.querySelector('details').open = true;">
                        <i class="fa-solid fa-list-ol"></i> CONFIGURE QUESTIONS
                    </button>
                    <a href="@Url.Action("Index", "Entrance_test")" class="btn-outline">CANCEL & EXIT</a>
                </div>

                <details class="questions">
                    <summary>
                        <i class="fa-solid fa-circle-chevron-down"></i>
                        Question Bank (5 Multiple Choice Questions)
                    </summary>

                    @* THE CRITICAL FIX IS IN THIS LOOP *@
                    @{
                        string[] numberWords = { "One", "Two", "Three", "Four", "Five" };
                    }

                    @for (int i = 1; i <= 5; i++)
                    {
                        string word = numberWords[i - 1];

                        // Matches model properties: QuetionOne, AnswerOneAA, etc.
                        string qField = "Quetion" + word;
                        string aaField = "Answer" + word + "AA";
                        string bbField = "Answer" + word + "BB";
                        string ccField = "Answer" + word + "CC";

                        // Matches Controller Parameters: string CorrectAnswerOne, etc.
                        string correctParamName = "CorrectAnswer" + word;

                        <fieldset class="question-block">
                            <legend>Question @i</legend>

                            <div style="margin-bottom:15px;">
                                <label>Question text</label>
                                @Html.TextBox(qField, null, new { placeholder = "Type your question...", required = "required" })
                            </div>

                            <div class="options-grid">
                                <div>
                                    <label>Option A</label>
                                    @Html.TextBox(aaField, null, new { placeholder = "Option A", required = "required" })
                                </div>
                                <div>
                                    <label>Option B</label>
                                    @Html.TextBox(bbField, null, new { placeholder = "Option B", required = "required" })
                                </div>
                                <div>
                                    <label>Option C</label>
                                    @Html.TextBox(ccField, null, new { placeholder = "Option C", required = "required" })
                                </div>
                            </div>

                            <div class="correct-selection">
                                <span style="font-size:12px; font-weight:800; color:#8b5cff; text-transform:uppercase; letter-spacing: 0.5px;">Mark Correct:</span>
                                <label class="radio-label">@Html.RadioButton(correctParamName, "A", true) A</label>
                                <label class="radio-label">@Html.RadioButton(correctParamName, "B") B</label>
                                <label class="radio-label">@Html.RadioButton(correctParamName, "C") C</label>
                            </div>
                        </fieldset>
                    }

                    <div class="finalize-area">
                        <button type="submit" class="btn-primary" style="padding: 18px 50px; font-size: 16px;">
                            <i class="fa-solid fa-cloud-arrow-up"></i> STORE & FINALIZE TEST
                        </button>
                        <p class="small-muted" style="margin-top:10px;">Once stored, the test will appear on your dashboard ready for publishing.</p>
                    </div>
                </details>
            }
        </div>
    </div>
</body>
</html>