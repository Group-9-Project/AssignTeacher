@{
    Layout = null; // Disables the shared layout to fix scrolling and styling conflicts
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Entrance Test Management - DGSS</title>

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">

    <style>
        /* CRITICAL: Force the page to be scrollable */
        html, body {
            height: auto;
            min-height: 100%;
            overflow-y: auto;
            background: #0f0f10;
            color: #e6e6e9;
            font-family: 'Inter', 'Segoe UI', sans-serif;
            margin: 0;
            padding: 0;
        }

        .container {
            max-width: 1100px;
            margin: 0 auto;
            padding: 60px 20px; /* Added more vertical padding */
        }

        /* Header Section */
        .dashboard-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
        }

        .page-title {
            font-size: 32px;
            font-weight: 700;
            margin: 0;
            letter-spacing: -0.5px;
        }

        .page-sub {
            color: #9b9b9f;
            margin-top: 5px;
            font-size: 15px;
        }

        /* Action Card */
        .create-card {
            background: linear-gradient(135deg, rgba(107, 75, 255, 0.15), rgba(139, 92, 255, 0.05));
            border: 1px dashed rgba(107, 75, 255, 0.4);
            border-radius: 12px;
            padding: 40px 30px;
            text-align: center;
            margin-bottom: 40px;
            transition: 0.3s;
        }

            .create-card:hover {
                border-color: #8b5cff;
                background: rgba(107, 75, 255, 0.2);
            }

        /* Glass Panels */
        .glass-panel {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: 12px;
            padding: 25px;
            margin-bottom: 50px; /* Space at bottom for scrolling clearance */
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
        }

        .panel-title {
            font-size: 20px;
            font-weight: 600;
            margin-bottom: 25px;
            color: #fff;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            padding-bottom: 12px;
        }

        /* Table Styling */
        .custom-table {
            width: 100%;
            border-collapse: collapse;
        }

            .custom-table th {
                text-align: left;
                color: #8b5cff;
                padding: 15px;
                border-bottom: 2px solid rgba(139, 92, 255, 0.2);
                text-transform: uppercase;
                font-size: 12px;
                letter-spacing: 1px;
            }

            .custom-table td {
                padding: 20px 15px;
                border-bottom: 1px solid rgba(255, 255, 255, 0.05);
                vertical-align: middle;
            }

        /* Form Controls */
        .publish-form {
            display: flex;
            gap: 15px;
            align-items: flex-end;
            flex-wrap: wrap;
        }

        .input-dark {
            background: rgba(0, 0, 0, 0.4);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #fff;
            padding: 10px 12px;
            border-radius: 8px;
            font-size: 13px;
            margin-top: 5px;
            outline: none;
            transition: 0.2s;
        }

            .input-dark:focus {
                border-color: #6b4bff;
                background: rgba(0,0,0,0.6);
            }

        /* Buttons */
        .btn-main {
            background: #6b4bff;
            color: #fff;
            border: none;
            padding: 12px 28px;
            border-radius: 10px;
            font-weight: 600;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            transition: 0.3s;
            cursor: pointer;
        }

            .btn-main:hover {
                background: #8b5cff;
                transform: translateY(-2px);
                box-shadow: 0 5px 20px rgba(107, 75, 255, 0.4);
            }

        .btn-publish {
            background: #27ae60;
            color: #fff;
            border: none;
            padding: 10px 20px;
            border-radius: 8px;
            font-size: 12px;
            font-weight: 700;
            cursor: pointer;
            transition: 0.2s;
        }

            .btn-publish:hover {
                background: #2ecc71;
                transform: scale(1.02);
            }

        .status-badge {
            background: rgba(139, 92, 255, 0.2);
            color: #b599ff;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 10px;
            font-weight: 800;
            text-transform: uppercase;
        }

        .alert-success {
            background: rgba(46, 204, 113, 0.15);
            color: #2ecc71;
            padding: 15px 20px;
            border-radius: 10px;
            margin-bottom: 25px;
            border: 1px solid rgba(46, 204, 113, 0.3);
            display: flex;
            align-items: center;
            gap: 10px;
        }
    </style>
</head>
<body>

    @model IEnumerable<SchoolTimetable.Models.Entrance_test>

    <div class="container">
        <div class="dashboard-header">
            <div>
                <h1 class="page-title">Test & Admissions</h1>
                <p class="page-sub">Manage entrance criteria and invite eligible candidates for DGSS.</p>
            </div>
        </div>

        <div class="create-card">
            <h3 style="margin-top:0; font-size: 24px;">Design a New Examination</h3>
            <p style="color: #bdbdc1; margin-bottom: 25px; max-width: 500px; margin-left: auto; margin-right: auto;">
                Configure questions, options, and duration for upcoming Grade 8 intakes.
            </p>
            <a href="@Url.Action("Create", "Entrance_test")" class="btn-main">
                <i class="fa-solid fa-circle-plus"></i> CREATE ENTRANCE TEST
            </a>
        </div>

        <div class="glass-panel">
            <div class="panel-title">Active Test Inventory & Scheduling</div>

            @if (TempData["Success"] != null)
            {
                <div class="alert-success">
                    <i class="fa-solid fa-circle-check"></i>
                    @TempData["Success"]
                </div>
            }

            <table class="custom-table">
                <thead>
                    <tr>
                        <th>Test Information</th>
                        <th>Duration</th>
                        <th>Structure</th>
                        <th>Schedule & Invite</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <span class="status-badge">Test ID: @item.TestId</span><br />
                                <strong style="font-size:17px; display:block; margin-top:8px; color: #fff;">@item.Title</strong>
                            </td>
                            <td>
                                <span style="color: #9b9b9f;"><i class="fa-regular fa-clock" style="margin-right:5px;"></i> @item.DurationMinutes Mins</span>
                            </td>
                            <td>
                                <span style="color: #9b9b9f;"><i class="fa-solid fa-list-check" style="margin-right:5px;"></i> 5 Questions</span>
                            </td>
                            <td>
                                @using (Html.BeginForm("PublishAndInvite", "Admin", FormMethod.Post, new { @class = "publish-form" }))
                                {
                                    @Html.AntiForgeryToken()
                                    @Html.Hidden("id", item.TestId)

                                    <div>
                                        <label style="font-size:11px; font-weight:700; color:#8b5cff; text-transform:uppercase;">Date</label>
                                        <input type="date" name="testDate" required class="input-dark" />
                                    </div>
                                    <div>
                                        <label style="font-size:11px; font-weight:700; color:#8b5cff; text-transform:uppercase;">Start Time</label>
                                        <input type="time" name="testTime" required class="input-dark" />
                                    </div>
                                    <div>
                                        <button type="submit" class="btn-publish" onclick="return confirm('Send email invitations to all parents of paid students for @item.Title?')">
                                            PUBLISH & INVITE
                                        </button>
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (!Model.Any())
            {
                <div style="text-align:center; padding: 60px 20px; color: #555;">
                    <i class="fa-solid fa-folder-open" style="font-size: 40px; margin-bottom: 15px; opacity: 0.3;"></i>
                    <p>No tests found. Click the button above to create your first entrance test.</p>
                </div>
            }
        </div>
    </div>

</body>
</html>