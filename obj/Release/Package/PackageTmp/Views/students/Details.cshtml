@model SchoolTimetable.ViewModels.StudentProfileViewModel
@using System.Web.Mvc

@{
    ViewBag.Title = Model.Student.FullName;
    Layout = null; // Ensuring no external layout interference
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registry: @Model.Student.FullName</title>

    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800&family=Barlow:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        :root {
            --navy-deep: #0a192f;
            --navy-muted: #112240;
            --navy-accent: #233554;
            --white-bright: #ffffff;
            --white-muted: #ccd6f6;
            --gold-accent: #c5a059;
            --status-red: #ff4d4d;
            --status-green: #64ffda;
        }

        body {
            margin: 0;
            padding: 0;
            background-color: var(--navy-deep);
            color: var(--white-muted);
            font-family: 'Barlow', sans-serif;
        }

        .profile-wrapper {
            max-width: 1300px;
            margin: 0 auto;
            padding: 40px 2rem;
        }

        /* Academic Header */
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
            border-bottom: 1px solid var(--navy-accent);
            padding-bottom: 20px;
        }

        .btn-back {
            text-decoration: none;
            color: var(--gold-accent);
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 800;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            border: 1px solid var(--gold-accent);
            padding: 8px 16px;
            transition: all 0.3s ease;
        }

            .btn-back:hover {
                background: var(--gold-accent);
                color: var(--navy-deep);
            }

        /* Layout Grid */
        .profile-grid {
            display: grid;
            grid-template-columns: 380px 1fr;
            gap: 30px;
            align-items: start;
        }

        .dg-card {
            background: var(--navy-muted);
            border: 1px solid var(--navy-accent);
            border-radius: 2px;
            overflow: hidden;
        }

        /* Identity Section */
        .card-padding {
            padding: 30px;
        }

        .student-name {
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 2.2rem;
            font-weight: 800;
            color: var(--white-bright);
            margin: 0;
            text-transform: uppercase;
            line-height: 1;
        }

        .student-email {
            color: var(--gold-accent);
            font-size: 0.9rem;
            margin: 10px 0 20px 0;
            letter-spacing: 0.5px;
        }

        /* Badges */
        .badge {
            padding: 4px 12px;
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 0.75rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            border-radius: 2px;
        }

        .badge-blue {
            background: var(--navy-accent);
            color: var(--white-bright);
        }

        .badge-red {
            background: var(--status-red);
            color: var(--navy-deep);
        }

        .badge-green {
            background: var(--status-green);
            color: var(--navy-deep);
        }

        /* Stats Grid */
        .stats-box {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
            margin: 25px 0;
        }

        .stat-item {
            background: var(--navy-deep);
            padding: 15px;
            text-align: center;
            border: 1px solid var(--navy-accent);
        }

        .stat-val {
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 1.8rem;
            font-weight: 800;
            color: var(--white-bright);
            display: block;
        }

        .stat-lab {
            font-size: 0.65rem;
            font-weight: 700;
            color: var(--gold-accent);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .danger .stat-val {
            color: var(--status-red);
        }

        /* Forms & Actions */
        .admin-block {
            margin-top: 20px;
            padding-top: 20px;
            border-top: 1px solid var(--navy-accent);
        }

        .form-control {
            width: 100%;
            background: var(--navy-deep);
            border: 1px solid var(--navy-accent);
            color: var(--white-bright);
            padding: 12px;
            margin-bottom: 15px;
            font-family: 'Barlow', sans-serif;
            box-sizing: border-box;
        }

        .btn-action {
            width: 100%;
            padding: 14px;
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            border: none;
            cursor: pointer;
            transition: opacity 0.3s ease;
        }

        /* Ledger Table */
        .dg-table {
            width: 100%;
            border-collapse: collapse;
        }

            .dg-table th {
                background: var(--navy-accent);
                color: var(--gold-accent);
                text-align: left;
                padding: 15px;
                font-family: 'Barlow Condensed', sans-serif;
                font-size: 0.85rem;
                text-transform: uppercase;
                letter-spacing: 1px;
            }

            .dg-table td {
                padding: 15px;
                border-bottom: 1px solid rgba(35, 53, 84, 0.4);
                font-size: 0.95rem;
            }

        .overdue-row {
            background: rgba(255, 77, 77, 0.05);
        }

        @@media (max-width: 992px) {
            .profile-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>

    <div class="profile-wrapper">
        <div class="page-header">
            <a href="@Url.Action("Index")" class="btn-back">← Registry Index</a>
            <div class="badge badge-blue">Archive Reference: @Model.Student.Id</div>
        </div>

        <div class="profile-grid">
            <aside>
                <div class="dg-card">
                    <div class="card-padding" style="text-align:center">
                        <h1 class="student-name">@Model.Student.FullName</h1>
                        <div class="student-email">@Model.Student.Email</div>

                        <div style="display:flex; justify-content:center; gap:8px; margin-top:10px;">
                            <span class="badge badge-blue">Grade @Model.Student.Grade</span>
                            @if (Model.Student.IsBlocked)
                            {<span class="badge badge-red">Account Blocked</span> }
                            else
                            { <span class="badge badge-green">Operational Status</span>}
                        </div>

                        <div class="stats-box">
                            <div class="stat-item">
                                <span class="stat-val">@Model.ActiveCount</span>
                                <span class="stat-lab">Active</span>
                            </div>
                            <div class="stat-item @(Model.OverdueCount > 0 ? "danger" : "")">
                                <span class="stat-val">@Model.OverdueCount</span>
                                <span class="stat-lab">Overdue</span>
                            </div>
                            <div class="stat-item @(Model.TotalFines > 0 ? "danger" : "")">
                                <span class="stat-val">R@Model.TotalFines.ToString("0")</span>
                                <span class="stat-lab">Fines</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-val">@Model.Borrowings.Count</span>
                                <span class="stat-lab">Total Issues</span>
                            </div>
                        </div>

                        @if (Model.Student.IsBlocked)
                        {
                            <div style="background:rgba(255, 77, 77, 0.1); border:1px solid var(--status-red); padding:15px; margin-bottom:20px; text-align:left;">
                                <strong style="color:var(--status-red); font-family:'Barlow Condensed'; font-size:0.8rem; letter-spacing:1px;">SUSPENSION LOG:</strong>
                                <div style="font-size:0.9rem; margin-top:8px;">@Model.Student.BlockReason</div>
                            </div>

                            using (Html.BeginForm("Unblock", "Students", FormMethod.Post))
                            {
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.Student.Id" />
                                <button type="submit" class="btn-action" style="background:var(--status-green); color:var(--navy-deep)" onclick="return confirm('Restore library privileges?')">
                                    Restore Access
                                </button>
                            }
                        }
                        else
                        {
                            <div class="admin-block" style="text-align:left;">
                                <h3 style="font-family:'Barlow Condensed'; font-size:0.8rem; letter-spacing:1.5px; color:var(--gold-accent); margin-bottom:15px; text-transform:uppercase;">Account Restriction</h3>
                                @using (Html.BeginForm("Block", "Students", FormMethod.Post))
                                {
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="StudentId" value="@Model.Student.Id" />
                                    <textarea name="BlockReason" class="form-control" rows="2" placeholder="LOG REASON FOR SUSPENSION..." required></textarea>
                                    <button type="submit" class="btn-action" style="background:var(--status-red); color:var(--white-bright)" onclick="return confirm('Suspend this account?')">
                                        Execute Block
                                    </button>
                                }
                            </div>
                        }
                    </div>
                </div>
            </aside>

            <main>
                <div class="dg-card">
                    <div style="background:var(--navy-accent); padding:15px 25px; display:flex; justify-content:space-between; align-items:center;">
                        <span style="font-family:'Barlow Condensed'; font-weight:800; text-transform:uppercase; letter-spacing:2px; color:var(--white-bright)">Borrowing Ledger</span>
                        @if (Model.ActiveCount > 0 || Model.OverdueCount > 0)
                        {
                            <a href="@Url.Action("Index","Borrowings")" style="color:var(--gold-accent); font-family:'Barlow Condensed'; font-size:0.8rem; text-decoration:none; font-weight:700;">SYSTEM MGMT →</a>
                        }
                    </div>

                    <div style="overflow-x:auto;">
                        <table class="dg-table">
                            <thead>
                                <tr>
                                    <th>Catalog Item</th>
                                    <th>Maturity Date</th>
                                    <th>Status</th>
                                    <th>Fine Balance</th>
                                    <th style="text-align:right">Command</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Borrowings != null && Model.Borrowings.Any())
                                {
                                    foreach (var b in Model.Borrowings)
                                    {
                                        var isOvd = b.Status == SchoolTimetable.Models.BorrowStatus.Overdue;
                                        <tr class="@(isOvd ? "overdue-row" : "")">
                                            <td>
                                                <div style="font-weight:600; color:var(--white-bright)">@b.Book.Title</div>
                                                <div style="font-size:0.75rem; opacity:0.6;">ISSUED: @b.BorrowedDate.ToString("dd MMM yyyy")</div>
                                            </td>
                                            <td style="@(isOvd ? "color:var(--status-red); font-weight:800;" : "")">
                                                @b.DueDate.ToString("dd MMM yyyy")
                                            </td>
                                            <td><span class="badge badge-blue">@b.Status</span></td>
                                            <td style="font-weight:bold; color:@(b.FineAmount > 0 && !b.FinePaid ? "var(--status-red)" : "var(--gold-accent)")">
                                                @if (b.FineAmount > 0)
                                                {
                                                    <span>R@b.FineAmount.ToString("0.00")</span>
                                                    if (b.FinePaid)
                                                    { <small style="opacity:0.6"> (PAID)</small> }
                                                }
                                                else
                                                { <span style="opacity:0.3">—</span>}
                                            </td>
                                            <td style="text-align:right">
                                                @if (b.Status == SchoolTimetable.Models.BorrowStatus.Active || b.Status == SchoolTimetable.Models.BorrowStatus.Overdue)
                                                {
                                                    using (Html.BeginForm("Return", "Borrowings", FormMethod.Post))
                                                    {
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@b.Id" />
                                                        <input type="hidden" name="returnTo" value="@Url.Action("Details", "Students", new { id = Model.Student.Id })" />
                                                        <button type="submit" class="badge badge-green" style="cursor:pointer; border:none;">Process Return</button>
                                                    }
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" style="text-align:center; padding:5rem; opacity:0.4; font-family:'Barlow Condensed'; letter-spacing:2px;">
                                            NO ARCHIVAL BORROWING DATA FOUND
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </main>
        </div>
    </div>

</body>
</html>