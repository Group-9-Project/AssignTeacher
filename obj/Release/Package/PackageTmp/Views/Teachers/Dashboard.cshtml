@model IEnumerable<SchoolTimetable.Models.TimetableSlot>
@{
    ViewBag.Title = "Teacher Dashboard";
    Layout = null; /* Standalone page - No Layout used */
    var teacherName = Session["TeacherName"] ?? "Teacher";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard :: @teacherName</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --navy-dark: #001a33;
            --navy-primary: #002b5c;
            --navy-light: #003d82;
            --white: #ffffff;
            --off-white: #f4f7f9;
        }

        body {
            font-family: 'Inter', sans-serif;
            color: var(--navy-dark);
            background-color: var(--off-white);
            margin: 0;
            padding: 0;
        }

        /* Dashboard Header */
        .dashboard-header {
            background: var(--navy-primary);
            padding: 30px 50px;
            border-bottom: 4px solid var(--navy-dark);
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: var(--white);
        }

        .welcome-text {
            font-weight: 800;
            text-transform: uppercase;
            margin: 0;
            font-size: 1.8rem;
            letter-spacing: -1px;
        }

        .header-sub {
            font-size: 0.8rem;
            color: var(--white);
            font-weight: 600;
            text-transform: uppercase;
            margin-top: 5px;
            letter-spacing: 1px;
            opacity: 0.9;
        }

        /* Container */
        .container {
            padding: 40px 50px;
        }

        /* Cards & Layout */
        .row {
            display: flex;
            gap: 30px;
            flex-wrap: wrap;
        }

        .col-main {
            flex: 2;
            min-width: 300px;
        }

        .col-side {
            flex: 1;
            min-width: 250px;
        }

        .card {
            background: var(--white);
            border: 2px solid var(--navy-primary);
            border-radius: 0;
            overflow: hidden;
            box-shadow: 8px 8px 0px rgba(0, 43, 92, 0.1);
        }

        .card-header {
            font-weight: 800;
            padding: 18px 25px;
            text-transform: uppercase;
            font-size: 0.85rem;
            letter-spacing: 1.5px;
            background-color: var(--navy-primary);
            color: var(--white);
            border-bottom: 2px solid var(--navy-dark);
        }

        /* Table Styling */
        .table {
            width: 100%;
            border-collapse: collapse;
        }

            .table thead th {
                background: #e6ecf2;
                text-transform: uppercase;
                font-size: 0.7rem;
                font-weight: 800;
                letter-spacing: 1px;
                color: var(--navy-primary);
                padding: 15px 25px;
                border-bottom: 2px solid var(--navy-primary);
                text-align: left;
            }

            .table tbody td {
                padding: 18px 25px;
                border-bottom: 1px solid #e6ecf2;
                font-size: 0.9rem;
            }

            .table tbody tr:hover {
                background-color: #f9fbff;
            }

        .badge-subject {
            padding: 6px 12px;
            font-weight: 800;
            font-size: 11px;
            text-transform: uppercase;
            border: 2px solid var(--navy-primary);
            color: var(--navy-primary);
            display: inline-block;
        }

        .class-name {
            font-weight: 800;
            color: var(--navy-primary);
        }

        /* Quick Actions */
        .list-group-item {
            padding: 20px 25px;
            font-weight: 800;
            font-size: 0.75rem;
            text-transform: uppercase;
            text-decoration: none;
            display: block;
            color: var(--navy-primary);
            border-bottom: 1px solid #e6ecf2;
            transition: all 0.2s;
            letter-spacing: 0.5px;
        }

            .list-group-item:last-child {
                border-bottom: none;
            }

            .list-group-item:hover {
                background-color: var(--navy-primary);
                color: var(--white);
                padding-left: 35px;
            }

        /* Buttons */
        .btn-logout {
            padding: 12px 25px;
            border: 2px solid var(--white);
            color: var(--white);
            text-transform: uppercase;
            font-weight: 800;
            font-size: 0.75rem;
            text-decoration: none;
            transition: all 0.2s;
        }

            .btn-logout:hover {
                background: var(--white);
                color: var(--navy-primary);
            }

        /* Icon Override */
        i, .fas, .far {
            display: none !important;
        }
    </style>
</head>
<body>

    <div class="dashboard-header">
        <div>
            <h2 class="welcome-text">WELCOME, @teacherName</h2>
            <div class="header-sub">Academic Portal :: Management Dashboard</div>
        </div>
        <a href="@Url.Action("Login", "Teachers")" class="btn-logout">
            Logout
        </a>
    </div>

    <div class="container">
        <div class="row">
            <div class="col-main">
                <div class="card">
                    <div class="card-header">
                        Assigned Schedule
                    </div>
                    <div style="overflow-x: auto;">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Day of Week</th>
                                    <th>Period</th>
                                    <th>Subject</th>
                                    <th>Class Room</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td style="font-weight: 800; color: var(--navy-dark);">
                                            @((DayOfWeek)item.DayOfWeek)
                                        </td>
                                        <td>
                                            <span style="font-size: 11px; font-weight: 800; color: var(--navy-light);">PERIOD</span>
                                            <span style="font-weight: 800;">@item.Period</span>
                                        </td>
                                        <td>
                                            <div class="badge-subject">
                                                @item.Subject.Name
                                            </div>
                                        </td>
                                        <td class="class-name">@item.Class.Name</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-side">
                <div class="card">
                    <div class="card-header">
                        Quick Management
                    </div>
                    <div class="list-group">
                        <a href="@Url.Action("UploadMaterial", "Teachers")" class="list-group-item">
                            Upload Learning Material
                        </a>
                        <a href="@Url.Action("CreateAnnouncement", "Teachers")" class="list-group-item">
                            Post New Announcement
                        </a>
                        <a href="@Url.Action("Details", "Teachers", new { id = Session["TeacherId"] })" class="list-group-item">
                            Account Profile
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

</body>
</html>