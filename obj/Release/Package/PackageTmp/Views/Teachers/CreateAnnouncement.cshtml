@model IEnumerable<SchoolTimetable.Models.Announcement>
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create Announcement</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
</head>
<body style="font-family: 'Inter', sans-serif; color: #001a33; background-color: #f4f7f9; margin: 0; padding: 40px; display: flex; justify-content: center; align-items: flex-start; min-height: 100vh;">

    <div style="background: #ffffff; border: 2px solid #002b5c; padding: 40px; width: 100%; max-width: 550px; box-shadow: 8px 8px 0px rgba(0, 43, 92, 0.1);">

        <h1 style="font-size: 1.5rem; font-weight: 800; text-transform: uppercase; margin: 0 0 25px 0; color: #002b5c; letter-spacing: -0.5px; border-bottom: 4px solid #002b5c; padding-bottom: 10px;">
            New Announcement
        </h1>

        @using (Html.BeginForm("CreateAnnouncement", "Teachers", FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            <div style="display: flex; flex-direction: column; gap: 8px; margin-bottom: 1.5rem;">
                <label style="font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: #002b5c; letter-spacing: 1.2px;">Target Class</label>
                @Html.DropDownList("SchoolClassId", (SelectList)ViewBag.ClassId, "ALL MY CLASSES", new
                {
                    style = "padding: 12px; border: 2px solid #002b5c; border-radius: 0; font-family: inherit; font-size: 0.95rem; color: #001a33; width: 100%; box-sizing: border-box; background-color: #ffffff;"
                })
                <small style="font-size: 0.7rem; color: #003d82; margin-top: 6px; font-weight: 600; text-transform: uppercase;">Select a specific class or leave blank for all students.</small>
            </div>

            <div style="display: flex; flex-direction: column; gap: 8px; margin-bottom: 1.5rem;">
                <label style="font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: #002b5c; letter-spacing: 1.2px;">Subject / Title</label>
                <input type="text" name="Title" required placeholder="E.G. TERM 2 PROJECT BRIEF"
                       style="padding: 12px; border: 2px solid #002b5c; border-radius: 0; font-family: inherit; font-size: 0.95rem; color: #001a33; width: 100%; box-sizing: border-box; background-color: #ffffff;" />
            </div>

            <div style="display: flex; flex-direction: column; gap: 8px; margin-bottom: 1.5rem;">
                <label style="font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: #002b5c; letter-spacing: 1.2px;">Announcement Message</label>
                <textarea name="Message" rows="5" required placeholder="TYPE YOUR MESSAGE HERE..."
                          style="padding: 12px; border: 2px solid #002b5c; border-radius: 0; font-family: inherit; font-size: 0.95rem; color: #001a33; width: 100%; box-sizing: border-box; background-color: #ffffff; resize: vertical;"></textarea>
            </div>

            <div style="padding-top: 10px;">
                <button type="submit"
                        style="padding: 14px 28px; font-weight: 800; text-transform: uppercase; cursor: pointer; font-size: 0.75rem; background: #002b5c; color: #ffffff; border: none; width: 100%; letter-spacing: 1px; transition: background 0.2s;">
                    Post Announcement
                </button>
            </div>
            <a href="@Url.Action("Dashboard", "Teachers")"
               style="flex: 1; padding: 14px 28px; font-weight: 800; text-transform: uppercase; cursor: pointer; font-size: 0.75rem; background: transparent; color: #002b5c; border: 2px solid #002b5c; text-align: center; text-decoration: none; letter-spacing: 1px;">
                Back
            </a>
        }
    </div>

</body>
</html>