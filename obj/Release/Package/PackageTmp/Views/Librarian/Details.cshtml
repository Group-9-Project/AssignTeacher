@model SchoolTimetable.ViewModels.StudentProfileViewModel
@using System.Web.Mvc

@{
    Layout = null;
    ViewBag.Title = Model.Student.FullName;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Student Profile</title>
    <style>
        :root {
            --dgss-navy: #002147;
            --dgss-white: #ffffff;
            --dgss-bg: #ffffff;
            --dgss-border: #002147;
            --dgss-accent: #0056b3;
            --critical-red: #d93025;
            --success-green: #1e7e34;
            --slate-text: #475569;
            --alice-blue: #f0f8ff;
        }

        body {
            margin: 0;
            padding: 0;
            background-color: var(--dgss-white);
            color: var(--dgss-navy);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .profile-wrapper {
            max-width: 1200px;
            margin: 2rem auto;
            padding: 0 1.5rem;
        }

        /* Alerts */
        .alert {
            padding: 15px;
            margin-bottom: 20px;
            border: 2px solid;
            font-weight: 800;
            text-transform: uppercase;
            font-size: 0.8rem;
        }

        .alert-success {
            background: #d4edda;
            color: #155724;
            border-color: #c3e6cb;
        }

        .alert-danger {
            background: #f8d7da;
            color: #721c24;
            border-color: #f5c6cb;
        }

        /* Academic Header */
        .page-header {
            border-bottom: 4px solid var(--dgss-navy);
            padding-bottom: 1rem;
            margin-bottom: 2.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .btn-back {
            text-decoration: none;
            color: var(--dgss-navy);
            font-weight: 800;
            font-size: 0.85rem;
            text-transform: uppercase;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        /* Grid Layout */
        .profile-grid {
            display: grid;
            grid-template-columns: 380px 1fr;
            gap: 2.5rem;
            align-items: start;
        }

        .dg-card {
            background: var(--dgss-white);
            border: 2px solid var(--dgss-navy);
        }

        .card-padding {
            padding: 2rem;
        }

        /* Identity */
        .student-name {
            font-size: 2rem;
            font-weight: 900;
            color: var(--dgss-navy);
            margin: 0;
            text-transform: uppercase;
        }

        .student-email {
            color: var(--dgss-accent);
            font-size: 0.95rem;
            margin-bottom: 1.5rem;
            font-family: monospace;
        }

        /* Badges & Buttons */
        .badge {
            padding: 6px 12px;
            font-size: 0.7rem;
            font-weight: 800;
            text-transform: uppercase;
            border: 2px solid;
            display: inline-block;
        }

        .badge-navy {
            background: var(--dgss-navy);
            color: white;
            border-color: var(--dgss-navy);
        }

        .badge-red {
            background: var(--critical-red);
            color: white;
            border-color: var(--critical-red);
        }

        .btn-dg {
            width: 100%;
            padding: 12px;
            font-weight: 900;
            text-transform: uppercase;
            border: none;
            cursor: pointer;
            margin-top: 10px;
        }

        .btn-danger {
            background: var(--critical-red);
            color: white;
        }

        .btn-success {
            background: var(--success-green);
            color: white;
        }

        .form-control {
            width: 100%;
            box-sizing: border-box;
            padding: 10px;
            border: 2px solid var(--dgss-navy);
            margin-bottom: 5px;
            font-family: inherit;
            resize: none;
        }

        /* Stats Box */
        .stats-box {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2px;
            background: var(--dgss-navy);
            border: 2px solid var(--dgss-navy);
            margin: 2rem 0;
        }

        .stat-item {
            background: var(--dgss-white);
            padding: 1.25rem;
            text-align: center;
        }

        .stat-val {
            font-size: 1.4rem;
            font-weight: 900;
            color: var(--dgss-navy);
            display: block;
        }

        .stat-lab {
            font-size: 0.65rem;
            font-weight: 800;
            color: var(--slate-text);
            text-transform: uppercase;
        }

        /* Table */
        .dg-table {
            width: 100%;
            border-collapse: collapse;
        }

            .dg-table th {
                background: var(--dgss-navy);
                color: white;
                text-align: left;
                padding: 15px;
                font-size: 0.75rem;
                text-transform: uppercase;
            }

            .dg-table td {
                padding: 15px;
                border-bottom: 1px solid #e2e8f0;
                font-size: 0.95rem;
            }

        .overdue-row {
            background: #fff5f5;
        }
    </style>
</head>
<body>

    <div class="profile-wrapper">
        @* Alert Messages *@
        @if (TempData["Success"] != null)
        {<div class="alert alert-success">@TempData["Success"]</div>}
        @if (TempData["Error"] != null)
        {<div class="alert alert-danger">@TempData["Error"]</div>}

        <div class="page-header">
            <a href="@Url.Action("Members")" class="btn-back">
                <span>&#10229;</span> Back to Student Registry
            </a>
            <div class="badge badge-navy">Student ID: @Model.Student.Id</div>
        </div>

        <div class="profile-grid">
            <aside>
                <div class="dg-card">
                    <div class="card-padding" style="text-align:center">
                        <h1 class="student-name">@Model.Student.FullName</h1>
                        <div class="student-email">@Model.Student.Email</div>

                        <div style="margin-top:20px;">
                            @if (Model.Student.IsBlocked)
                            {
                                <div style="background:#fff0f0; border:1px solid var(--critical-red); padding:1rem; margin-bottom:1rem; text-align:left;">
                                    <strong style="color:var(--critical-red); font-size:0.75rem; text-transform:uppercase;">Suspension Reason:</strong>
                                    <div style="font-size:0.9rem; margin-top:5px; color:#000;">@Model.Student.BlockReason</div>
                                </div>

                                using (Html.BeginForm("Unblock", "Librarian", FormMethod.Post))
                                {
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@Model.Student.Id" />
                                    <button type="submit" class="btn-dg btn-success" onclick="return confirm('Restore library privileges?')">
                                        Lift Suspension
                                    </button>
                                }
                            }
                            else
                            {
                                <div style="text-align:left; border-top:1px solid #eee; padding-top:1rem;">
                                    <h3 style="font-size:0.75rem; text-transform:uppercase; color:var(--slate-text); margin-bottom:10px;">Account Security</h3>
                                    @using (Html.BeginForm("Block", "Librarian", FormMethod.Post))
                                    {
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="StudentId" value="@Model.Student.Id" />
                                        <textarea name="BlockReason" class="form-control" rows="2" placeholder="Reason for blocking..." required></textarea>
                                        <button type="submit" class="btn-dg btn-danger" onclick="return confirm('Suspend this account?')">
                                            Suspend Student
                                        </button>
                                    }
                                </div>
                            }
                        </div>

                        <div class="stats-box">
                            <div class="stat-item">
                                <span class="stat-val">@Model.ActiveCount</span>
                                <span class="stat-lab">On Loan</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-val" style="@(Model.OverdueCount > 0 ? "color:var(--critical-red)" : "")">@Model.OverdueCount</span>
                                <span class="stat-lab">Overdue</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-val">R @Model.TotalFines.ToString("0.00")</span>
                                <span class="stat-lab">Balance</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-val">@Model.Borrowings.Count</span>
                                <span class="stat-lab">History</span>
                            </div>
                        </div>
                    </div>
                </div>
            </aside>

            <main>
                <div class="dg-card">
                    <div style="background:var(--dgss-navy); color:white; padding:1.25rem 1.5rem;">
                        <span style="font-weight:900; text-transform:uppercase; letter-spacing:2px; font-size:0.85rem;">Borrowing History Ledger</span>
                    </div>
                    <div style="overflow-x:auto;">
                        <table class="dg-table">
                            <thead>
                                <tr>
                                    <th>Item Details</th>
                                    <th>Deadline</th>
                                    <th>Status</th>
                                    <th>Fine (ZAR)</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Borrowings != null && Model.Borrowings.Any())
                                {
                                    foreach (var b in Model.Borrowings)
                                    {
                                        var isOvd = b.Status == SchoolTimetable.Models.BorrowStatus.Overdue;
                                        <tr class="@(isOvd ? "overdue-row" : "")">
                                            <td>
                                                <div style="font-weight:800; color:var(--dgss-navy); text-transform: uppercase; font-size: 0.8rem;">@b.Book.Title</div>
                                                <div style="font-size:0.7rem; color:var(--slate-text);">Issued: @b.BorrowedDate.ToString("dd MMM yyyy")</div>
                                            </td>
                                            <td style="@(isOvd ? "color:var(--critical-red); font-weight:900;" : "font-weight:700;")">
                                                @b.DueDate.ToString("dd MMM yyyy")
                                            </td>
                                            <td>
                                                <span class="badge @(isOvd ? "badge-red" : "badge-navy")" style="font-size: 0.6rem;">@b.Status</span>
                                            </td>
                                            <td style="font-weight:800;">
                                                @if (b.FineAmount > 0)
                                                {
                                                    <span>R @b.FineAmount.ToString("0.00")</span>
                                                    if (b.FinePaid)
                                                    { <span style="color:var(--success-green); font-size: 0.65rem;">(PAID)</span> }
                                                }
                                                else
                                                { <span>—</span>}
                                            </td>
                                            <td>
                                                @if (b.Status != SchoolTimetable.Models.BorrowStatus.Returned)
                                                {
                                                    using (Html.BeginForm("Return", "Borrowings", FormMethod.Post))
                                                    {
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@b.Id" />
                                                        <input type="hidden" name="returnTo" value="@Url.Action("Details", "Librarian", new { id = Model.Student.Id })" />
                                                        <button type="submit" class="badge" style="border:none; cursor:pointer; background:var(--success-green); color:white; border-color:var(--success-green)">Process Return</button>
                                                    }
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" style="text-align:center; padding:4rem; color:var(--slate-text); font-style:italic;">
                                            No activity records found for this student.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </main>
        </div>
    </div>

</body>
</html>