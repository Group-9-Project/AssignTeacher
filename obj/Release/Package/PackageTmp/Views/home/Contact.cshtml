@{
    ViewBag.Title = "Contact";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Durban Girls Secondary School</title>
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800&family=Barlow:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        :root {
            --navy-deep: #050c18;
            --navy-card: rgba(10, 25, 47, 0.85);
            --navy-accent: #112240;
            --gold-subtle: #c5a059;
            --white-bright: #e6f1ff;
            --white-muted: #8892b0;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Barlow', sans-serif;
            background: var(--navy-deep);
            color: var(--white-muted);
            line-height: 1.6;
            min-height: 110vh; /* Force scrollability */
            overflow-x: hidden;
        }

        .page-bg-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, rgba(5, 12, 24, 0.95), rgba(5, 12, 24, 0.8)), url('/Content/Images/tp-image-3986.jpg');
            background-size: cover;
            background-position: center;
            z-index: -1;
        }

        nav {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1rem 5%;
            background: rgba(5, 12, 24, 0.9);
            backdrop-filter: blur(15px);
            border-bottom: 1px solid var(--navy-accent);
        }

        .nav-logo-container {
            display: flex;
            align-items: center;
            gap: 15px;
            text-decoration: none;
        }

        .school-crest-nav {
            height: 45px;
            filter: brightness(0.9);
        }

        .nav-logo-text {
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 1.2rem;
            font-weight: 800;
            color: var(--white-bright);
            letter-spacing: 1px;
            text-transform: uppercase;
            line-height: 1;
        }

        .nav-links-wrapper {
            display: flex;
            list-style: none;
            gap: 2.5rem;
        }

        .nav-link {
            text-decoration: none;
            color: var(--white-muted);
            font-size: 0.8rem;
            text-transform: uppercase;
            font-weight: 600;
            letter-spacing: 2px;
            transition: 0.3s;
        }

            .nav-link:hover, .active-link {
                color: var(--gold-subtle);
            }

        .btn-portal {
            border: 1px solid var(--gold-subtle);
            color: var(--gold-subtle);
            padding: 0.5rem 1.2rem;
            font-size: 0.75rem;
            text-decoration: none;
            text-transform: uppercase;
            font-weight: 700;
            transition: 0.3s;
        }

        /* Removed flex-centering from wrapper */
        .contact-wrapper {
            max-width: 1200px;
            margin: 0 auto;
            padding: 160px 5% 100px;
            text-align: left;
        }

        .contact-card {
            width: 100%;
            max-width: 1000px;
            background: var(--navy-card);
            padding: 5rem 4rem;
            border-radius: 4px;
            border: 1px solid var(--navy-accent);
            box-shadow: 0 20px 40px rgba(0,0,0,0.4);
        }

        .section-tag {
            text-transform: uppercase;
            letter-spacing: 4px;
            font-weight: 700;
            font-size: 0.8rem;
            color: var(--gold-subtle);
            margin-bottom: 10px;
            display: block;
        }

        h1 {
            font-family: 'Barlow Condensed', sans-serif;
            font-size: clamp(2.5rem, 5vw, 4rem);
            font-weight: 800;
            text-transform: uppercase;
            margin-bottom: 4rem;
            color: var(--white-bright);
            line-height: 1;
        }

        /* Detail Grid - Left Aligned */
        .detail-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 40px;
        }

        .detail-group {
            padding-bottom: 2rem;
            border-bottom: 1px solid var(--navy-accent);
            transition: 0.3s;
        }

            .detail-group:hover {
                border-bottom-color: var(--gold-subtle);
            }

            .detail-group i {
                font-size: 1.4rem;
                color: var(--gold-subtle);
                margin-bottom: 1.2rem;
                display: block;
            }

        .label {
            display: block;
            font-family: 'Barlow Condensed', sans-serif;
            text-transform: uppercase;
            font-weight: 700;
            letter-spacing: 2px;
            font-size: 0.85rem;
            color: var(--white-muted);
            margin-bottom: 8px;
        }

        .info {
            font-size: 1.4rem;
            font-weight: 400;
            color: var(--white-bright);
        }

            .info a {
                color: var(--white-bright);
                text-decoration: none;
                transition: 0.2s;
            }

                .info a:hover {
                    color: var(--gold-subtle);
                }

        .enrollment-footer {
            margin-top: 5rem;
            padding-top: 3rem;
            border-top: 1px solid var(--navy-accent);
        }

        .btn-apply {
            display: inline-block;
            background: var(--gold-subtle);
            color: var(--navy-deep);
            padding: 1.2rem 3.5rem;
            text-decoration: none;
            font-weight: 800;
            text-transform: uppercase;
            font-family: 'Barlow Condensed', sans-serif;
            letter-spacing: 2px;
            transition: 0.3s;
        }

            .btn-apply:hover {
                transform: translateY(-3px);
                filter: brightness(1.1);
            }

        footer {
            padding: 5rem 5%;
            text-align: left; /* Left align footer too */
            background: var(--navy-deep);
            border-top: 1px solid var(--navy-accent);
        }

        @@media (max-width: 768px) {
            .nav-links-wrapper {
                display: none;
            }

            .contact-card {
                padding: 3rem 1.5rem;
            }

            .detail-grid {
                grid-template-columns: 1fr;
            }

            .info {
                font-size: 1.2rem;
            }
        }
    </style>
</head>
<body>

    <div class="page-bg-overlay"></div>

    <nav>
        <a href="@Url.Action("Index", "Home")" class="nav-logo-container">
            <img src="~/Content/Images/za-368-kzn-dgss.jpg" alt="DGSS Logo" class="school-crest-nav" />
            <div class="nav-logo-text">DGSS<br>Durban</div>
        </a>

        <ul class="nav-links-wrapper">
            <li><a href="@Url.Action("Index", "Home")" class="nav-link">Home</a></li>
            <li><a href="@Url.Action("About", "Home")" class="nav-link">About</a></li>
            <li><a href="@Url.Action("Contact", "Home")" class="nav-link active-link">Contact</a></li>
        </ul>

        <a href="@Url.Action("Login", "Teachers")" class="btn-portal">Staff Portal</a>
    </nav>

    <main class="contact-wrapper">
        <div class="contact-card">
            <span class="section-tag">Direct Communication Channels</span>
            <h1>Connect With Us</h1>

            <div class="detail-grid">
                <div class="detail-group">
                    <i class="fas fa-phone-alt"></i>
                    <span class="label">Main Switchboard</span>
                    <p class="info">+27 (0)31 309 3925</p>
                </div>

                <div class="detail-group">
                    <i class="fas fa-paper-plane"></i>
                    <span class="label">Email Registry</span>
                    <p class="info"><a href="mailto:admin@durbangirlssec.co.za">admin@durbangirlssec.co.za</a></p>
                </div>

                <div class="detail-group">
                    <i class="fas fa-map-pin"></i>
                    <span class="label">Physical Campus Address</span>
                    <p class="info">3331 Gladys Manzi Road, Durban, 4001</p>
                </div>

                <div class="detail-group">
                    <i class="fas fa-history"></i>
                    <span class="label">Operational Hours</span>
                    <p class="info">08:00 — 14:30 (Monday — Friday)</p>
                </div>
            </div>

            <div class="enrollment-footer">
                <p style="margin-bottom: 25px; font-size: 1.1rem; color: var(--white-muted);">Official admissions for the 2027 academic year are now being processed by the administration office.</p>
                <a href="@Url.Action("Register", "Parents")" class="btn-apply">Initiate Digital Application</a>
            </div>
        </div>
    </main>

    <footer>
        <p style="font-family: 'Barlow Condensed'; font-weight: 800; letter-spacing: 5px; color: var(--gold-subtle); margin-bottom: 10px; text-transform: uppercase;">Onward and Upward</p>
        <p style="font-size: 0.75rem; color: var(--white-muted);">© @DateTime.Now.Year DURBAN GIRLS SECONDARY SCHOOL. <br>GOVERNANCE THROUGH EXCELLENCE.</p>
    </footer>

</body>
</html>