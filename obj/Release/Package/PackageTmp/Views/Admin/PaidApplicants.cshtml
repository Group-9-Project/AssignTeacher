@model IEnumerable<SchoolTimetable.Models.Application>

@{
    ViewBag.Title = "Manage Registrations";
    Layout = null; 
}

<!DOCTYPE html>
<html>
<head>
    <title>Paid Applicants - DGSS Admin</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css">
    <style>
        body {
            background-color: #0a192f;
            color: #ccd6f6;
            padding: 40px;
            font-family: 'Segoe UI', sans-serif;
        }

        .header-box {
            border-left: 5px solid #ffd700;
            padding-left: 20px;
            margin-bottom: 30px;
        }

        .table-container {
            background: #112240;
            border-radius: 12px;
            padding: 25px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.4);
        }

        .table {
            color: #ccd6f6;
        }

            .table thead th {
                border-bottom: 2px solid #233554;
                color: #ffd700;
                text-transform: uppercase;
                letter-spacing: 1px;
            }

            .table td {
                border-bottom: 1px solid #233554;
                vertical-align: middle;
            }

        .paid-badge {
            background-color: rgba(40, 167, 69, 0.2);
            color: #28a745;
            padding: 5px 12px;
            border-radius: 20px;
            font-weight: bold;
            font-size: 0.8rem;
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="header-box">
            <h2 class="text-white">Confirmed Payments</h2>
            <p>List of applicants who have successfully paid the R1,000 registration fee.</p>
        </div>

        <div class="table-container">
            <table class="table">
                <thead>
                    <tr>
                        <th>Student Name</th>
                        <th>Grade</th>
                        <th>Average</th>
                        <th>Payment Status</th>
                        <th class="text-right">Manage</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">No confirmed payments found.</td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <span class="font-weight-bold text-white">@item.FirstName @item.LastName</span><br />
                                <small>ID: #@item.Id.ToString("D5")</small>
                            </td>
                            <td>Grade @item.GradeApplyingFor</td>
                            <td><span class="text-warning">@item.AverageMark%</span></td>
                            <td>
                                <span class="paid-badge">
                                    <i class="fa fa-check-circle"></i> R1,000 PAID
                                </span>
                            </td>
                            <td class="text-right">
                                <a href="@Url.Action("ApplicationDetails", "Admin", new { id = item.Id })" class="btn btn-outline-info btn-sm">
                                    Review Application
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-4">
            <a href="@Url.Action("Dashboard", "Admin")" class="text-muted"><i class="fa fa-arrow-left"></i> Back to Dashboard</a>
        </div>
    </div>
</body>
</html>