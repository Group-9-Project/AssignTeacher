@model SchoolTimetable.ViewModels.TimetableViewModel
@{
    Layout = null;
    ViewBag.Title = Model.Teacher.FullName + " - Timetable";
    var userRole = Session["UserRole"] != null ? Session["UserRole"].ToString() : "";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --navy-deep: #002147;
            --navy-primary: #003366;
            --white: #ffffff;
            --slate-100: #f1f5f9;
            --slate-200: #e2e8f0;
            --slate-300: #cbd5e1;
            --slate-500: #64748b;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--white);
            color: var(--navy-deep);
            margin: 0;
            padding: 40px;
        }

        /* Header */
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-bottom: 2rem;
            border-bottom: 4px solid var(--navy-deep);
            padding-bottom: 1rem;
        }

        .header-text h1 {
            font-size: 2rem;
            font-weight: 800;
            text-transform: uppercase;
            margin: 0;
            letter-spacing: -1px;
        }

        .header-text p {
            margin: 2px 0 0 0;
            font-size: 0.85rem;
            color: var(--slate-500);
            font-weight: 600;
            text-transform: uppercase;
        }

        /* Table */
        .table-container {
            border: 1px solid var(--navy-deep);
        }

        .timetable {
            width: 100%;
            border-collapse: collapse;
            table-layout: fixed;
        }

            .timetable th {
                background: var(--navy-deep);
                color: var(--white);
                font-weight: 700;
                text-transform: uppercase;
                font-size: 0.75rem;
                padding: 15px;
                border: 1px solid var(--white);
            }

            .timetable td {
                border: 1px solid var(--slate-200);
                height: 120px;
                vertical-align: top;
                padding: 8px !important;
            }

        .label-cell {
            background: var(--slate-100);
            width: 110px;
            text-align: center;
        }

        .p-num {
            font-size: 1.3rem;
            font-weight: 800;
            display: block;
            color: var(--navy-deep);
        }

        .p-time {
            font-size: 0.7rem;
            font-weight: 700;
            color: var(--slate-500);
        }

        /* Slots */
        .slot-content {
            height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 8px;
            box-sizing: border-box;
            background: var(--white);
        }

        .sub-code {
            font-weight: 800;
            font-size: 1rem;
            color: var(--navy-primary);
        }

        .sub-name {
            font-size: 0.75rem;
            font-weight: 600;
            line-height: 1.2;
            color: var(--navy-deep);
        }

        .room-tag {
            font-size: 0.65rem;
            font-weight: 700;
            text-transform: uppercase;
            margin-top: 5px;
            color: var(--slate-500);
        }

        /* Controls */
        .actions {
            display: flex;
            gap: 8px;
        }

        .btn {
            padding: 10px 20px;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            text-decoration: none;
            border: 2px solid var(--navy-deep);
            transition: 0.2s;
        }

        .btn-navy {
            background: var(--navy-deep);
            color: var(--white);
        }

            .btn-navy:hover {
                background: var(--white);
                color: var(--navy-deep);
            }

        .btn-outline {
            background: var(--white);
            color: var(--navy-deep);
        }

            .btn-outline:hover {
                background: var(--navy-deep);
                color: var(--white);
            }

        .mini-btn {
            font-size: 9px;
            font-weight: 800;
            padding: 3px 6px;
            border: 1px solid var(--navy-deep);
            color: var(--navy-deep);
            text-decoration: none;
            text-transform: uppercase;
        }

        .assign-link {
            display: flex;
            height: 100%;
            align-items: center;
            justify-content: center;
            color: var(--slate-300);
            text-decoration: none;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            border: 1px dashed var(--slate-300);
        }

            .assign-link:hover {
                color: var(--navy-deep);
                border-color: var(--navy-deep);
                background: var(--slate-100);
            }

        i, .fas {
            display: none !important;
        }
    </style>
</head>
<body>

    <div class="page-header">
        <div class="header-text">
            <h1>@Model.Teacher.FullName</h1>
            <p>Institutional Timetable</p>
        </div>
        <div class="actions">
            @if (userRole == "Admin")
            {
                <a href="@Url.Action("Index", "Teachers")" class="btn btn-outline">Exit to List</a>
            }
            else
            {
                <a href="@Url.Action("Dashboard", "Teachers")" class="btn btn-navy">My Dashboard</a>
            }
        </div>
    </div>

    <div class="table-container">
        <table class="timetable">
            <thead>
                <tr>
                    <th class="label-cell">Session</th>
                    @foreach (var d in Model.Days)
                    {
                        <th>@Model.DayNames[d]</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.Periods)
                {
                    <tr>
                        <td class="label-cell">
                            <span class="p-num">P@p</span>
                            <span class="p-time">@Model.PeriodTime(p)</span>
                        </td>
                        @foreach (var d in Model.Days)
                        {
                            var slot = Model.Slots.FirstOrDefault(s => s.DayOfWeek == d && s.Period == p);
                            if (slot != null)
                            {
                                <td>
                                    <div class="slot-content" style="border-left: 4px solid @(slot.Subject.Color ?? "#002147")">
                                        <div>
                                            <div class="sub-code">@slot.Subject.Code</div>
                                            <div class="sub-name">@slot.Subject.Name</div>
                                            <div class="room-tag">Room: @(slot.Class != null ? slot.Class.Name : "TBA")</div>
                                        </div>

                                        @if (userRole == "Admin")
                                        {
                                            <div style="display:flex; gap:4px; margin-top:8px;">
                                                <a href="@Url.Action("Edit", "Timetable", new { id = slot.Id })" class="mini-btn">Edit</a>
                                                <a href="@Url.Action("Create", "Substitutions", new { slotId = slot.Id })" class="mini-btn">Sub</a>
                                            </div>
                                        }
                                    </div>
                                </td>
                            }
                            else
                            {
                                <td>
                                    @if (userRole == "Admin")
                                    {
                                        <a href="@Url.Action("Create", "Timetable", new { teacherId = Model.Teacher.Id, day = d, period = p })" class="assign-link">
                                            Assign
                                        </a>
                                    }
                                </td>
                            }
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>

</body>
</html>