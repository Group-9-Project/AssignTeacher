@model IEnumerable<SchoolTimetable.Models.Announcement>
@{
    Layout = null; // Explicitly disabling layout
    ViewBag.Title = "Student Announcements";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - DGSS</title>

    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --dg-navy: #002147;
            --dg-navy-light: #003366;
            --dg-white: #ffffff;
            --dg-bg: #f4f7f9;
            --dg-border: #d1d9e6;
            --dg-text: #002147;
            --dg-text-muted: #64748b;
        }

        body {
            background-color: var(--dg-bg);
            color: var(--dg-text);
            font-family: 'Inter', sans-serif;
            margin: 0;
            padding: 0;
        }

        .content-container {
            max-width: 900px;
            margin: 4rem auto;
            padding: 0 1.5rem;
        }

        /* --- Header Section --- */
        .page-header {
            margin-bottom: 3rem;
            position: relative;
            border-bottom: 2px solid var(--dg-navy);
            padding-bottom: 1.5rem;
        }

        .btn-back-nav {
            display: inline-block;
            margin-bottom: 1rem;
            color: var(--dg-navy);
            text-decoration: none !important;
            font-size: 0.85rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: 0.2s;
        }

            .btn-back-nav:hover {
                opacity: 0.7;
            }

        .page-title {
            font-family: 'Playfair Display', serif;
            font-size: 2.8rem;
            color: var(--dg-navy);
            margin: 0;
        }

        .notice-subtitle {
            font-weight: 600;
            color: var(--dg-text-muted);
            text-transform: uppercase;
            letter-spacing: 0.2em;
            font-size: 0.75rem;
            margin-top: 0.5rem;
        }

        /* --- Announcement Cards --- */
        .notice-card {
            background: var(--dg-white);
            border: 1px solid var(--dg-border);
            border-radius: 0;
            margin-bottom: 2rem;
            position: relative;
            box-shadow: 0 2px 5px rgba(0,0,0,0.03);
        }

            .notice-card::before {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 4px;
                background: var(--dg-navy);
            }

        .card-header-custom {
            padding: 1.5rem 2rem;
            background: #fafbfc;
            border-bottom: 1px solid #f0f0f0;
        }

        .ann-title {
            font-weight: 700;
            color: var(--dg-navy);
            font-size: 1.3rem;
            margin: 0 0 0.5rem 0;
            line-height: 1.2;
        }

        .ann-meta {
            font-size: 0.75rem;
            color: var(--dg-text-muted);
            font-weight: 500;
            display: flex;
            gap: 15px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

            .ann-meta strong {
                color: var(--dg-navy);
            }

        .card-body-custom {
            padding: 2rem;
        }

        .ann-content {
            color: #2d3748;
            line-height: 1.8;
            font-size: 1.05rem;
            white-space: pre-line; /* Preserves line breaks from the database */
        }

        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 5rem;
            background: white;
            border: 1px dashed var(--dg-border);
            color: var(--dg-text-muted);
        }
    </style>
</head>
<body>

    <div class="content-container">

        <header class="page-header">
            <a href="@Url.Action("Dashboard")" class="btn-back-nav">
                &larr; Back to Hub
            </a>
            <h1 class="page-title">Notice Board</h1>
            <p class="notice-subtitle">Official Student Communications</p>
        </header>

        @if (!Model.Any())
        {
            <div class="empty-state">
                <p>There are currently no active announcements.</p>
            </div>
        }

        @foreach (var ann in Model)
        {
            <div class="notice-card">
                <div class="card-header-custom">
                    <h2 class="ann-title">@ann.Title</h2>
                    <div class="ann-meta">
                        <span>Posted: <strong>@ann.DatePosted.ToString("MMM dd, yyyy")</strong></span>
                        <span> By: <strong>@ann.Author.FirstName</strong></span>
                    </div>
                </div>

                <div class="card-body-custom">
                    <div class="ann-content">
                        @ann.Message
                    </div>
                </div>
            </div>
        }

    </div>

</body>
</html>