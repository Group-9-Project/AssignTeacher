@model SchoolTimetable.Models.Entrance_test
@{
    Layout = null;
    var durationMinutes = Model.DurationMinutes;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Entrance Test - @Model.Title</title>
    <style>
        :root {
            --bg: #0f0f10;
            --card: #161618;
            --muted: #a1a1aa;
            --text: #ffffff;
            --accent: #7c4dff;
            --border: #27272a;
        }

        body {
            background-color: var(--bg);
            color: var(--text);
            font-family: 'Segoe UI', system-ui, sans-serif;
            margin: 0;
            padding: 40px 20px;
        }

        .container {
            max-width: 850px;
            margin: 0 auto;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
            border-bottom: 1px solid var(--border);
            padding-bottom: 20px;
        }

        .timer-box {
            background: #1e1e20;
            padding: 12px 20px;
            border-radius: 12px;
            border: 1px solid #facc15;
            color: #facc15;
            font-weight: bold;
            font-size: 1.2rem;
            position: sticky;
            top: 20px;
        }

        .question-block {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 24px;
            margin-bottom: 24px;
        }

        .question-heading {
            display: block;
            font-size: 1.15rem;
            font-weight: 600;
            margin-bottom: 20px;
            line-height: 1.5;
            color: #efeff1;
        }

        .q-number {
            background: var(--accent);
            color: white;
            padding: 4px 12px;
            border-radius: 6px;
            font-size: 0.8rem;
            text-transform: uppercase;
            margin-right: 12px;
        }

        .options-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .option-item {
            display: flex;
            align-items: center;
            padding: 16px;
            background: #1c1c1f;
            border: 1px solid var(--border);
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.2s ease;
        }

            .option-item:hover {
                border-color: var(--accent);
                background: #252529;
            }

        input[type="radio"] {
            margin-right: 15px;
            width: 18px;
            height: 18px;
            accent-color: var(--accent);
        }

        .submit-btn {
            background: var(--accent);
            color: white;
            border: none;
            padding: 20px;
            border-radius: 12px;
            font-weight: bold;
            font-size: 1.1rem;
            cursor: pointer;
            width: 100%;
            margin-top: 20px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
        }

            .submit-btn:hover {
                background: #6b41db;
            }
    </style>
</head>
<body>

    <div class="container">
        <div class="header">
            <div>
                <h1 style="margin:0;">@Model.Title</h1>
                <p style="color:var(--muted); margin: 8px 0 0 0;">Durban Girls Secondary School - Entrance Examination</p>
            </div>
            <div class="timer-box"> <span id="timer">--:--</span></div>
        </div>

        @using (Html.BeginForm("WriteQuiz", "StudentAccount", FormMethod.Post, new { id = "quizForm" }))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.TestId)

            <div class="question-block">
                <span class="question-heading"><span class="q-number">Q1</span> @Model.QuetionOne</span>
                <div class="options-list">
                    <label class="option-item"><input type="radio" name="selectedAnswer1" value="@Model.AnswerOneAA" required /> @Model.AnswerOneAA</label>
                    <label class="option-item"><input type="radio" name="selectedAnswer1" value="@Model.AnswerOneBB" /> @Model.AnswerOneBB</label>
                    <label class="option-item"><input type="radio" name="selectedAnswer1" value="@Model.AnswerOneCC" /> @Model.AnswerOneCC</label>
                </div>
            </div>

            <div class="question-block">
                <span class="question-heading"><span class="q-number">Q2</span> @Model.QuetionTwo</span>
                <div class="options-list">
                    <label class="option-item"><input type="radio" name="selectedAnswer2" value="@Model.AnswerTwoAA" required /> @Model.AnswerTwoAA</label>
                    <label class="option-item"><input type="radio" name="selectedAnswer2" value="@Model.AnswerTwoBB" /> @Model.AnswerTwoBB</label>
                    <label class="option-item"><input type="radio" name="selectedAnswer2" value="@Model.AnswerTwoCC" /> @Model.AnswerTwoCC</label>
                </div>
            </div>

            <div class="question-block">
                <span class="question-heading"><span class="q-number">Q3</span> @Model.QuetionThree</span>
                <div class="options-list">
                    <label class="option-item"><input type="radio" name="selectedAnswer3" value="@Model.AnswerThreeAA" required /> @Model.AnswerThreeAA</label>
                    <label class="option-item"><input type="radio" name="selectedAnswer3" value="@Model.AnswerThreeBB" /> @Model.AnswerThreeBB</label>
                    <label class="option-item"><input type="radio" name="selectedAnswer3" value="@Model.AnswerThreeCC" /> @Model.AnswerThreeCC</label>
                </div>
            </div>

            <div class="question-block">
                <span class="question-heading"><span class="q-number">Q4</span> @Model.QuetionFour</span>
                <div class="options-list">
                    <label class="option-item"><input type="radio" name="selectedAnswer4" value="@Model.AnswerFourAA" required /> @Model.AnswerFourAA</label>
                    <label class="option-item"><input type="radio" name="selectedAnswer4" value="@Model.AnswerFourBB" /> @Model.AnswerFourBB</label>
                    <label class="option-item"><input type="radio" name="selectedAnswer4" value="@Model.AnswerFourCC" /> @Model.AnswerFourCC</label>
                </div>
            </div>

            <div class="question-block">
                <span class="question-heading"><span class="q-number">Q5</span> @Model.QuetionFive</span>
                <div class="options-list">
                    <label class="option-item"><input type="radio" name="selectedAnswer5" value="@Model.AnswerFiveAA" required /> @Model.AnswerFiveAA</label>
                    <label class="option-item"><input type="radio" name="selectedAnswer5" value="@Model.AnswerFiveBB" /> @Model.AnswerFiveBB</label>
                    <label class="option-item"><input type="radio" name="selectedAnswer5" value="@Model.AnswerFiveCC" /> @Model.AnswerFiveCC</label>
                </div>
            </div>

            <button type="submit" class="submit-btn">SUBMIT Test</button>
        }
    </div>

    <script>
    (function () {
        var totalSeconds = @(durationMinutes * 60);
        var display = document.getElementById('timer');
        var form = document.getElementById('quizForm');

        function startTimer() {
            var timerInterval = setInterval(function () {
                var minutes = Math.floor(totalSeconds / 60);
                var seconds = totalSeconds % 60;
                display.textContent = (minutes < 10 ? "0" + minutes : minutes) + ":" + (seconds < 10 ? "0" + seconds : seconds);

                if (totalSeconds <= 0) {
                    clearInterval(timerInterval);
                    form.submit();
                }
                totalSeconds--;
            }, 1000);
        }
        window.onload = startTimer;
    })();
    </script>
</body>
</html>