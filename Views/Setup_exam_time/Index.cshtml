@model IEnumerable<Setup_Examination_timetable.Models.Setup_exam_time>

@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Index</title>
</head>
<body>
    <p>
        @Html.ActionLink("Create New", "Create")
    </p>
    <table class="table">
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Exam_name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.venue)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Exam_Starttime)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Exam_Endtime)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Exam_date)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Grade)
            </th>
            <th></th>
        </tr>
    
    @foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Exam_name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.venue)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Exam_Starttime)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Exam_Endtime)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Exam_date)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Grade)
            </td>
            <td>
                @Html.ActionLink("Edit", "Edit", new { id=item.Id }) |
                @Html.ActionLink("Details", "Details", new { id=item.Id }) |
                @Html.ActionLink("Delete", "Delete", new { id=item.Id })
            </td>
        </tr>
    }
    
    </table>
</body>
</html>
