@model IEnumerable<Setup_Examination_timetable.Models.Setup_exam_time>

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Published Timetable</title>
    <style>
        table {
            border-collapse: collapse;
            width: 100%;
        }

        th, td {
            border: 1px solid #ccc;
            padding: 6px;
            text-align: center;
            vertical-align: top;
        }

        th {
            background: #eee;
        }

        .stack {
            padding: 8px;
            min-height: 40px;
        }

        .session-actions {
            margin-top: 6px;
        }
    </style>
</head>
<body>
    <h2>Published Timetable</h2>

    @if (Model == null || !Model.Any())
    {
        <p>No timetable entries published.</p>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    @* render a header cell for each distinct session (date + start + end) *@
                    @{ var sessions = Model.GroupBy(m => new { m.Exam_date, m.Exam_Starttime, m.Exam_Endtime })
                                             .OrderBy(g => g.Key.Exam_date).ThenBy(g => g.Key.Exam_Starttime).ToList(); }
                    @foreach (var s in sessions)
                    {
                        <th>
                            @s.Key.Exam_date.ToString("yyyy-MM-dd")<br />
                            @s.Key.Exam_Starttime @(" - ") @s.Key.Exam_Endtime
                            <div class="session-actions">
                                @* POST to Setup_exam_time/DeleteSession (was incorrectly posting to Home) *@
                                @using (Html.BeginForm("DeleteSession", "Setup_exam_time", FormMethod.Post))
                                {
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="date" value="@s.Key.Exam_date.ToString("yyyy-MM-dd")" />
                                    <input type="hidden" name="start" value="@s.Key.Exam_Starttime" />
                                    <input type="hidden" name="end" value="@s.Key.Exam_Endtime" />
                                    <input type="submit" value="Delete Session" onclick="return confirm('Delete all entries for this session?');" />
                                }
                            </div>
                        </th>
                    }
                </tr>
            </thead>
            <tbody>
                <tr>
                    @* for each session column, show stacked Grade, Venue, Exam Name. If multiple entries exist for that session, show them stacked separated *@
                    @foreach (var s in sessions)
                    {
                        <td>
                            <div class="stack">
                                @foreach (var item in s)
                                {
                                    <div><strong>Grade:</strong> @item.Grade</div>
                                    <div><strong>Venue:</strong> @item.venue</div>
                                    <div><strong>Exam:</strong> @item.Exam_name</div>
                                    <hr />
                                }
                            </div>
                        </td>
                    }
                </tr>
            </tbody>
        </table>
    }
</body>
</html>