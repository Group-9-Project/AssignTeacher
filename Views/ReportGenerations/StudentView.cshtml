@model SchoolTimetable.Models.ReportGeneration

@{
    Layout = null;
    ViewBag.Title = "Student Academic Report";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Calibri', 'Arial', sans-serif;
            background-color: #f5f5f5;
            padding: 20px;
            color: #333;
        }

        .report-container {
            max-width: 900px;
            margin: 0 auto;
            background-color: #ffffff;
            padding: 30px;
            box-shadow: 0 6px 18px rgba(0,0,0,0.08);
            border-radius: 6px;
        }

        .header {
            text-align: center;
            border-bottom: 3px solid #003d7a;
            padding-bottom: 15px;
            margin-bottom: 22px;
        }

        .school-name {
            font-size: 18px;
            font-weight: 700;
            color: #003d7a;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .report-title {
            font-size: 14px;
            color: #666;
            margin-top: 6px;
        }

        .student-info {
            background-color: #f0f4fb;
            padding: 16px;
            margin-bottom: 20px;
            border-left: 5px solid #003d7a;
            border-radius: 4px;
        }

        .student-name {
            font-size: 22px;
            font-weight: 700;
            color: #003d7a;
            margin-bottom: 8px;
        }

        .info-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 6px;
            font-size: 14px;
        }

        .info-label { font-weight: 600; color: #333; }
        .info-value { color: #444; }

        .results-section { margin-top: 18px; }

        .section-title {
            font-size: 14px;
            font-weight: 700;
            color: #003d7a;
            border-bottom: 2px solid #e6eef9;
            padding-bottom: 10px;
            margin-bottom: 16px;
            text-transform: uppercase;
        }

        .results-table { width: 100%; border-collapse: collapse; margin-bottom: 18px; }
        .results-table thead { background-color: #003d7a; color: #fff; }
        .results-table th {
            padding: 10px 12px;
            text-align: left;
            font-size: 12px;
            font-weight: 700;
            border: 1px solid #e6eef9;
        }
        .results-table td {
            padding: 10px 12px;
            border: 1px solid #eef3fb;
            font-size: 13px;
            vertical-align: middle;
        }
        .results-table tbody tr:nth-child(even) { background-color: #fbfdff; }

        .subject-cell { font-weight: 600; color: #003d7a; }
        .grade-cell { text-align: center; font-weight: 700; color: #003d7a; }
        .percentage-cell { text-align: center; font-weight: 600; color: #333; }

        .status-cell {
            text-align: center;
            font-weight: 700;
            text-transform: uppercase;
            padding: 6px 10px;
            border-radius: 4px;
            display: inline-block;
            min-width: 80px;
        }
        .status-pass { background-color: #d4edda; color: #155724; }
        .status-fail { background-color: #f8d7da; color: #721c24; }

        .no-results {
            text-align: center;
            padding: 20px;
            color: #999;
            font-style: italic;
            background-color: #fafbfc;
            border: 1px solid #eee;
            border-radius: 4px;
        }

        .footer {
            margin-top: 22px;
            padding-top: 12px;
            border-top: 1px solid #eee;
            text-align: center;
            font-size: 12px;
            color: #888;
        }

        .action-links { margin-top: 18px; text-align: center; }
        .btn {
            display: inline-block;
            padding: 8px 16px;
            margin: 6px;
            background-color: #003d7a;
            color: #fff;
            text-decoration: none;
            border-radius: 4px;
            font-size: 13px;
            border: none;
            cursor: pointer;
        }
        .btn-secondary { background-color: #6c757d; }
        .btn:hover { background-color: #002d5c; }

        .grade-descriptor {
            font-size: 12px;
            text-align: center;
            background-color: #e7f3ff;
            color: #003d7a;
            font-weight: 700;
            padding: 6px 8px;
            border-radius: 3px;
            display: inline-block;
        }

        media print {
            body { background-color: #fff; }
            .report-container { box-shadow: none; border: none; }
            .action-links { display: none; }
        }
    </style>
</head>
<body>
    <div class="report-container">
        <div class="header">
            <div class="school-name">South African School Report</div>
            <div class="report-title">Student Academic Performance Report</div>
        </div>

        <div class="student-info">
            <div class="student-name">@Model.StudentName</div>
            <div class="info-row">
                <span class="info-label">Student Number:</span>
                <span class="info-value">@Model.StudentNumber</span>
            </div>
            <div class="info-row">
                <span class="info-label">Grade:</span>
                <span class="info-value">@Model.Grade</span>
            </div>
        </div>

        <div class="results-section">
            <div class="section-title">Subject Performance</div>

            <table class="results-table">
                <thead>
                    <tr>
                        <th>Subject</th>
                        <th>Grade Descriptor</th>
                        <th style="text-align:center;">Exam %</th>
                        <th style="text-align:center;">Continuous %</th>
                        <th style="text-align:center;">Overall %</th>
                        <th style="text-align:center;">Status</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="subject-cell">@Model.Subject</td>
                        <td class="grade-descriptor">@Model.Descriptor</td>
                        <td class="percentage-cell">@Model.Percentage%</td>
                        <td class="percentage-cell">@Math.Round(Model.FinalPercentage, 1)%</td>
                        <td class="percentage-cell"><strong>@Math.Round(Model.GradeAverage, 1)%</strong></td>
                        <td>
                            @{
                                var statusClass = !string.IsNullOrEmpty(Model.Status) && Model.Status.Contains("Pass") ? "status-pass" : "status-fail";
                            }
                            <span class="status-cell @statusClass">@Model.Status</span>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="footer">
            <p>Report Generated: @DateTime.Now.ToString("dd MMMM yyyy")</p>
            <p>This is an official South African school report.</p>
        </div>

        <div class="action-links">
            <button onclick="window.print();" class="btn">Print Report</button>
        </div>
    </div>
</body>
</html>