@model SchoolTimetable.Models.ReportGeneration

@{
    Layout = null;
    ViewBag.Title = "Create Report";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>
    <style>
        :root {
            --dgss-navy: #0d2b73;
            --dgss-light-blue: #d4e0f1;
            --dgss-accent: #4169e1;
            --dgss-bg: #f0f4f8;
            --dgss-white: #ffffff;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: var(--dgss-light-blue);
            font-family: 'Segoe UI', sans-serif;
            color: #333;
        }

        .header {
            background-color: var(--dgss-bg);
            padding: 25px;
            text-align: center;
            border-bottom: 4px solid var(--dgss-navy);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .header-logo img {
            height: 85px;
        }

        .container-custom {
            max-width: 1000px;
            margin: 40px auto;
            padding: 40px;
            background-color: var(--dgss-white);
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        .form-group-custom {
            display: flex;
            flex-direction: column;
            flex: 1;
            min-width: 180px;
            margin-bottom: 15px;
        }

            .form-group-custom label {
                font-weight: 700;
                color: var(--dgss-navy);
                text-transform: uppercase;
                font-size: 12px;
                margin-bottom: 5px;
            }

            .form-group-custom input, .form-group-custom select {
                border: 2px solid #e0e6ed;
                padding: 12px;
                border-radius: 6px;
                font-size: 14px;
            }

                /* Readonly fields styling */
                .form-group-custom input[readonly] {
                    background-color: #f9f9f9;
                    border-color: #eee;
                    color: #666;
                }

        .center-heading {
            text-align: center;
            color: var(--dgss-accent);
            font-size: 20px;
            font-weight: 700;
            margin: 40px 0;
            display: flex;
            align-items: center;
        }

            .center-heading::before, .center-heading::after {
                content: "";
                flex: 1;
                height: 1px;
                background: #e0e6ed;
                margin: 0 20px;
            }

        .btn-custom {
            border: 2px solid var(--dgss-navy);
            padding: 12px 25px;
            cursor: pointer;
            border-radius: 8px;
            font-weight: bold;
            background: transparent;
            color: var(--dgss-navy);
            transition: all 0.2s ease;
            font-size: 14px;
        }

            .btn-custom:hover {
                background: var(--dgss-navy);
                color: white;
            }

        .footer {
            background-color: var(--dgss-navy);
            color: #fff;
            padding: 30px;
            margin-top: 60px;
            text-align: center;
        }
    </style>
</head>
<body>
    <div class="header">
        <div class="header-logo">
            <img src="https://tse3.mm.bing.net/th/id/OIP.4F7suouXbLCmtrEpz8RoXAHaCD?rs=1&pid=ImgDetMain&o=7&rm=3" alt="Logo" />
        </div>
        <div class="header-text" style="margin-left: 20px;">
            <h1 style="color: var(--dgss-navy);">Report Generation</h1>
        </div>
    </div>

    <div class="container-custom">
        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="form-section">
                <div style="display:flex; gap:20px; flex-wrap: wrap;">

                    <div class="form-group-custom">
                        @Html.LabelFor(model => model.StudentNumber)
                        @Html.DropDownListFor(model => model.StudentNumber, (IEnumerable<SelectListItem>)ViewBag.StudentNumber, "-- Select Student --", new { @class = "form-control", id = "ddlStudentNumber" })
                        @Html.ValidationMessageFor(model => model.StudentNumber, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group-custom">
                        <label>Student Name</label>
                        @Html.TextBoxFor(model => model.StudentName, new { @class = "form-control", id = "txtStudentName", @readonly = "readonly", placeholder = "Select student..." })
                    </div>


                    @* ADDED: Class Display (Mimics OnlineClass info) *@
                    <div class="form-group-custom">
                        <label>Assigned Class</label>
                        <input type="text" id="txtClassName" class="form-control" readonly placeholder="Classroom" />
                    </div>

                    @* MODIFIED: Teacher Selection (Locked to current Session user) *@
                    <div class="form-group-custom">
                        @Html.LabelFor(model => model.TeacherId, "Reporting Teacher")
                        @Html.DropDownList("TeacherId", null, htmlAttributes: new { @class = "form-control", @style = "pointer-events: none; background: #f9f9f9;" })
                    </div>

                    <div class="form-group-custom">
                        @Html.LabelFor(model => model.Subject)
                        @Html.EnumDropDownListFor(model => model.Subject, "-- Select Subject --", new { @class = "form-control" })
                    </div>
                </div>
            </div>

            <div class="center-heading">Marks Entry</div>

            <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap:15px;">
                <div class="form-group-custom">
                    @Html.LabelFor(model => model.assignmentMark, "Assignment Mark")
                    @Html.EditorFor(model => model.assignmentMark, new { htmlAttributes = new { @class = "form-control", type = "number", min = "0", max = "100" } })
                </div>
                <div class="form-group-custom">
                    @Html.LabelFor(model => model.test1Mark, "Test 1 Mark")
                    @Html.EditorFor(model => model.test1Mark, new { htmlAttributes = new { @class = "form-control", type = "number", min = "0", max = "100" } })
                </div>
                <div class="form-group-custom">
                    @Html.LabelFor(model => model.test2Mark, "Test 2 Mark")
                    @Html.EditorFor(model => model.test2Mark, new { htmlAttributes = new { @class = "form-control", type = "number", min = "0", max = "100" } })
                </div>
                <div class="form-group-custom">
                    @Html.LabelFor(model => model.examMark, "Exam Mark")
                    @Html.EditorFor(model => model.examMark, new { htmlAttributes = new { @class = "form-control", type = "number", min = "0", max = "100" } })
                </div>
            </div>

            <div class="button-row" style="text-align:center; margin-top:40px; display: flex; justify-content: center; gap: 15px;">
                <button type="submit" class="btn-custom" style="background-color: var(--dgss-navy); color: white;">Save Report</button>
                <a href="@Url.Action("Index")" class="btn-custom" style="text-decoration: none;">Cancel & Exit</a>
            </div>
        }
    </div>

    <div class="footer">
        <p>© 2026 Durban Girls Secondary School</p>
    </div>

    <!-- Essential Scripts -->
    <script src="https://ajax.aspnetcdn.com/ajax/jQuery/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            $("#ddlStudentNumber").change(function () {
                var studentNum = $(this).val();

                if (studentNum) {
                    // Show loading state in text boxes
                    $("#txtStudentName").val("Loading...");
                    $("#txtClassName").val("...");

                    $.ajax({
                        url: '@Url.Action("GetStudentDetails", "ReportGenerations")',
                        type: 'GET',
                        data: { studentNumber: studentNum },
                        success: function (data) {
                            if (data) {
                                $("#txtStudentName").val(data.FullName);
                                $("#txtClassName").val(data.ClassName);
                            }
                        },
                        error: function () {
                            alert("Failed to load student data. Please try again.");
                            $("#txtStudentName").val("");
                            $("#txtClassName").val("");
                        }
                    });
                } else {
                    $("#txtStudentName").val("");
                    $("#txtClassName").val("");
                }
            });
        });
    </script>
</body>
</html>