@model SchoolTimetable.Models.ReportGeneration

@{
    Layout = null;
    ViewBag.Title = "Create Report";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background-color: #d4e0f1;
            margin: 0;
            padding: 0;
            font-family: Arial, sans-serif;
        }

        .header {
            background-color: #f0f4f8;
            padding: 20px;
            text-align: center;
            border-bottom: 3px solid #0d2b73;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .header-logo {
            display: inline-block;
            margin-right: 20px;
            vertical-align: middle;
        }

        .header-logo img {
            height: 80px;
            width: auto;
        }

        .header-text {
            display: inline-block;
            vertical-align: middle;
            text-align: left;
        }

        .header-text h1 {
            margin: 0;
            color: #0d2b73;
            font-size: 36px;
            font-weight: bold;
        }

        .header-text p {
            margin: 5px 0 0 0;
            color: #0d2b73;
            font-size: 18px;
        }

        .container-custom {
            max-width: 1000px;
            margin: 40px auto;
            padding: 30px;
            background-color: #ffffff;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }

        .form-section {
            margin-bottom: 30px;
        }

        .form-row {
            display: flex;
            gap: 40px;
            margin-bottom: 25px;
            justify-content: flex-start;
            flex-wrap: wrap;
        }

        .form-row-two-col {
            display: flex;
            gap: 200px;
            margin-bottom: 25px;
            justify-content: flex-start;
            flex-wrap: wrap;
        }

        .form-row-four-col {
            display: flex;
            gap: 30px;
            margin-bottom: 25px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .form-group-custom {
            display: flex;
            flex-direction: column;
            min-width: 140px;
        }

        .form-group-custom label {
            font-weight: bold;
            font-size: 12px;
            margin-bottom: 8px;
            color: #0d2b73;
            text-align: left;
        }

        .form-group-custom input,
        .form-group-custom select {
            border: 2px solid #ccc;
            padding: 10px 8px;
            font-size: 14px;
            width: 140px;
            background-color: #fff;
            border-radius: 4px;
        }

        .form-group-custom input:focus,
        .form-group-custom select:focus {
            outline: none;
            border-color: #0d2b73;
            background-color: #f9f9f9;
        }

        .center-heading {
            text-align: center;
            color: #4169e1;
            font-size: 18px;
            font-weight: bold;
            margin: 30px 0 25px 0;
        }

        .button-row {
            display: flex;
            gap: 30px;
            justify-content: center;
            margin-top: 35px;
            flex-wrap: wrap;
        }

        .btn-custom {
            border: 2px solid #0d2b73;
            padding: 12px 40px;
            font-size: 14px;
            font-weight: bold;
            background-color: #fff;
            color: #0d2b73;
            cursor: pointer;
            min-width: 140px;
            border-radius: 4px;
            transition: all 0.3s ease;
        }

        .btn-custom:hover {
            background-color: #0d2b73;
            color: #fff;
        }

        .btn-custom:active {
            transform: scale(0.98);
        }

        .footer {
            background-color: #0d2b73;
            color: #fff;
            padding: 20px;
            text-align: left;
            margin-top: 40px;
        }

        .footer-content {
            max-width: 1000px;
            margin: 0 auto;
        }

        .footer-title {
            font-weight: bold;
            font-size: 16px;
            margin-bottom: 10px;
        }

        .footer-info {
            font-size: 13px;
            line-height: 1.8;
            margin-bottom: 15px;
        }

        .footer-copyright {
            text-align: center;
            font-size: 12px;
            margin-top: 15px;
            border-top: 1px solid rgba(255,255,255,0.2);
            padding-top: 10px;
        }

        .validation-summary {
            color: #d32f2f;
            margin-bottom: 20px;
            padding: 12px;
            background-color: #ffebee;
            border-left: 4px solid #d32f2f;
            border-radius: 4px;
        }

        .text-danger {
            color: #d32f2f;
            font-size: 12px;
            margin-top: 4px;
        }

        .back-link {
            display: inline-block;
            margin-bottom: 20px;
            color: #0d2b73;
            text-decoration: none;
            font-weight: 600;
        }

        .back-link:hover {
            text-decoration: underline;
        }

        media (max-width: 768px) {
            .form-row-two-col { gap: 80px; }
            .form-row-four-col { gap: 20px; }
            .button-row { gap: 15px; }
        }
    </style>
</head>
<body>
    <div class="header">
        <div class="header-logo">
            <img src="https://tse3.mm.bing.net/th/id/OIP.4F7suouXbLCmtrEpz8RoXAHaCD?rs=1&pid=ImgDetMain&o=7&rm=3" alt="School Logo" />
        </div>
        <div class="header-text">
            <h1>Report Generation</h1>
            <p>Student Academic Performance</p>
        </div>
    </div>

    <div class="container-custom">
        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

            if (ViewData.ModelState.Values.Any(x => x.Errors.Count > 0))
            {
                <div class="validation-summary">
                    @Html.ValidationSummary(true, "Please correct the errors below:", new { })
                </div>
            }

            <div class="form-section">
                <!-- Student Number -->
                <div class="form-row">
                    <div class="form-group-custom">
                        @Html.LabelFor(model => model.StudentNumber)
                        @Html.EditorFor(model => model.StudentNumber, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.StudentNumber, "", new { @class = "text-danger" })
                    </div>
                </div>

                <!-- Student Name and Grade -->
                <div class="form-row-two-col">
                    <div class="form-group-custom">
                        @Html.LabelFor(model => model.StudentName)
                        @Html.EditorFor(model => model.StudentName, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.StudentName, "", new { @class = "text-danger" })
                    </div>
                    <div class="form-group-custom">
                        @Html.LabelFor(model => model.Grade)
                        @Html.EditorFor(model => model.Grade, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.Grade, "", new { @class = "text-danger" })
                    </div>
                </div>

                <!-- Center Heading -->
                <div class="center-heading">
                    Upload Student Marks
                </div>

                <!-- Subject -->
                <div class="form-row">
                    <div class="form-group-custom">
                        @Html.LabelFor(model => model.Subject)
                        @Html.EnumDropDownListFor(model => model.Subject, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.Subject, "", new { @class = "text-danger" })
                    </div>
                </div>

                <!-- Teacher -->

                <!-- Marks Row (4 columns) -->
                <div class="form-row-four-col">
                    <div class="form-group-custom">
                        @Html.LabelFor(model => model.assignmentMark)
                        @Html.EditorFor(model => model.assignmentMark, new { htmlAttributes = new { @class = "form-control", type = "number" } })
                        @Html.ValidationMessageFor(model => model.assignmentMark, "", new { @class = "text-danger" })
                    </div>
                    <div class="form-group-custom">
                        @Html.LabelFor(model => model.test1Mark)
                        @Html.EditorFor(model => model.test1Mark, new { htmlAttributes = new { @class = "form-control", type = "number" } })
                        @Html.ValidationMessageFor(model => model.test1Mark, "", new { @class = "text-danger" })
                    </div>
                    <div class="form-group-custom">
                        @Html.LabelFor(model => model.test2Mark)
                        @Html.EditorFor(model => model.test2Mark, new { htmlAttributes = new { @class = "form-control", type = "number" } })
                        @Html.ValidationMessageFor(model => model.test2Mark, "", new { @class = "text-danger" })
                    </div>
                    <div class="form-group-custom">
                        @Html.LabelFor(model => model.examMark)
                        @Html.EditorFor(model => model.examMark, new { htmlAttributes = new { @class = "form-control", type = "number" } })
                        @Html.ValidationMessageFor(model => model.examMark, "", new { @class = "text-danger" })
                    </div>
                </div>

                <!-- Buttons -->
                <div class="button-row">
                    <button type="submit" class="btn-custom">Add Marks</button>

                    <button type="button" class="btn-custom" onclick="location.href='@Url.Action("Delete")'">Delete</button>
                    <button type="button" class="btn-custom" onclick="location.href='@Url.Action("Details")'">Details</button>
                    <button type="button" class="btn-custom" onclick="location.href='@Url.Action("StudentView")'">StudentView</button>

                    <button type="button" class="btn-custom" onclick="location.href='@Url.Action("Index")'">View Reports</button>
                </div>
            </div>
        }
    </div>

    <div class="footer">
        <div class="footer-content">
            <div class="footer-title">Durban Girls Secondary School</div>
            <div class="footer-info">
                📍 165 Helen Street, Durban, South Africa, 4001<br>
                📞 +27 31 305 3163<br>
                ✉️ info@durbangirlsschool.co.za
            </div>
            <div class="footer-copyright">
                © 2026 Durban Girls Secondary School. All rights reserved.
            </div>
        </div>
    </div>

    @section Scripts {
        @Scripts.Render("~/bundles/jqueryval")
    }
</body>
</html>