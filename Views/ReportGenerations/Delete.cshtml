@model SchoolTimetable.Models.ReportGeneration

@{
    Layout = null;
    ViewBag.Title = "Delete Record";
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>
    <style>
        :root {
            --dgss-navy: #0d2b73;
            --dgss-light-blue: #d4e0f1;
            --dgss-accent: #4169e1;
            --dgss-bg: #f0f4f8;
            --dgss-white: #ffffff;
            --dgss-danger: #d32f2f;
            --dgss-danger-hover: #b71c1c;
        }

        body {
            background-color: var(--dgss-light-blue);
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #333;
        }

        /* Header Consistency */
        .header {
            background-color: var(--dgss-bg);
            padding: 25px;
            text-align: center;
            border-bottom: 4px solid var(--dgss-navy);
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        }

        .header-logo img {
            height: 80px;
            width: auto;
            filter: drop-shadow(0px 2px 2px rgba(0,0,0,0.1));
        }

        .page-title {
            padding: 25px;
            text-align: center;
            color: var(--dgss-navy);
            font-size: 24px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .main-content {
            max-width: 1100px;
            margin: 0 auto 40px auto;
            padding: 0 20px;
        }

        /* Warning/Confirmation Box */
        .confirmation-box {
            background-color: #fff;
            padding: 25px;
            margin-bottom: 25px;
            border-left: 6px solid var(--dgss-danger);
            border-radius: 8px;
            box-shadow: 0 4px 15px rgba(211, 47, 47, 0.1);
        }

        .confirmation-title {
            color: var(--dgss-danger);
            font-weight: 800;
            font-size: 18px;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .confirmation-box p {
            margin: 0;
            font-size: 15px;
            color: #555;
            line-height: 1.5;
        }

        /* Student Card */
        .student-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background-color: var(--dgss-white);
            padding: 25px;
            margin-bottom: 20px;
            border-top: 4px solid var(--dgss-navy);
            border-radius: 8px;
            box-shadow: 0 5px 15px rgba(13, 43, 115, 0.08);
        }

        .student-name {
            font-size: 26px;
            font-weight: 800;
            color: var(--dgss-navy);
        }

        .student-info {
            display: flex;
            gap: 40px;
        }

        .info-label {
            font-size: 11px;
            color: #777;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 4px;
        }

        .info-value {
            font-size: 16px;
            color: var(--dgss-navy);
            font-weight: 700;
        }

        /* Marks Table Customization */
        .marks-table-wrapper {
            background-color: var(--dgss-white);
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            margin-bottom: 30px;
        }

        .marks-table {
            width: 100%;
            border-collapse: collapse;
        }

            .marks-table thead {
                background-color: var(--dgss-navy);
                color: #fff;
            }

            .marks-table th {
                padding: 16px 12px;
                text-align: left;
                font-size: 12px;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                font-weight: 700;
            }

            .marks-table td {
                padding: 18px 12px;
                border-bottom: 1px solid #f0f4f8;
                font-size: 14px;
                color: #444;
            }

            .marks-table tr:last-child td {
                border-bottom: none;
            }

        /* Action Buttons */
        .button-container {
            display: flex;
            gap: 20px;
            justify-content: center;
            padding: 20px 0;
        }

        .btn-delete {
            background-color: var(--dgss-danger);
            color: #fff;
            padding: 15px 40px;
            border: none;
            font-weight: 700;
            cursor: pointer;
            font-size: 14px;
            border-radius: 8px;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s ease;
        }

            .btn-delete:hover {
                background-color: var(--dgss-danger-hover);
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(211, 47, 47, 0.3);
            }

        .btn-cancel {
            background-color: var(--dgss-white);
            color: var(--dgss-navy);
            padding: 15px 40px;
            border: 2px solid var(--dgss-navy);
            font-weight: 700;
            cursor: pointer;
            font-size: 14px;
            text-decoration: none;
            display: inline-block;
            border-radius: 8px;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s ease;
        }

            .btn-cancel:hover {
                background-color: var(--dgss-navy);
                color: #fff;
            }

        /* Footer Consistency */
        .footer {
            background-color: var(--dgss-navy);
            color: #fff;
            padding: 40px 20px;
            margin-top: 40px;
        }

        .footer-content {
            max-width: 1100px;
            margin: 0 auto;
        }

        .footer-title {
            font-weight: 800;
            font-size: 16px;
            margin-bottom: 12px;
        }

        .footer-info {
            font-size: 13px;
            line-height: 1.8;
            opacity: 0.8;
        }

        .footer-copyright {
            text-align: center;
            margin-top: 25px;
            padding-top: 20px;
            font-size: 12px;
            border-top: 1px solid rgba(255,255,255,0.1);
            opacity: 0.6;
        }

        @@media (max-width: 768px) {
            .student-header {
                flex-direction: column;
                text-align: center;
                gap: 20px;
            }

            .student-info {
                flex-direction: column;
                gap: 15px;
            }

            .button-container {
                flex-direction: column;
            }

            .marks-table {
                display: block;
                overflow-x: auto;
            }
        }
    </style>
</head>
<body>
    <div class="header">
        <div class="header-logo">
            <img src="https://tse3.mm.bing.net/th/id/OIP.4F7suouXbLCmtrEpz8RoXAHaCD?rs=1&pid=ImgDetMain&o=7&rm=3" alt="Logo" />
        </div>
    </div>

    <div class="page-title">Delete Student Record</div>

    <div class="main-content">
        <div class="confirmation-box">
            <div class="confirmation-title">⚠️ Warning: Permanent Deletion</div>
            <p>Are you sure you want to delete this record for <strong>@Model.StudentName</strong>? This action cannot be undone and will remove all associated marks from the system.</p>
        </div>

        <div class="student-header">
            <div class="student-name">@Html.DisplayFor(m => m.StudentName)</div>
            <div class="student-info">
                <div class="info-item">
                    <div class="info-label">Student ID</div>
                    <div class="info-value">@Html.DisplayFor(m => m.StudentNumber)</div>
                </div>
                <div class="info-item">
                    <div class="info-label">Subject</div>
                    <div class="info-value">@Html.DisplayFor(m => m.Subject)</div>
                </div>
            </div>
        </div>

        <div class="marks-table-wrapper">
            <table class="marks-table" role="table">
                <thead>
                    <tr>
                        <th>Assign</th>
                        <th>Test 1</th>
                        <th>Test 2</th>
                        <th>Exam</th>
                        <th>Descriptor</th>
                        <th>Exam %</th>
                        <th>Final %</th>
                        <th>Avg %</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>@Html.DisplayFor(m => m.assignmentMark)</td>
                        <td>@Html.DisplayFor(m => m.test1Mark)</td>
                        <td>@Html.DisplayFor(m => m.test2Mark)</td>
                        <td>@Html.DisplayFor(m => m.examMark)</td>
                        <td style="font-weight:bold; color:var(--dgss-navy);">@Html.DisplayFor(m => m.Descriptor)</td>
                        <td>@Math.Round(Convert.ToDouble(Model.Percentage), 2)%</td>
                        <td style="font-weight:bold;">@Math.Round(Convert.ToDouble(Model.FinalPercentage), 2)%</td>
                        <td>@Math.Round(Convert.ToDouble(Model.GradeAverage), 2)%</td>
                        <td>
                            <span style="padding: 4px 8px; border-radius: 4px; font-weight: bold; background: #f0f4f8; color: @(Model.Status.ToString().ToLower().Contains("pass") ? "#2e7d32" : "#d32f2f")">
                                @Html.DisplayFor(m => m.Status)
                            </span>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            <div class="button-container">
                <button type="submit" class="btn-delete">Confirm Delete</button>
                @Html.ActionLink("Back to List", "Index", null, new { @class = "btn-cancel" })
            </div>
        }
    </div>

    <div class="footer">
        <div class="footer-content">
            <div class="footer-title">Durban Girls Secondary School</div>
            <div class="footer-info">
                📍 165 Helen Street, Durban, South Africa, 4001<br />
                📞 +27 31 305 3163<br />
                ✉️ info@durbangirlsschool.co.za
            </div>
            <div class="footer-copyright">© @DateTime.Now.Year Durban Girls Secondary School. All Rights Reserved.</div>
        </div>
    </div>
</body>
</html>