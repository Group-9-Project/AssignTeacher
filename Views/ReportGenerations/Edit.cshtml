@model SchoolTimetable.Models.ReportGeneration

@{
    Layout = null;
    ViewBag.Title = "Edit Academic Report";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>
    <style>
        :root {
            --dgss-navy: #0d2b73;
            --dgss-light-blue: #d4e0f1;
            --dgss-accent: #4169e1;
            --dgss-white: #ffffff;
            --dgss-border: #cfdbe9;
            --dgss-error: #d32f2f;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: var(--dgss-light-blue);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #222;
            padding-bottom: 50px;
        }

        /* Header Consistency */
        .header {
            background-color: #f0f4f8;
            padding: 25px 20px;
            text-align: center;
            border-bottom: 4px solid var(--dgss-navy);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 25px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        }

        .header-logo img {
            height: 80px;
            width: auto;
            display: block;
        }

        .header-text h1 {
            margin: 0;
            color: var(--dgss-navy);
            font-size: 28px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .header-text p {
            margin: 4px 0 0 0;
            color: var(--dgss-navy);
            font-size: 14px;
            font-weight: 600;
            opacity: 0.8;
        }

        /* Form Container */
        .container-custom {
            max-width: 1000px;
            margin: 40px auto;
            padding: 35px;
            background-color: var(--dgss-white);
            border-radius: 12px;
            box-shadow: 0 10px 25px rgba(13, 43, 115, 0.1);
            border-top: 6px solid var(--dgss-navy);
        }

        .center-heading {
            text-align: center;
            color: var(--dgss-accent);
            font-size: 18px;
            font-weight: 700;
            margin: 30px 0 20px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-bottom: 1px solid var(--dgss-border);
            padding-bottom: 10px;
        }

        .form-row {
            display: flex;
            gap: 20px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .form-group-custom {
            display: flex;
            flex-direction: column;
            flex: 1;
            min-width: 220px;
        }

            .form-group-custom label {
                font-weight: 700;
                color: var(--dgss-navy);
                margin-bottom: 8px;
                font-size: 13px;
                text-transform: uppercase;
            }

            .form-group-custom input,
            .form-group-custom select {
                padding: 12px 15px;
                font-size: 15px;
                border: 2px solid var(--dgss-border);
                border-radius: 8px;
                background: #fff;
                width: 100%;
                transition: border-color 0.3s, box-shadow 0.3s;
            }

                .form-group-custom input:focus,
                .form-group-custom select:focus {
                    outline: none;
                    border-color: var(--dgss-accent);
                    box-shadow: 0 0 0 3px rgba(65, 105, 225, 0.1);
                }

        .validation-summary {
            color: var(--dgss-error);
            margin-bottom: 25px;
            padding: 15px;
            background: #fff1f1;
            border-left: 5px solid var(--dgss-error);
            border-radius: 6px;
            font-size: 14px;
        }

        .text-danger {
            color: var(--dgss-error);
            font-size: 11px;
            margin-top: 5px;
            font-weight: 600;
        }

        .button-row {
            display: flex;
            gap: 15px;
            justify-content: center;
            margin-top: 40px;
        }

        .btn-save {
            padding: 14px 40px;
            font-weight: 700;
            border-radius: 8px;
            cursor: pointer;
            border: none;
            background: var(--dgss-navy);
            color: #fff;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: transform 0.2s, background 0.3s;
        }

            .btn-save:hover {
                background: var(--dgss-accent);
                transform: translateY(-2px);
            }

        .btn-back {
            padding: 14px 40px;
            font-weight: 700;
            border-radius: 8px;
            cursor: pointer;
            border: 2px solid var(--dgss-navy);
            background: #fff;
            color: var(--dgss-navy);
            text-transform: uppercase;
            text-decoration: none;
            display: inline-block;
            text-align: center;
            transition: all 0.3s;
        }

            .btn-back:hover {
                background: var(--dgss-navy);
                color: #fff;
            }

        .footer {
            background-color: var(--dgss-navy);
            color: #fff;
            padding: 30px 20px;
            margin-top: 40px;
            border-radius: 8px;
        }

        .footer-content {
            max-width: 1000px;
            margin: 0 auto;
        }

        .footer-title {
            font-weight: 700;
            font-size: 16px;
            margin-bottom: 10px;
        }

        .footer-info {
            font-size: 13px;
            line-height: 1.8;
            opacity: 0.9;
        }

        @@media (max-width: 768px) {
            .header {
                flex-direction: column;
                text-align: center;
            }

            .form-group-custom {
                min-width: 100%;
            }

            .button-row {
                flex-direction: column;
            }

            .btn-save, .btn-back {
                width: 100%;
            }
        }
    </style>
</head>
<body>
    <div class="header">
        <div class="header-logo">
            <img src="https://tse3.mm.bing.net/th/id/OIP.4F7suouXbLCmtrEpz8RoXAHaCD?rs=1&pid=ImgDetMain&o=7&rm=3" alt="Logo" />
        </div>
        <div class="header-text">
            <h1>Academic Management</h1>
            <p>Update Student Performance Record</p>
        </div>
    </div>

    <div class="container-custom">
        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

            if (ViewData.ModelState.Values.Any(x => x.Errors.Count > 0))
            {
                <div class="validation-summary">
                    @Html.ValidationSummary(true, "Please review the following errors:")
                </div>
            }

            @Html.HiddenFor(m => m.ReportId)

            <div class="form-section">
                <!-- Basic Info Section (Grade Field Removed) -->
                <div class="form-row">
                    <div class="form-group-custom">
                        @Html.LabelFor(m => m.StudentNumber, "Student ID")
                        @Html.EditorFor(m => m.StudentNumber, new { htmlAttributes = new { @class = "form-control", placeholder = "e.g. 2024001" } })
                        @Html.ValidationMessageFor(m => m.StudentNumber, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group-custom">
                        @Html.LabelFor(m => m.StudentName, "Full Name")
                        @Html.EditorFor(m => m.StudentName, new { htmlAttributes = new { @class = "form-control", placeholder = "First and Last Name" } })
                        @Html.ValidationMessageFor(m => m.StudentName, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="center-heading">Performance Data</div>

                <div class="form-row">
                    <div class="form-group-custom">
                        @Html.LabelFor(m => m.Subject)
                        @Html.EnumDropDownListFor(m => m.Subject, new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.Subject, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group-custom">
                        @Html.LabelFor(m => m.TeacherId, "Subject Educator")
                        @Html.DropDownList("TeacherId", null, "-- Select Teacher --", new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.TeacherId, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group-custom">
                        @Html.LabelFor(m => m.assignmentMark, "Assignment")
                        @Html.EditorFor(m => m.assignmentMark, new { htmlAttributes = new { @class = "form-control", type = "number", min = "0" } })
                        @Html.ValidationMessageFor(m => m.assignmentMark, "", new { @class = "text-danger" })
                    </div>
                    <div class="form-group-custom">
                        @Html.LabelFor(m => m.test1Mark, "Test 1")
                        @Html.EditorFor(m => m.test1Mark, new { htmlAttributes = new { @class = "form-control", type = "number", min = "0" } })
                        @Html.ValidationMessageFor(m => m.test1Mark, "", new { @class = "text-danger" })
                    </div>
                    <div class="form-group-custom">
                        @Html.LabelFor(m => m.test2Mark, "Test 2")
                        @Html.EditorFor(m => m.test2Mark, new { htmlAttributes = new { @class = "form-control", type = "number", min = "0" } })
                        @Html.ValidationMessageFor(m => m.test2Mark, "", new { @class = "text-danger" })
                    </div>
                    <div class="form-group-custom">
                        @Html.LabelFor(m => m.examMark, "Final Exam")
                        @Html.EditorFor(m => m.examMark, new { htmlAttributes = new { @class = "form-control", type = "number", min = "0" } })
                        @Html.ValidationMessageFor(m => m.examMark, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group-custom">
                        @Html.LabelFor(m => m.Descriptor, "Level Descriptor (1-7)")
                        @Html.EditorFor(m => m.Descriptor, new { htmlAttributes = new { @class = "form-control", type = "number", min = "1", max = "7" } })
                        @Html.ValidationMessageFor(m => m.Descriptor, "", new { @class = "text-danger" })
                    </div>
                    <div class="form-group-custom">
                        @Html.LabelFor(m => m.Percentage, "Exam %")
                        @Html.EditorFor(m => m.Percentage, new { htmlAttributes = new { @class = "form-control", type = "number", step = "0.01" } })
                        @Html.ValidationMessageFor(m => m.Percentage, "", new { @class = "text-danger" })
                    </div>
                    <div class="form-group-custom">
                        @Html.LabelFor(m => m.FinalPercentage, "Final Year %")
                        @Html.EditorFor(m => m.FinalPercentage, new { htmlAttributes = new { @class = "form-control", type = "number", step = "0.01" } })
                        @Html.ValidationMessageFor(m => m.FinalPercentage, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group-custom">
                        @Html.LabelFor(m => m.GradeAverage, "Grade Average %")
                        @Html.EditorFor(m => m.GradeAverage, new { htmlAttributes = new { @class = "form-control", type = "number", step = "0.01" } })
                        @Html.ValidationMessageFor(m => m.GradeAverage, "", new { @class = "text-danger" })
                    </div>
                    <div class="form-group-custom">
                        @Html.LabelFor(m => m.Status, "Outcome Status")
                        @Html.EditorFor(m => m.Status, new { htmlAttributes = new { @class = "form-control", placeholder = "Pass / Fail" } })
                        @Html.ValidationMessageFor(m => m.Status, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="button-row">
                    <button type="submit" class="btn-save">Update Record</button>
                    <a href="@Url.Action("Index")" class="btn-back">Cancel Changes</a>
                </div>
            </div>
        }
    </div>

    <div class="footer-content" style="padding: 0 20px;">
        <div class="footer">
            <div class="footer-title">Durban Girls Secondary School</div>
            <div class="footer-info">
                📍 165 Helen Street, Durban, South Africa, 4001<br />
                📞 +27 31 305 3163 | ✉️ info@durbangirlsschool.co.za
            </div>
            <div style="text-align:center; margin-top:15px; font-size:12px; opacity:0.7;">© @DateTime.Now.Year Durban Girls Secondary School Management System</div>
        </div>
    </div>
</body>
</html>