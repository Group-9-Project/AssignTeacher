@model SchoolTimetable.ViewModels.BookFormViewModel

@{
    Layout = null;
    ViewBag.Title = "Home Page";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Durban Girls Secondary School</title>
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800&family=Barlow:wght@200;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        :root {
            --navy-deep: #002147;
            --navy-accent: #003366;
            --pure-white: #ffffff;
            --soft-gray: #f4f7f9;
            --glass-bg: rgba(255, 255, 255, 0.85);
            --navy-glass: rgba(0, 33, 71, 0.05);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Barlow', sans-serif;
            background: var(--soft-gray);
            color: var(--navy-deep);
            line-height: 1.6;
            overflow-x: hidden;
        }

        /* Full Background - Highly Visible with subtle vignette */
        .page-bg-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(rgba(255,255,255,0.4), rgba(255,255,255,0.1)), url('/Content/Images/tp-image-3986.jpg');
            background-size: cover;
            background-position: center;
            z-index: -1;
            filter: saturate(1.1);
        }

        /* Modern Transparent Nav */
        nav {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1.2rem 5%;
            background: var(--glass-bg);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(0, 33, 71, 0.1);
        }

        .nav-logo-container {
            display: flex;
            align-items: center;
            gap: 15px;
            text-decoration: none;
        }

        .school-crest-nav {
            height: 55px;
            width: auto;
        }

        .nav-logo-text {
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 1.3rem;
            font-weight: 800;
            color: var(--navy-deep);
            letter-spacing: 0.5px;
            line-height: 1;
            text-transform: uppercase;
            border-left: 2px solid var(--navy-deep);
            padding-left: 15px;
        }

        .nav-links-wrapper {
            display: flex;
            list-style: none;
            gap: 2.5rem;
        }

        .nav-link {
            text-decoration: none;
            color: var(--navy-deep);
            font-size: 0.85rem;
            text-transform: uppercase;
            font-weight: 700;
            letter-spacing: 1.5px;
            transition: 0.3s;
            position: relative;
        }

            .nav-link::after {
                content: '';
                position: absolute;
                bottom: -5px;
                left: 0;
                width: 0%;
                height: 2px;
                background: var(--navy-deep);
                transition: 0.3s;
            }

            .nav-link:hover::after {
                width: 100%;
            }

        .btn-portal {
            border: 2px solid var(--navy-deep);
            color: var(--navy-deep);
            padding: 0.6rem 1.5rem;
            font-size: 0.8rem;
            text-decoration: none;
            text-transform: uppercase;
            font-weight: 800;
            transition: 0.3s;
        }

            .btn-portal:hover {
                background: var(--navy-deep);
                color: var(--pure-white);
            }

        /* Hero Content Card */
        .hero {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 120px 20px 60px;
        }

        .hero-title {
            font-family: 'Barlow Condensed', sans-serif;
            font-size: clamp(3.5rem, 12vw, 9rem);
            font-weight: 800;
            color: var(--navy-deep);
            text-transform: uppercase;
            line-height: 0.85;
            margin-bottom: 1.5rem;
            letter-spacing: -2px;
        }

            .hero-title span {
                display: block;
                font-weight: 200;
                font-size: 0.45em;
                letter-spacing: 15px;
                color: var(--navy-accent);
                margin-top: 10px;
            }

        .hero-description {
            font-size: 1.25rem;
            margin: 0 auto 3rem;
            max-width: 650px;
            color: var(--navy-deep);
            font-weight: 400;
        }

        /* Elegant Timer */
        .timer-grid {
            display: flex;
            justify-content: center;
            gap: 1rem;
            margin-bottom: 3.5rem;
        }

        .unit {
            background: var(--glass-bg);
            border: 1px solid rgba(0, 33, 71, 0.1);
            padding: 1.5rem;
            min-width: 100px;
            border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        }

        .timer-val {
            display: block;
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 2.5rem;
            font-weight: 800;
            color: var(--navy-deep);
        }

        /* Floating Pillars */
        .pillars-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            width: 100%;
            max-width: 1200px;
            margin-top: 4rem;
        }

        .pillar-card {
            background: var(--pure-white);
            padding: 3.5rem 2rem;
            border-radius: 15px;
            transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            box-shadow: 0 20px 40px rgba(0,0,0,0.08);
            border: 1px solid rgba(0,0,0,0.02);
        }

            .pillar-card:hover {
                transform: translateY(-15px);
                box-shadow: 0 30px 60px rgba(0, 33, 71, 0.15);
            }

        .pillar-icon {
            font-size: 2.5rem;
            color: var(--navy-accent);
            margin-bottom: 1.5rem;
        }

        .pillar-card h3 {
            font-family: 'Barlow Condensed', sans-serif;
            text-transform: uppercase;
            font-size: 1.7rem;
            margin-bottom: 1rem;
            color: var(--navy-deep);
        }

        /* Action Button */
        .btn-apply {
            background: var(--navy-deep);
            color: var(--pure-white);
            padding: 1.2rem 4rem;
            font-size: 1.1rem;
            text-decoration: none;
            text-transform: uppercase;
            font-weight: 800;
            border-radius: 50px;
            letter-spacing: 2px;
            transition: 0.3s;
            box-shadow: 0 15px 30px rgba(0, 33, 71, 0.3);
        }

            .btn-apply:hover {
                background: var(--navy-accent);
                transform: scale(1.05);
                box-shadow: 0 20px 40px rgba(0, 33, 71, 0.4);
            }

        footer {
            background: var(--pure-white);
            padding: 4rem 2rem;
            text-align: center;
            border-top: 1px solid rgba(0,0,0,0.05);
        }

        .motto {
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 800;
            font-size: 1.5rem;
            letter-spacing: 8px;
            color: var(--navy-deep);
            margin-bottom: 15px;
            display: block;
        }

        @@media (max-width: 768px) {
            nav {
                padding: 1rem 5%;
            }

            .nav-links-wrapper {
                display: none;
            }

            .hero-title {
                font-size: 4rem;
            }

                .hero-title span {
                    letter-spacing: 5px;
                }
        }
    </style>
</head>
<body>

    <div class="page-bg-overlay"></div>

    <nav>
        <a href="/" class="nav-logo-container">
            <img src="~/Content/Images/za-368-kzn-dgss.jpg" alt="DGSS Crest" class="school-crest-nav" />
            <div class="nav-logo-text">Durban Girls<br>Secondary School</div>
        </a>

        <ul class="nav-links-wrapper">
            <li><a href="@Url.Action("Index", "Home")" class="nav-link">Home</a></li>
            <li><a href="@Url.Action("About", "Home")" class="nav-link">Our Heritage</a></li>
            <li><a href="@Url.Action("Contact", "Home")" class="nav-link">Contact</a></li>
        </ul>

        <a href="@Url.Action("Login", "Teachers")" class="btn-portal">Login</a>
    </nav>

    <main class="hero">
        <div class="timer-container">
            <p style="text-transform:uppercase; letter-spacing: 5px; font-weight: 700; font-size: 0.85rem; margin-bottom: 20px; color: var(--navy-accent);">2027 Admissions Open</p>
            <div class="timer-grid">
                <div class="unit"><span class="timer-val" id="days">00</span><span style="font-size: 0.7rem; text-transform: uppercase; font-weight: 600;">Days</span></div>
                <div class="unit"><span class="timer-val" id="hours">00</span><span style="font-size: 0.7rem; text-transform: uppercase; font-weight: 600;">Hours</span></div>
                <div class="unit"><span class="timer-val" id="mins">00</span><span style="font-size: 0.7rem; text-transform: uppercase; font-weight: 600;">Mins</span></div>
            </div>
        </div>

        <h1 class="hero-title">
            ONWARD<span>AND UPWARD</span>
        </h1>

        <p class="hero-description">
            Empowering the next generation of South African leaders through a rich heritage of academic and cultural excellence.
        </p>

        <a href="@Url.Action("Register", "Parents")" class="btn-apply">Begin Your Application</a>

        <div class="pillars-grid">
            <div class="pillar-card">
                <i class="fas fa-microscope pillar-icon"></i>
                <h3>Innovation</h3>
                <p style="color: #666;">State-of-the-art facilities designed to foster scientific inquiry and creative problem solving.</p>
            </div>
            <div class="pillar-card">
                <i class="fas fa-balance-scale pillar-icon"></i>
                <h3>Character</h3>
                <p style="color: #666;">Instilling values of integrity, compassion, and leadership in a diverse global society.</p>
            </div>
            <div class="pillar-card">
                <i class="fas fa-globe-africa pillar-icon"></i>
                <h3>Community</h3>
                <p style="color: #666;">Deeply rooted in the Durban community with a focus on sustainable social responsibility.</p>
            </div>
        </div>
    </main>

    <footer>
        <span class="motto">EMPOWERING EXCELLENCE</span>
        <p style="font-size: 0.8rem; color: #888; font-weight: 600;">&copy; @DateTime.Now.Year DURBAN GIRLS SECONDARY SCHOOL. <br>COMMITMENT TO EXCELLENCE SINCE 1882.</p>
    </footer>

    <script>
        const countDate = new Date("Sep 30, 2026 23:59:59").getTime();
        const timer = setInterval(function () {
            const now = new Date().getTime();
            const gap = countDate - now;
            const d = Math.floor(gap / (1000 * 60 * 60 * 24));
            const h = Math.floor((gap % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const m = Math.floor((gap % (1000 * 60 * 60)) / (1000 * 60));

            document.getElementById("days").innerText = d.toString().padStart(2, '0');
            document.getElementById("hours").innerText = h.toString().padStart(2, '0');
            document.getElementById("mins").innerText = m.toString().padStart(2, '0');

            if (gap < 0) {
                clearInterval(timer);
                document.querySelector(".timer-grid").innerHTML = "<h2 style='color:var(--navy-deep)'>ADMISSIONS CLOSED</h2>";
            }
        }, 1000);
    </script>
</body>
</html>