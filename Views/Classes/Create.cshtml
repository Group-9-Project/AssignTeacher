@model SchoolTimetable.Models.SchoolClass
@{
    ViewBag.Title = "Add Class";
    Layout = null; // Explicitly disabling layout
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register Class - School Timetable</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        :root {
            --navy-deep: #002147;
            --white-bright: #ffffff;
            --slate-50: #f8fafc;
            --slate-100: #f1f5f9;
            --slate-200: #e2e8f0;
            --slate-300: #cbd5e1;
            --slate-500: #64748b;
            --error-red: #be123c;
        }

        body {
            background-color: var(--slate-50);
            font-family: 'Inter', sans-serif;
            color: var(--navy-deep);
            margin: 0;
            padding: 0;
        }

        .form-container {
            max-width: 800px;
            margin: 4rem auto;
            padding: 0 1.5rem;
        }

        /* Institutional Navy Header */
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-bottom: 2.5rem;
            border-bottom: 4px solid var(--navy-deep);
            padding-bottom: 1rem;
        }

        .page-title {
            font-size: 1.8rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: -1px;
            margin: 0;
            color: var(--navy-deep);
        }

        /* Form Card */
        .card {
            background: var(--white-bright);
            border: 1px solid var(--slate-300);
            border-radius: 4px;
            padding: 3rem;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.04);
        }

        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
            margin-bottom: 1rem;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
            margin-bottom: 1.5rem;
        }

        .form-label {
            font-size: 0.7rem;
            font-weight: 800;
            text-transform: uppercase;
            color: var(--slate-500);
            letter-spacing: 0.8px;
        }

        .form-control {
            padding: 14px;
            border: 2px solid var(--slate-200);
            border-radius: 2px;
            font-family: inherit;
            font-size: 0.95rem;
            transition: all 0.2s;
            color: var(--navy-deep);
            background: var(--white-bright);
        }

            .form-control:focus {
                outline: none;
                border-color: var(--navy-deep);
                background: #fafafa;
            }

        /* Validation UI */
        .validation-summary-errors {
            background: #fff1f2;
            color: var(--error-red);
            padding: 1.2rem;
            border-left: 5px solid var(--error-red);
            margin-bottom: 2rem;
            font-size: 0.85rem;
            font-weight: 600;
            list-style: none;
        }

        .field-validation-error {
            color: var(--error-red);
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            margin-top: 4px;
        }

        /* Buttons */
        .btn {
            padding: 12px 24px;
            font-weight: 800;
            text-transform: uppercase;
            border-radius: 2px;
            cursor: pointer;
            font-size: 0.75rem;
            letter-spacing: 0.5px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            transition: all 0.2s;
            border: 2px solid var(--navy-deep);
        }

        .btn-primary {
            background: var(--navy-deep);
            color: white;
        }

            .btn-primary:hover {
                background: white;
                color: var(--navy-deep);
            }

        .btn-outline {
            background: transparent;
            border-color: var(--slate-300);
            color: var(--slate-500);
        }

            .btn-outline:hover {
                border-color: var(--navy-deep);
                color: var(--navy-deep);
                background: white;
            }

        .form-footer {
            display: flex;
            gap: 12px;
            justify-content: flex-end;
            padding-top: 2rem;
            border-top: 1px solid var(--slate-100);
            margin-top: 1rem;
        }
    </style>
</head>
<body>

    <div class="form-container">
        <div class="page-header">
            <h1 class="page-title">Register New Class</h1>
            <a href="@Url.Action("Index")" class="btn btn-outline">
                <i class="fas fa-arrow-left"></i> Registry
            </a>
        </div>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

            if (!ViewData.ModelState.IsValid)
            {
                <div class="validation-summary-errors">
                    <i class="fas fa-exclamation-circle"></i> @Html.ValidationSummary(false, "Check the following fields:")
                </div>
            }

            <div class="card">
                <div class="form-grid">
                    <div class="form-group">
                        @Html.LabelFor(m => m.Name, "Designation Name", new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.Name, new { @class = "form-control", placeholder = "e.g. Grade 10-A" })
                        @Html.ValidationMessageFor(m => m.Name)
                    </div>
                    <div class="form-group">
                        @Html.LabelFor(m => m.Grade, "Academic Grade", new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.Grade, new { @class = "form-control", placeholder = "e.g. 10" })
                        @Html.ValidationMessageFor(m => m.Grade)
                    </div>
                </div>

                <div class="form-grid">
                    <div class="form-group">
                        @Html.LabelFor(m => m.Room, "Allocated Venue/Room", new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.Room, new { @class = "form-control", placeholder = "e.g. LAB-01" })
                    </div>
                    <div class="form-group">
                        @Html.LabelFor(m => m.StudentCount, "Enrollment Capacity", new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.StudentCount, new { @class = "form-control", placeholder = "35", type = "number" })
                    </div>
                </div>

                <div class="form-footer">
                    <a href="@Url.Action("Index")" class="btn btn-outline">Discard</a>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Save Class Data
                    </button>
                </div>
            </div>
        }
    </div>

</body>
</html>