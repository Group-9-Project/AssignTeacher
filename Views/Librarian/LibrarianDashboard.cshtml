@model SchoolTimetable.ViewModels.LibrarianDashboardViewModel
@{
    Layout = null;
    ViewBag.Title = "Librarian Terminal";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>DGSS LIBRARY</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&family=Roboto+Mono:wght@500;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --navy-dark: #001f3f; /* Deep Navy */
            --navy-mid: #003366;
            --white: #ffffff;
            --off-white: #f4f7f9;
            --border-heavy: 3px solid var(--navy-dark);
            --border-thin: 1px solid #d1d5db;
            --danger: #cc0000;
        }

        body {
            background-color: var(--off-white);
            color: var(--navy-dark);
            font-family: 'Inter', sans-serif;
            margin: 0;
            padding: 30px;
        }

        .terminal-frame {
            max-width: 1600px;
            margin: 0 auto;
            background: var(--white);
            border: var(--border-heavy);
        }

        /* Top Bar - Identity */
        .system-bar {
            background: var(--navy-dark);
            color: var(--white);
            padding: 8px 20px;
            font-family: 'Roboto Mono', monospace;
            font-size: 0.7rem;
            display: flex;
            justify-content: space-between;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        /* Main Header */
        .header {
            padding: 40px 50px;
            border-bottom: var(--border-heavy);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .header h1 {
                margin: 0;
                font-size: 2.5rem;
                font-weight: 900;
                text-transform: uppercase;
                letter-spacing: -1px;
            }

        /* Utility Actions */
        .nav-bar {
            padding: 0;
            border-bottom: var(--border-thin);
            display: flex;
        }

        .nav-link {
            padding: 15px 30px;
            border-right: var(--border-thin);
            text-decoration: none;
            color: var(--navy-dark);
            font-weight: 700;
            font-size: 0.8rem;
            text-transform: uppercase;
            transition: 0.1s;
        }

            .nav-link:hover {
                background: var(--navy-dark);
                color: var(--white);
            }

        /* KPI Dashboard Row */
        .stats-row {
            display: flex;
            border-bottom: var(--border-heavy);
        }

        .stat-item {
            flex: 1;
            padding: 30px 50px;
            border-right: var(--border-thin);
        }

            .stat-item:last-child {
                border-right: none;
            }

        .stat-label {
            display: block;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            color: #666;
            margin-bottom: 5px;
        }

        .stat-value {
            font-family: 'Roboto Mono', monospace;
            font-size: 3rem;
            font-weight: 700;
            line-height: 1;
        }

        /* Grid Layout */
        .main-container {
            display: grid;
            grid-template-columns: 2fr 1fr;
            min-height: 500px;
        }

        .panel-left {
            padding: 40px 50px;
            border-right: var(--border-heavy);
        }

        .panel-right {
            padding: 40px 40px;
            background: #fafafa;
        }

        h2.section-title {
            font-size: 1.2rem;
            text-transform: uppercase;
            margin-bottom: 30px;
            border-bottom: 2px solid var(--navy-dark);
            display: inline-block;
            padding-bottom: 5px;
        }

        /* Terminal Table */
        .terminal-table {
            width: 100%;
            border-collapse: collapse;
        }

            .terminal-table th {
                text-align: left;
                padding: 10px 15px;
                background: var(--navy-dark);
                color: var(--white);
                font-size: 0.75rem;
                text-transform: uppercase;
            }

            .terminal-table td {
                padding: 15px;
                border-bottom: 1px solid #eee;
                font-size: 0.9rem;
            }

            .terminal-table tr:hover {
                background: #f0f4f8;
            }

        /* Overdue List Item */
        .penalty-item {
            padding: 15px;
            border: 1px solid var(--navy-dark);
            margin-bottom: 10px;
            background: white;
        }

        .penalty-member {
            font-weight: 800;
            display: block;
        }

        .penalty-amt {
            color: var(--danger);
            font-family: 'Roboto Mono', monospace;
            font-weight: 700;
        }

        .footer {
            padding: 15px 50px;
            font-size: 0.65rem;
            font-weight: 700;
            color: #999;
            text-transform: uppercase;
        }
    </style>
</head>
<body>

    <div class="terminal-frame">
        <div class="system-bar">
            <span>Durban Girls Secondary School</span>
            <span>Node: DGSS-LIB-01 // @DateTime.Now.ToString("HH:mm:ss")</span>
        </div>

        <div class="header">
            <div>
                <h1>Librarian Terminal</h1>
                <span style="font-weight: 700; letter-spacing: 1px; font-size: 0.8rem;">RECORDS & ASSET MANAGEMENT</span>
            </div>
            <div style="text-align: right">
                <span style="display:block; font-size: 0.9rem; font-weight: 700;">USER: @Session["UserName"]</span>
                <a href="@Url.Action("Logout", "Teachers")" style="color: var(--danger); text-decoration: none; font-size: 0.7rem; font-weight: 800;">[ LOGOUT ]</a>
            </div>
        </div>

        <div class="nav-bar">
            <a href="@Url.Action("Index", "Books")" class="nav-link">Catalogue</a>
            <a href="@Url.Action("Create", "Books")" class="nav-link">Add Books</a>
            <a href="@Url.Action("Index", "Borrowings")" class="nav-link">Borrowings</a>
            <a href="@Url.Action("Members", "Librarian")" class="nav-link">Members</a>
        </div>

        <div class="stats-row">
            <div class="stat-item">
                <span class="stat-label">Total Books</span>
                <span class="stat-value">@Model.TotalBooks</span>
            </div>
            <div class="stat-item">
                <span class="stat-label">Out for borrowing</span>
                <span class="stat-value">@Model.ActiveBorrowings</span>
            </div>
            <div class="stat-item" style="color: var(--danger);">
                <span class="stat-label" style="color: var(--danger);">Overdue Count</span>
                <span class="stat-value">@Model.OverdueBorrowings</span>
            </div>
            <div class="stat-item">
                <span class="stat-label">Total Members</span>
                <span class="stat-value">@Model.TotalStudents</span>
            </div>
        </div>

        <div class="main-container">
            <div class="panel-left">
                <h2 class="section-title">Recent Borrowings</h2>
                <table class="terminal-table">
                    <thead>
                        <tr>
                            <th>Ref ID</th>
                            <th>Student / Member</th>
                            <th>Book Title</th>
                            <th>Return Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in Model.RecentBorrowings)
                        {
                            <tr>
                                <td style="font-family: 'Roboto Mono'; font-weight:700;">#@b.Id.ToString("D5")</td>
                                <td><strong>@b.Student.FullName</strong></td>
                                <td>@b.Book.Title</td>
                                <td>@b.DueDate.ToString("dd MMM yyyy")</td>
                                <td><span style="font-weight:900; font-size: 0.7rem;">@b.Status.ToString().ToUpper()</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="panel-right">
                <h2 class="section-title">Outstanding Fines</h2>
                @if (Model.OverdueList.Any())
                {
                    foreach (var o in Model.OverdueList)
                    {
                        <div class="penalty-item">
                            <div style="display: flex; justify-content: space-between;">
                                <span class="penalty-member">@o.Student.FullName</span>
                                <span class="penalty-amt">R @o.FineAmount.ToString("N2")</span>
                            </div>
                            <span style="font-size: 0.7rem; color: #666; text-transform: uppercase;">@o.Book.Title</span>
                        </div>
                    }
                }
                else
                {
                    <p style="font-size: 0.8rem; font-weight: 700; color: #006633;">All records clear.</p>
                }
            </div>
        </div>

        <div class="footer">
            © 2026 Durban Girls Secondary School | System Integrity: Nominal
        </div>
    </div>

</body>
</html>