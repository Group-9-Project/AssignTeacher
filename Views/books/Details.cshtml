@model SchoolTimetable.Models.Book
@{
    Layout = null;
    ViewBag.Title = Model.Title;
    var sessionUser = SchoolTimetable.Models.SessionHelper.GetUser(Session);
    var myBorrow = ViewBag.MyBorrow as SchoolTimetable.Models.Borrowing;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Library Catalogue</title>

    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@800&family=Barlow:wght@400;500;600;700&display=swap');

        :root {
            --navy-deep: #0a192f;
            --navy-muted: #112240;
            --navy-accent: #233554;
            --white-bright: #ffffff;
            --white-muted: #ccd6f6;
            --gold-highlight: #b08d48;
            --danger-red: #ef4444;
            --success-teal: #10b981;
        }

        body {
            background-color: var(--navy-deep);
            margin: 0;
            padding: 0;
            color: var(--white-bright);
            font-family: 'Barlow', sans-serif;
        }

        .details-container {
            max-width: 1100px;
            margin: 2rem auto;
            padding: 0 1rem;
        }

        /* Nav Header */
        .nav-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
            gap: 15px;
        }

        .nav-links-group {
            display: flex;
            gap: 20px;
        }

        .back-link {
            color: var(--white-muted);
            text-decoration: none;
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 800;
            text-transform: uppercase;
            font-size: 0.9rem;
            letter-spacing: 0.1em;
            transition: 0.3s;
            display: flex;
            align-items: center;
        }

        .back-link:hover {
            color: var(--white-bright);
            transform: translateX(-5px);
        }

        .dashboard-link {
            color: var(--gold-highlight);
            border: 1px solid var(--gold-highlight);
            padding: 4px 12px;
            transition: 0.3s;
        }

        .dashboard-link:hover {
            background: var(--gold-highlight);
            color: var(--navy-deep) !important;
        }

        .grid-layout {
            display: grid;
            grid-template-columns: 1.5fr 1fr;
            gap: 2rem;
            align-items: start;
        }

        /* Light Theme Card */
        .card-light {
            background: var(--white-bright);
            color: var(--navy-deep);
            border-radius: 2px;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
        }

        .book-header {
            padding: 3rem;
        }

        .book-title {
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 3.5rem;
            text-transform: uppercase;
            color: var(--navy-deep);
            line-height: 0.9;
            margin: 0 0 0.5rem 0;
        }

        .book-author {
            font-size: 1.2rem;
            color: var(--navy-accent);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 2rem;
        }

        .info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
            margin-bottom: 2rem;
            padding: 1.5rem;
            background: #f8f9fa;
            border: 1px solid #eee;
        }

        .info-item label {
            display: block;
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 800;
            text-transform: uppercase;
            font-size: 0.75rem;
            color: #888;
            margin-bottom: 0.2rem;
        }

        .info-item span {
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--navy-deep);
        }

        /* Buttons */
        .action-stack {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-top: 2rem;
        }

        .btn-dg {
            padding: 1.2rem;
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            font-size: 1rem;
            cursor: pointer;
            transition: 0.3s;
            border: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            border-radius: 0;
        }

        .btn-navy {
            background: var(--navy-deep);
            color: var(--white-bright);
        }

        .btn-navy:hover {
            background: var(--navy-accent);
            transform: translateY(-2px);
        }

        .btn-gold-outline {
            border: 2px solid var(--gold-highlight);
            color: var(--gold-highlight);
            background: transparent;
        }

        .btn-gold-outline:hover {
            background: var(--gold-highlight);
            color: white;
        }

        /* History Card */
        .card-dark {
            background: var(--navy-muted);
            border: 1px solid var(--navy-accent);
            color: var(--white-bright);
        }

        .history-table {
            width: 100%;
            border-collapse: collapse;
        }

        .history-table th {
            text-align: left;
            padding: 1rem;
            background: var(--navy-accent);
            color: var(--white-bright);
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 0.8rem;
        }

        .history-table td {
            padding: 1rem;
            border-bottom: 1px solid var(--navy-accent);
            color: var(--white-muted);
        }

        .badge-dg {
            padding: 0.3rem 0.6rem;
            font-family: 'Barlow Condensed';
            font-size: 0.75rem;
            font-weight: 800;
            text-transform: uppercase;
        }

        .badge-reserved {
            background: var(--gold-highlight);
            color: white;
        }

    </style>
</head>
<body>

    <div class="details-container">
        <div class="nav-header">
            <a href="@Url.Action("Index")" class="back-link">← Back to Catalogue</a>

            <div class="nav-links-group">
                @if (sessionUser != null)
                {
                    if (sessionUser.IsLibrarian)
                    {
                        <a href="@Url.Action("Librarian", "Librarian")" class="back-link dashboard-link">Librarian Dashboard ⌂</a>
                    }
                    else
                    {
                        <a href="@Url.Action("", "StudentAccount")" class="back-link dashboard-link">My Dashboard ⌂</a>
                    }
                }
            </div>
        </div>

        <div class="grid-layout">
            <div class="card-light">
                <div class="book-header">
                    <h1 class="book-title">@Model.Title</h1>
                    <p class="book-author">By @Model.Author</p>

                    <div class="info-grid">
                        <div class="info-item"><label>ISBN</label><span>@(string.IsNullOrEmpty(Model.ISBN) ? "N/A" : Model.ISBN)</span></div>
                        <div class="info-item"><label>Classification</label><span>@(string.IsNullOrEmpty(Model.Genre) ? "General" : Model.Genre)</span></div>
                        <div class="info-item"><label>Stock Level</label><span>@Model.AvailableCopies / @Model.TotalCopies</span></div>
                        <div class="info-item">
                            <label>Status</label>
                            <span style="color: @(Model.AvailableCopies == 0 ? "var(--danger-red)" : "var(--success-teal)")">
                                @(Model.AvailableCopies == 0 ? "OUT OF STOCK" : "AVAILABLE")
                            </span>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <p style="color: #555; line-height: 1.8; margin-bottom: 2rem; border-left: 3px solid #ddd; padding-left: 1rem;">@Model.Description</p>
                    }

                    <div class="action-stack">
                        @if (myBorrow != null)
                        {
                            <div style="background: #f0f4f8; padding: 1.5rem; border: 1px solid var(--navy-accent);">
                                <h3 style="font-family: 'Barlow Condensed'; margin: 0; color: var(--navy-deep);">CURRENT STATUS: @myBorrow.Status</h3>
                                <p style="font-size: 0.9rem; color: #666;">Return Date: @myBorrow.DueDate.ToString("dd MMM yyyy")</p>
                            </div>
                        }
                        else if (Model.AvailableCopies > 0)
                        {
                            using (Html.BeginForm("Reserve", "Books", new { id = Model.Id }, FormMethod.Post))
                            {
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-dg btn-navy" style="width:100%">Book for Collection</button>
                            }
                        }

                        @if (sessionUser != null && sessionUser.IsLibrarian)
                        {
                            <a href="@Url.Action("Edit", "Books", new { id = Model.Id })" class="btn-dg btn-gold-outline">Edit Resource Details</a>
                        }
                    </div>
                </div>
            </div>

            @if (sessionUser != null && sessionUser.IsLibrarian)
            {
                <div class="card-dark">
                    <div style="padding: 1.5rem; border-bottom: 1px solid var(--navy-accent);">
                        <h3 style="font-family: 'Barlow Condensed'; margin: 0; text-transform: uppercase;">Librarian Insights</h3>
                    </div>
                    <table class="history-table">
                        <thead>
                            <tr>
                                <th>Student</th>
                                <th>Date</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var b in Model.Borrowings.OrderByDescending(x => x.BorrowedDate).Take(5))
                            {
                                <tr>
                                    <td>@(b.Student != null ? b.Student.FullName : "User " + b.AppUserId)</td>
                                    <td>@b.BorrowedDate.ToString("dd MMM")</td>
                                    <td><span class="badge-dg badge-reserved">@b.Status</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</body>
</html>