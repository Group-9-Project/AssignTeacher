@model IEnumerable<SchoolTimetable.Models.TimetableSlot>
@{
    ViewBag.Title = "Teacher Dashboard";
    Layout = null;
    var teacherName = Session["TeacherName"] ?? "Teacher";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard :: @teacherName</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --navy-dark: #001a33;
            --navy-primary: #002b5c;
            --navy-light: #003d82;
            --white: #ffffff;
            --off-white: #f4f7f9;
            --live-green: #22c55e;
        }

        body {
            font-family: 'Inter', sans-serif;
            color: var(--navy-dark);
            background-color: var(--off-white);
            margin: 0;
        }

        /* Layout */
        .dashboard-header {
            background: var(--navy-primary);
            padding: 30px 50px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: var(--white);
            border-bottom: 4px solid var(--navy-dark);
        }

        .welcome-text {
            font-weight: 800;
            text-transform: uppercase;
            margin: 0;
            font-size: 1.8rem;
            letter-spacing: -1px;
        }

        .container {
            padding: 40px 50px;
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 30px;
        }

        /* Cards */
        .card {
            background: var(--white);
            border: 2px solid var(--navy-primary);
            box-shadow: 8px 8px 0px rgba(0, 43, 92, 0.1);
            margin-bottom: 30px;
        }

        .card-header {
            font-weight: 800;
            padding: 18px 25px;
            text-transform: uppercase;
            font-size: 0.85rem;
            background: var(--navy-primary);
            color: var(--white);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        /* Tables */
        .table {
            width: 100%;
            border-collapse: collapse;
        }

            .table th {
                background: #e6ecf2;
                text-transform: uppercase;
                font-size: 0.7rem;
                font-weight: 800;
                padding: 15px 25px;
                text-align: left;
                color: var(--navy-primary);
                border-bottom: 2px solid var(--navy-primary);
            }

            .table td {
                padding: 18px 25px;
                border-bottom: 1px solid #e6ecf2;
                font-size: 0.9rem;
            }

        /* Quick Links */
        .list-group-item {
            padding: 18px 25px;
            font-weight: 800;
            font-size: 0.75rem;
            text-transform: uppercase;
            text-decoration: none;
            display: block;
            color: var(--navy-primary);
            border-bottom: 1px solid #e6ecf2;
            transition: 0.2s;
        }

            .list-group-item:hover {
                background: var(--navy-primary);
                color: white;
                padding-left: 35px;
            }

        /* Online Class Styles */
        .oc-stats {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            background: #f8fafc;
            border-bottom: 1px solid #e2e8f0;
        }

        .oc-stat {
            padding: 15px;
            text-align: center;
            border-right: 1px solid #e2e8f0;
        }

        .oc-stat-val {
            display: block;
            font-size: 1.2rem;
            font-weight: 800;
            color: var(--navy-primary);
        }

        .oc-stat-lbl {
            font-size: 10px;
            text-transform: uppercase;
            color: #64748b;
            font-weight: 700;
        }

        .oc-class-row {
            display: flex;
            align-items: center;
            padding: 15px 20px;
            border-bottom: 1px solid #f1f5f9;
            position: relative;
        }

        .oc-status-bar {
            width: 4px;
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
        }

        .status-live {
            background: var(--live-green);
        }

        .status-upcoming {
            background: var(--navy-light);
        }

        .oc-info {
            flex: 1;
            margin-left: 10px;
        }

        .oc-title {
            font-weight: 700;
            font-size: 0.95rem;
        }

        .oc-meta {
            font-size: 0.75rem;
            color: #64748b;
            margin-top: 4px;
        }

        .btn-oc {
            padding: 6px 12px;
            font-size: 11px;
            font-weight: 800;
            text-transform: uppercase;
            border-radius: 4px;
            border: 1px solid #cbd5e1;
            cursor: pointer;
            text-decoration: none;
            margin-left: 5px;
        }

        .btn-oc-green {
            background: var(--live-green);
            color: white;
            border: none;
        }

        .btn-oc-new {
            background: white;
            color: var(--navy-primary);
            padding: 4px 10px;
            font-size: 10px;
        }

        .btn-logout {
            padding: 10px 20px;
            border: 2px solid white;
            color: white;
            text-decoration: none;
            font-weight: 800;
            font-size: 12px;
        }

        @@media (max-width: 1024px) {
            .container {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>

    <div class="dashboard-header">
        <div>
            <h2 class="welcome-text">WELCOME, @teacherName</h2>
            <div class="header-sub">Academic Portal :: Management Dashboard</div>
        </div>
        <a href="@Url.Action("Login", "Teachers")" class="btn-logout">Logout</a>
    </div>

    <div class="container">
        <div class="col-main">
            <div class="card">
                <div class="card-header">Assigned Schedule</div>
                <div style="overflow-x: auto;">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Day</th>
                                <th>Period</th>
                                <th>Subject</th>
                                <th>Room</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td style="font-weight: 800;">@((DayOfWeek)item.DayOfWeek)</td>
                                    <td><strong>P @item.Period</strong></td>
                                    <td><span style="font-weight: 800; color: var(--navy-light);">@item.Subject.Name</span></td>
                                    <td>@item.Class.Name</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    Online Classes
                    <a href="@Url.Action("Create", "OnlineClass")" class="btn-oc-new">+ New Class</a>
                </div>
                <div class="oc-stats">
                    <div class="oc-stat"><span class="oc-stat-val" id="statLive">—</span><span class="oc-stat-lbl">Live</span></div>
                    <div class="oc-stat"><span class="oc-stat-val" id="statUpcoming">—</span><span class="oc-stat-lbl">Upcoming</span></div>
                    <div class="oc-stat"><span class="oc-stat-val" id="statCompleted">—</span><span class="oc-stat-lbl">Done</span></div>
                    <div class="oc-stat"><span class="oc-stat-val" id="statStudents">—</span><span class="oc-stat-lbl">Students</span></div>
                </div>
                <div id="ocClassList">
                    <div style="padding: 40px; text-align: center; color: #64748b;">Loading classes...</div>
                </div>
            </div>
        </div>

        <div class="col-side">
            <div class="card">
                <div class="card-header">Quick Management</div>
                <div class="list-group">
                    <a href="@Url.Action("UploadMaterial", "Teachers")" class="list-group-item">Upload Materials</a>
                    <a href="@Url.Action("CreateAnnouncement", "Teachers")" class="list-group-item">Post Announcement</a>
                    <a href="@Url.Action("Details", "Teachers", new { id = Session["TeacherId"] })" class="list-group-item">Profile Settings</a>
                    <a href="@Url.Action("Manage", "Consultation")" class="list-group-item">Consultation</a>
                </div>
            </div>
        </div>
    </div>

    <script>
        (function () {
            fetch('@Html.Raw(Url.Action("TeacherDashboardJson", "OnlineClass"))')
                .then(r => r.json())
                .then(data => {
                    document.getElementById('statLive').textContent = data.liveCount;
                    document.getElementById('statUpcoming').textContent = data.upcomingCount;
                    document.getElementById('statCompleted').textContent = data.completedCount;
                    document.getElementById('statStudents').textContent = data.totalStudents;
                    renderClasses(data.classes);
                })
                .catch(() => {
                    document.getElementById('ocClassList').innerHTML = '<div style="padding:20px; color:red;">Failed to load.</div>';
                });
        })();

        function renderClasses(classes) {
            const el = document.getElementById('ocClassList');
            if (!classes || classes.length === 0) {
                el.innerHTML = '<div style="padding:30px; text-align:center;">No classes scheduled.</div>';
                return;
            }

            let html = '';
            classes.forEach(cls => {
                const barClass = cls.isLive ? 'status-live' : 'status-upcoming';
                html += `
                <div class="oc-class-row">
                    <div class="oc-status-bar ${barClass}"></div>
                    <div class="oc-info">
                        <div class="oc-title">${cls.title}</div>
                        <div class="oc-meta">${cls.subject} &bull; ${cls.scheduledAt}</div>
                    </div>
                    <div class="oc-actions">
                        ${cls.isLive ? `<a href="${cls.meetingUrl}" class="btn-oc btn-oc-green">Enter</a>` : `<a href="${cls.detailsUrl}" class="btn-oc">Details</a>`}
                    </div>
                </div>`;
            });
            el.innerHTML = html;
        }
    </script>
</body>
</html>