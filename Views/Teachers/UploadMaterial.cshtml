@model IEnumerable<SchoolTimetable.Models.LearningMaterial>
@{
    ViewBag.Title = "Upload Material";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Upload Materials :: Academic Portal</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
</head>
<body style="font-family: 'Inter', sans-serif; color: #001a33; background-color: #f4f7f9; margin: 0; padding: 60px 20px; display: flex; flex-direction: column; align-items: center;">

    <div style="width: 100%; max-width: 600px;">
        <div style="margin-bottom: 2rem; border-bottom: 4px solid #002b5c; padding-bottom: 1.2rem; width: 100%;">
            <h1 style="font-size: 1.8rem; font-weight: 800; text-transform: uppercase; margin: 0; color: #002b5c; letter-spacing: -1px;">Learning Materials</h1>
        </div>

        <div style="background: #ffffff; border: 2px solid #002b5c; box-shadow: 8px 8px 0px rgba(0, 43, 92, 0.1); overflow: hidden;">
            <div style="background: #002b5c; color: #ffffff; padding: 20px 30px; border-bottom: 2px solid #001a33;">
                <h5 style="margin: 0; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1.5px; font-weight: 800;">Upload New Material</h5>
            </div>

            <div style="padding: 40px;">
                <p style="font-size: 0.75rem; color: #003d82; margin-bottom: 25px; font-weight: 600; text-transform: uppercase; border-left: 3px solid #002b5c; padding-left: 10px;">
                    Ensure filenames are professional before uploading.
                </p>

                @using (Html.BeginForm("UploadMaterial", "Teachers", FormMethod.Post, new { enctype = "multipart/form-data" }))
                {
                    @Html.AntiForgeryToken()

                    <div style="margin-bottom: 1.5rem;">
                        <label style="display: block; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: #002b5c; margin-bottom: 10px; letter-spacing: 1.2px;">Target Class</label>
                        @Html.DropDownList("SchoolClassId", (SelectList)ViewBag.ClassId, "SELECT TARGET CLASS", new
                        {
                            style = "width: 100%; padding: 14px; border: 2px solid #002b5c; font-family: inherit; font-size: 0.95rem; color: #001a33; box-sizing: border-box;",
                            required = "required"
                        })
                    </div>

                    <div style="margin-bottom: 1.5rem;">
                        <label style="display: block; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: #002b5c; margin-bottom: 10px; letter-spacing: 1.2px;">Material Title</label>
                        <input type="text" name="title" required placeholder="E.G. GRADE 11 PHYSICS - NEWTONIAN LAWS"
                               style="width: 100%; padding: 14px; border: 2px solid #002b5c; font-family: inherit; font-size: 0.95rem; color: #001a33; box-sizing: border-box;" />
                    </div>

                    <div style="margin-bottom: 1.5rem;">
                        <label style="display: block; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: #002b5c; margin-bottom: 10px; letter-spacing: 1.2px;">Description / Instructions</label>
                        <textarea name="description" rows="4" required placeholder="PROVIDE CONTEXT FOR YOUR STUDENTS..."
                                  style="width: 100%; padding: 14px; border: 2px solid #002b5c; font-family: inherit; font-size: 0.95rem; color: #001a33; box-sizing: border-box; resize: vertical;"></textarea>
                    </div>

                    <div style="margin-bottom: 1.8rem;">
                        <label style="display: block; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: #002b5c; margin-bottom: 10px; letter-spacing: 1.2px;">Document Attachment</label>
                        <input type="file" name="file" required
                               style="width: 100%; padding: 10px; border: 2px solid #002b5c; font-family: inherit; box-sizing: border-box;" />
                    </div>

                    <button type="submit"
                            style="width: 100%; padding: 16px; background: #002b5c; color: #ffffff; font-weight: 800; text-transform: uppercase; font-size: 0.8rem; border: none; cursor: pointer; letter-spacing: 1.5px;">
                        Upload to Portal
                    </button>
                }
            </div>
        </div>

        <div style="text-align: center; margin-top: 25px;">
            <a href="@Url.Action("Dashboard")"
               style="color: #002b5c; font-size: 0.7rem; font-weight: 800; text-transform: uppercase; text-decoration: none; letter-spacing: 1px; border-bottom: 2px solid #002b5c; padding-bottom: 2px;">
                Return to Dashboard
            </a>
        </div>
    </div>

</body>
</html>