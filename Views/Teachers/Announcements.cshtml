@model SchoolTimetable.Models.Announcement
@{
    ViewBag.Title = "Create Announcement";
    Layout = null; /* Standalone page - No Layout used */
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create Announcement :: Management</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --navy-dark: #001a33;
            --navy-primary: #002b5c;
            --navy-light: #003d82;
            --white: #ffffff;
            --off-white: #f4f7f9;
            --border-navy: #002b5c;
        }

        body {
            font-family: 'Inter', sans-serif;
            color: var(--navy-dark);
            background-color: var(--off-white);
            margin: 0;
            padding: 60px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        /* Container for content alignment */
        .content-wrapper {
            width: 100%;
            max-width: 600px;
        }

        /* Header Section */
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
            border-bottom: 4px solid var(--navy-primary);
            padding-bottom: 1.2rem;
        }

        .page-title {
            font-size: 1.8rem;
            font-weight: 800;
            text-transform: uppercase;
            margin: 0;
            color: var(--navy-primary);
            letter-spacing: -1px;
        }

        /* Card / Form Container */
        .card {
            background: var(--white);
            border: 2px solid var(--navy-primary);
            border-radius: 0;
            padding: 3rem;
            box-shadow: 8px 8px 0px rgba(0, 43, 92, 0.1);
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-bottom: 1.8rem;
        }

        .form-label {
            font-size: 0.75rem;
            font-weight: 800;
            text-transform: uppercase;
            color: var(--navy-primary);
            letter-spacing: 1.2px;
        }

        .form-control {
            padding: 14px;
            border: 1.5px solid var(--navy-primary);
            border-radius: 0;
            font-family: inherit;
            font-size: 0.95rem;
            color: var(--navy-dark);
            width: 100%;
            box-sizing: border-box;
            background-color: var(--white);
        }

            .form-control:focus {
                outline: none;
                background-color: #fcfdfe;
                box-shadow: inset 0 0 0 1px var(--navy-primary);
            }

            .form-control::placeholder {
                color: #a3b8cc;
                font-size: 0.85rem;
            }

        /* Buttons */
        .btn-container {
            display: flex;
            gap: 12px;
            padding-top: 10px;
        }

        .btn {
            padding: 14px 28px;
            font-weight: 800;
            text-transform: uppercase;
            cursor: pointer;
            font-size: 0.75rem;
            text-decoration: none;
            display: inline-block;
            transition: all 0.2s;
            border: 2px solid var(--navy-primary);
            text-align: center;
            letter-spacing: 1px;
        }

        .btn-primary {
            background: var(--navy-primary);
            color: var(--white);
        }

            .btn-primary:hover {
                background: var(--navy-dark);
                transform: translateY(-1px);
            }

        .btn-outline {
            background: transparent;
            color: var(--navy-primary);
        }

            .btn-outline:hover {
                background: var(--navy-primary);
                color: var(--white);
            }

        /* Strict removal of icons */
        i, .fas, .far, .fab {
            display: none !important;
        }
    </style>
</head>
<body>

    <div class="content-wrapper">
        <div class="page-header">
            <h1 class="page-title">New Announcement</h1>
        </div>

        <div class="card">
            @using (Html.BeginForm("CreateAnnouncement", "Teachers", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label class="form-label">Subject Title</label>
                    <input type="text" name="title" class="form-control" placeholder="E.G. GRADE 12 MATH EXTRA CLASS" required />
                </div>

                <div class="form-group">
                    <label class="form-label">Message Content</label>
                    <textarea name="message" class="form-control" rows="6" placeholder="ENTER ANNOUNCEMENT DETAILS HERE..." required></textarea>
                </div>

                <div class="btn-container">
                    <button type="submit" class="btn btn-primary">Post Announcement</button>
                    <a href="@Url.Action("Dashboard", "Teachers")" class="btn btn-outline">Cancel</a>
                </div>
            }
        </div>
    </div>

</body>
</html>