@model SchoolTimetable.Models.Teacher
@{
    Layout = null; // Strictly disabled the layout
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Durban Girls Secondary School</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --navy-deep: #002147;
            --navy-accent: #003366;
            --gold-accent: #c5a059;
            --white-bright: #ffffff;
            --slate-100: #f1f5f9;
            --slate-300: #cbd5e1;
            --slate-700: #334155;
            --error-red: #b91c1c;
            --success-green: #15803d;
        }

        * {
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--slate-100);
            color: var(--navy-deep);
            margin: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .login-card {
            width: 100%;
            max-width: 400px;
            background: var(--white-bright);
            border: 1px solid var(--slate-300);
            border-top: 5px solid var(--gold-accent);
            border-radius: 4px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            overflow: hidden;
            position: relative;
        }

        /* Back Button Styling */
        .btn-back-home {
            display: block;
            text-align: center;
            padding: 10px;
            background: #f8fafc;
            color: var(--navy-accent);
            text-decoration: none;
            font-size: 10px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            border-bottom: 1px solid var(--slate-100);
            transition: background 0.2s;
        }

            .btn-back-home:hover {
                background: var(--slate-100);
                color: var(--gold-accent);
            }

        .login-header {
            background: var(--navy-deep);
            color: white;
            padding: 30px 20px;
            text-align: center;
        }

            .login-header h4 {
                margin: 0;
                font-size: 1.1rem;
                font-weight: 800;
                text-transform: uppercase;
                letter-spacing: 2px;
            }

        .login-body {
            padding: 35px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-label {
            display: block;
            font-size: 0.75rem;
            font-weight: 800;
            text-transform: uppercase;
            color: var(--navy-accent);
            margin-bottom: 8px;
            letter-spacing: 0.5px;
        }

        .form-control {
            width: 100%;
            padding: 14px;
            border: 1px solid var(--slate-300);
            border-radius: 2px;
            font-family: inherit;
            font-size: 0.95rem;
        }

            .form-control:focus {
                outline: none;
                border-color: var(--navy-deep);
                box-shadow: 0 0 0 3px rgba(0, 33, 71, 0.08);
            }

        .alert {
            padding: 12px;
            margin-bottom: 25px;
            font-size: 0.8rem;
            font-weight: 700;
            border-radius: 2px;
            text-align: center;
            text-transform: uppercase;
        }

        .alert-danger {
            background: #fee2e2;
            color: var(--error-red);
            border: 1px solid #fecaca;
        }

        .alert-success {
            background: #dcfce7;
            color: var(--success-green);
            border: 1px solid #bbf7d0;
        }

        .btn {
            width: 100%;
            padding: 14px;
            font-weight: 800;
            text-transform: uppercase;
            font-size: 0.75rem;
            cursor: pointer;
            border-radius: 2px;
            border: 1px solid transparent;
            transition: all 0.2s;
            text-decoration: none;
            display: block;
            text-align: center;
        }

        .btn-primary {
            background: var(--navy-deep);
            color: white;
        }

            .btn-primary:hover {
                background: var(--navy-accent);
            }

        .btn-outline {
            background: transparent;
            border-color: var(--slate-300);
            color: var(--navy-accent);
            margin-top: 15px;
        }

            .btn-outline:hover {
                background: var(--slate-100);
            }

        .login-footer {
            padding: 20px;
            background: #f8fafc;
            text-align: center;
            border-top: 1px solid var(--slate-100);
        }

        .footer-text {
            font-size: 0.7rem;
            font-weight: 800;
            text-transform: uppercase;
            color: var(--slate-700);
        }

        .link-small {
            font-size: 0.75rem;
            font-weight: 700;
            color: var(--gold-accent);
            text-decoration: none;
            text-transform: uppercase;
        }

        hr {
            border: none;
            border-top: 1px solid var(--slate-100);
            margin: 30px 0;
        }

        /* Removal of icons */
        i, .fas, .fa {
            display: none !important;
        }
    </style>
</head>
<body>

    <div class="login-card">
        <a href="@Url.Action("Index", "Home")" class="btn-back-home">
            Return to Homepage
        </a>

        <div class="login-header">
            <h4>DGSS Portal Login</h4>
        </div>

        <div class="login-body">
            @using (Html.BeginForm("Login", "Teachers", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }

                if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">@TempData["Success"]</div>
                }

                <div class="form-group">
                    <label class="form-label">Email Address</label>
                    <input type="text" name="Email" class="form-control" placeholder="Enter Student Number" required />
                </div>

                <div class="form-group">
                    <label class="form-label">Password</label>
                    <input type="password" name="password" class="form-control" placeholder="••••••••" required />
                </div>

                <button type="submit" class="btn btn-primary">Sign In</button>
            }

            <hr />

            <div style="text-align: center;">
                <p style="font-size: 0.65rem; color: var(--slate-700); font-weight: 800; text-transform: uppercase; margin-bottom: 10px;">New Parent Account</p>
                <a href="@Url.Action("Register", "Parents")" class="btn btn-outline">Register Now</a>
            </div>

            <div style="text-align: center; margin-top: 25px;">
                <a href="@Url.Action("ForgotPassword", "Parents")" class="link-small">Forgot Password?</a>
            </div>
        </div>

        <div class="login-footer">
            <span class="footer-text">Durban Girls Secondary School</span>
        </div>
    </div>

</body>
</html>