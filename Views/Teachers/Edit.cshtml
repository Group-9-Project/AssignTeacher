@model SchoolTimetable.Models.Teacher
@{
    ViewBag.Title = "Edit Profile";
    Layout = null;
    var userRole = Session["UserRole"].ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Profile :: Management System</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --navy-deep: #002147;
            --navy-accent: #003366;
            --gold-accent: #c5a059;
            --white-bright: #ffffff;
            --slate-50: #f8fafc;
            --slate-100: #f1f5f9;
            --slate-300: #cbd5e1;
            --slate-700: #334155;
            --error-red: #cc0000;
        }

        body {
            font-family: 'Inter', sans-serif;
            color: var(--navy-deep);
            background-color: var(--slate-50);
            margin: 0;
            padding: 40px 20px;
        }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
            border-bottom: 3px solid var(--navy-deep);
            padding-bottom: 1.2rem;
            max-width: 800px;
            margin-left: auto;
            margin-right: auto;
        }

        .page-title {
            font-size: 1.7rem;
            font-weight: 800;
            text-transform: uppercase;
            margin: 0;
            letter-spacing: -0.5px;
        }

        .form-container {
            max-width: 800px;
            margin: 0 auto;
        }

        .card {
            background: var(--white-bright);
            border: 1px solid var(--slate-300);
            border-radius: 4px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
            overflow: hidden;
        }

        .card-header {
            background: var(--navy-deep);
            color: white;
            padding: 18px 25px;
        }

            .card-header h5 {
                margin: 0;
                font-size: 0.85rem;
                text-transform: uppercase;
                letter-spacing: 1.5px;
                font-weight: 700;
            }

        .card-body {
            padding: 35px;
        }

        .form-label {
            display: block;
            font-size: 0.7rem;
            font-weight: 800;
            text-transform: uppercase;
            color: var(--navy-accent);
            margin-bottom: 8px;
            letter-spacing: 0.8px;
        }

        .form-control, .form-select {
            padding: 12px;
            border: 1px solid var(--slate-300);
            border-radius: 2px;
            font-family: inherit;
            font-size: 0.95rem;
            color: var(--navy-deep);
            width: 100%;
            box-sizing: border-box;
            background-color: var(--white-bright);
        }

            .form-control:focus {
                outline: none;
                border-color: var(--navy-deep);
                box-shadow: 0 0 0 3px rgba(0, 33, 71, 0.05);
            }

        .section-title {
            font-size: 0.75rem;
            font-weight: 800;
            color: var(--gold-accent);
            text-transform: uppercase;
            margin: 35px 0 15px 0;
            border-bottom: 2px solid var(--slate-100);
            padding-bottom: 8px;
            letter-spacing: 1px;
        }

        .text-muted {
            font-size: 0.7rem;
            color: #64748b;
            margin-top: 6px;
            display: block;
            font-weight: 500;
        }

        .text-danger {
            color: var(--error-red);
            font-size: 0.7rem;
            font-weight: 700;
            list-style: none;
            padding: 0;
            margin-top: 4px;
        }

        .row {
            display: flex;
            gap: 24px;
            flex-wrap: wrap;
        }

        .col-md-6 {
            flex: 1;
            min-width: 300px;
        }

        .mb-3 {
            margin-bottom: 1.8rem;
        }

        .btn {
            padding: 12px 28px;
            font-weight: 800;
            text-transform: uppercase;
            border-radius: 2px;
            cursor: pointer;
            font-size: 0.7rem;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
            border: 2px solid var(--navy-deep);
        }

        .btn-primary {
            background: var(--navy-deep);
            color: white;
        }

            .btn-primary:hover {
                background: var(--navy-accent);
                border-color: var(--navy-accent);
            }

        .btn-outline {
            background: transparent;
            color: var(--navy-deep);
        }

            .btn-outline:hover {
                background: var(--navy-deep);
                color: white;
            }

        i, .fas, .fa {
            display: none !important;
        }
    </style>
</head>
<body>

    <div class="page-header">
        <h1 class="page-title">Edit Profile</h1>
        <a href="@Url.Action("Details", new { id = Model.Id })" class="btn btn-outline">Back to Profile</a>
    </div>

    <div class="form-container">
        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.Id)
            @Html.HiddenFor(m => m.CreatedAt)

            if (!ViewData.ModelState.IsValid)
            {
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
            }

            <div class="card">
                <div class="card-header">
                    <h5>Identity & Contact</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            @Html.LabelFor(m => m.FirstName, new { @class = "form-label" })
                            @Html.TextBoxFor(m => m.FirstName, new { @class = "form-control" })
                            @Html.ValidationMessageFor(m => m.FirstName, "", new { @class = "text-danger" })
                        </div>
                        <div class="col-md-6 mb-3">
                            @Html.LabelFor(m => m.LastName, new { @class = "form-label" })
                            @Html.TextBoxFor(m => m.LastName, new { @class = "form-control" })
                            @Html.ValidationMessageFor(m => m.LastName, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="mb-3">
                        @Html.LabelFor(m => m.Phone, new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.Phone, new { @class = "form-control", placeholder = "e.g. +27..." })
                    </div>

                    <h5 class="section-title">System Access</h5>

                    <div class="mb-3">
                        @Html.LabelFor(m => m.Email, new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.Email, new { @class = "form-control", type = "email" })
                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Update Access Password</label>
                        @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Leave empty to keep current" })
                        <span class="text-muted">Security: Only enter a value if you wish to reset your login password.</span>
                    </div>

                    @if (userRole == "Admin")
                    {
                        <div class="mb-3">
                            <label class="form-label">Teacher Status</label>
                            @Html.DropDownListFor(m => m.IsActive, new[] {
                                new SelectListItem{Text="Authorized / Active", Value="true"},
                                new SelectListItem{Text="Deauthorized / Inactive", Value="false"}
                            }, new { @class = "form-select" })
                        </div>
                    }
                    else
                    {
                        @Html.HiddenFor(m => m.IsActive)
                    }

                    <div style="display: flex; gap: 12px; justify-content: flex-end; margin-top: 30px; padding-top: 25px; border-top: 1px solid var(--slate-100);">
                        <a href="@Url.Action("Details", new { id = Model.Id })" class="btn btn-outline">Discard Changes</a>
                        <button type="submit" class="btn btn-primary">Update Record</button>
                    </div>
                </div>
            </div>
        }
    </div>

</body>
</html>