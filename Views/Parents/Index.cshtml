@model IEnumerable<SchoolTimetable.Models.Application>
@{
    ViewBag.Title = "Parent Dashboard";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800&family=Barlow:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        :root {
            --navy-deep: #0a192f;
            --navy-muted: #112240;
            --navy-accent: #233554;
            --white-bright: #ffffff;
            --white-muted: #ccd6f6;
            --gold-accent: #c5a059;
            --status-green: #64ffda;
            --status-orange: #ffab00;
        }

        body {
            margin: 0;
            background-color: var(--navy-deep);
            color: var(--white-muted);
            font-family: 'Barlow', sans-serif;
        }

        /* Top Navigation Bar */
        .top-nav {
            background-color: var(--navy-muted);
            padding: 15px 2rem;
            display: flex;
            justify-content: flex-end;
            border-bottom: 1px solid var(--navy-accent);
        }

        .logout-link {
            color: var(--white-bright);
            text-decoration: none;
            text-transform: uppercase;
            font-weight: 700;
            font-size: 0.8rem;
            letter-spacing: 1px;
            padding: 8px 16px;
            border: 1px solid var(--gold-accent);
            transition: all 0.3s ease;
        }

            .logout-link:hover {
                background-color: var(--gold-accent);
                color: var(--navy-deep);
            }

        .parent-wrapper {
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px 2rem;
        }

        /* Header */
        .dashboard-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 50px;
            border-bottom: 1px solid var(--navy-accent);
            padding-bottom: 25px;
        }

        .welcome-text h2 {
            margin: 0;
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 800;
            font-size: 3rem;
            color: var(--white-bright);
            text-transform: uppercase;
        }

        .welcome-text p {
            margin: 10px 0 0;
            color: var(--gold-accent);
            text-transform: uppercase;
            font-weight: 600;
            letter-spacing: 2px;
            font-size: 0.9rem;
        }

        /* Grid System */
        .actions-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 25px;
            margin-bottom: 50px;
        }

        .action-card {
            padding: 35px;
            border-radius: 2px;
            transition: all 0.3s ease;
            text-decoration: none;
            display: block;
            border: 1px solid var(--navy-accent);
        }

            .action-card.status-card {
                background: var(--navy-accent);
                border-left: 4px solid var(--gold-accent);
                color: var(--white-bright);
            }

            .action-card.primary {
                background: var(--white-bright);
                color: var(--navy-deep);
            }

            .action-card.secondary {
                background: var(--navy-muted);
                color: var(--white-muted);
            }

            .action-card:hover {
                transform: translateY(-5px);
                border-color: var(--gold-accent);
            }

            .action-card h3 {
                margin: 0;
                font-family: 'Barlow Condensed', sans-serif;
                font-size: 2rem;
                font-weight: 800;
                text-transform: uppercase;
            }

            .action-card p {
                margin: 15px 0 20px;
                opacity: 0.8;
                line-height: 1.5;
            }

        .action-link {
            font-weight: 800;
            text-transform: uppercase;
            font-size: 0.85rem;
            letter-spacing: 2px;
            border-bottom: 2px solid currentColor;
        }

        /* Activity Stream */
        .activity-panel {
            background: var(--navy-muted);
            padding: 40px;
            border: 1px solid var(--navy-accent);
        }

        .tag {
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 800;
            text-transform: uppercase;
            font-size: 0.75rem;
            padding: 4px 10px;
            background: var(--gold-accent);
            color: var(--navy-deep);
            margin-right: 15px;
        }

        .activity-item {
            padding: 15px 0;
            border-bottom: 1px solid rgba(35, 53, 84, 0.5);
        }
    </style>
</head>
<body>

    <nav class="top-nav">
        <a href="@Url.Action("Logout", "Parents")" class="logout-link">Log Out</a>
    </nav>

    <div class="parent-wrapper">
        <div class="dashboard-header">
            <div class="welcome-text">
                <h2>Welcome</h2>
            </div>
            <div style="text-align:right">
                <a href="@Url.Action("Create", "Applications")" style="background: var(--gold-accent); color: white; padding: 12px 20px; text-decoration: none; font-weight: 800; text-transform: uppercase; font-size: 0.8rem;">
                    + New Application
                </a>
            </div>
        </div>
    </div>
    <div class="actions-grid">
        <a href="@Url.Action("MyApplications", "Parents")" class="action-card status-card">
            <h3>My Applications</h3>
            <p>Track your submitted student enrollments, check approval status, and manage required documentation.</p>
            <span class="action-link">View Tracked Submissions →</span>
        </a>
        <a href="@Url.Action("PaymentList", "Parents")" class="action-card primary">
            <h3>Manage Payments</h3>
            <p>View all approved applications and settle outstanding registration fees.</p>
            <span class="action-link">Select Application →</span>
        </a>
        <a href="@Url.Action("MyRequests", "Consultation")" class="action-card primary">
            <h3>Request Consultation</h3>
            <p>Make consultations with teachers</p>
            <span class="action-link">Request Consultation</span>
        </a>
        <a href="@Url.Action("Details", "ReportGeneration")" class="action-card primary">
            <h3>Veiw Academic Record</h3>
            <p>View academic records/student progress</p>
            <span class="action-link">Veiw Academic Record</span>
        </a>
    </div>
</body>
</html>