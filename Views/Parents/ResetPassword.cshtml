@{
    ViewBag.Title = "Reset Password";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewBag.Title - DGSS</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800&family=Barlow:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        :root {
            --navy-deep: #050c18;
            --navy-card: rgba(10, 25, 47, 0.95);
            --navy-accent: #112240;
            --gold-accent: #c5a059;
            --white-bright: #e6f1ff;
            --white-muted: #8892b0;
            --danger: #ff4d4d;
        }

        body {
            margin: 0;
            padding: 0;
            font-family: 'Barlow', sans-serif;
            background: var(--navy-deep);
            color: var(--white-muted);
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
        }

        /* Background Overlay consistent with other pages */
        .page-bg-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, rgba(5, 12, 24, 0.95), rgba(5, 12, 24, 0.85)), url('/Content/Images/tp-image-3986.jpg');
            background-size: cover;
            background-position: center;
            z-index: -1;
        }

        .reset-container {
            width: 100%;
            max-width: 400px;
            background: var(--navy-card);
            padding: 40px;
            border-radius: 4px;
            border: 1px solid var(--navy-accent);
            box-shadow: 0px 10px 30px rgba(0,0,0,0.5);
            backdrop-filter: blur(10px);
        }

        h2 {
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 2.2rem;
            text-align: center;
            color: var(--white-bright);
            text-transform: uppercase;
            margin-bottom: 5px;
            letter-spacing: 1px;
        }

        .subtitle {
            text-align: center;
            color: var(--gold-accent);
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin-bottom: 25px;
            font-weight: 600;
        }

        .email-info {
            text-align: center;
            background: rgba(197, 160, 89, 0.1);
            padding: 10px;
            border-radius: 4px;
            margin-bottom: 25px;
            font-size: 0.9rem;
            border: 1px solid rgba(197, 160, 89, 0.2);
        }

            .email-info strong {
                color: var(--white-bright);
            }

        .form-group {
            margin-bottom: 15px;
        }

        input {
            width: 100%;
            padding: 12px;
            background: var(--navy-deep);
            border: 1px solid var(--navy-accent);
            border-radius: 4px;
            color: var(--white-bright);
            font-size: 1rem;
            box-sizing: border-box;
            transition: 0.3s;
        }

            input:focus {
                outline: none;
                border-color: var(--gold-accent);
                box-shadow: 0 0 5px rgba(197, 160, 89, 0.3);
            }

        button {
            width: 100%;
            padding: 14px;
            background: transparent;
            color: var(--gold-accent);
            border: 1px solid var(--gold-accent);
            border-radius: 4px;
            cursor: pointer;
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 1.2rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
            transition: 0.3s;
            margin-top: 10px;
        }

            button:hover {
                background: rgba(197, 160, 89, 0.1);
                transform: translateY(-2px);
            }

        .error {
            background: rgba(255, 77, 77, 0.1);
            color: var(--danger);
            padding: 12px;
            border-radius: 4px;
            margin-bottom: 20px;
            font-size: 0.85rem;
            border: 1px solid var(--danger);
            text-align: center;
        }
    </style>
</head>
<body>

    <div class="page-bg-overlay"></div>

    <div class="reset-container">
        <h2>Security Reset</h2>
        <div class="subtitle">Verification Required</div>

        <div class="email-info">
            Enter the code sent to:<br />
            <strong>@ViewBag.TargetEmail</strong>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="error">
                <i class="fas fa-exclamation-triangle"></i> @ViewBag.Error
            </div>
        }

        @using (Html.BeginForm())
        {
            <input type="hidden" name="email" value="@ViewBag.TargetEmail" />

            <div class="form-group">
                <input type="text" name="code" placeholder="Verification Code" required autofocus />
            </div>

            <div class="form-group">
                <input type="password" name="newPassword" placeholder="New Password" required />
            </div>

            <div class="form-group">
                <input type="password" name="confirmNewPassword" placeholder="Confirm New Password" required />
            </div>

            <button type="submit">Update Password</button>
        }
    </div>

</body>
</html>