@model SchoolTimetable.Models.Parent

@{
    ViewBag.Title = "Parent Registration";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewBag.Title - DGSS</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800&family=Barlow:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        :root {
            --pure-white: #ffffff;
            --off-white: #f8f9fa;
            --navy-text: #050c18;
            --gold-accent: #c5a059;
            --gray-muted: #6c757d;
            --navy-light: #112240;
            --danger: #dc3545;
        }

        body {
            margin: 0;
            padding: 0;
            font-family: 'Barlow', sans-serif;
            background: var(--off-white);
            color: var(--navy-text);
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
        }

        /* Subtle Background Overlay */
        .page-bg-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, rgba(255, 255, 255, 0.9), rgba(248, 249, 250, 0.8)), url('/Content/Images/tp-image-3986.jpg');
            background-size: cover;
            background-position: center;
            z-index: -1;
        }

        .register-container {
            width: 100%;
            max-width: 450px;
            background: var(--pure-white);
            padding: 40px;
            border-radius: 8px;
            border: 1px solid #dee2e6;
            box-shadow: 0px 15px 35px rgba(0,0,0,0.1);
        }

            .register-container h2 {
                font-family: 'Barlow Condensed', sans-serif;
                font-size: 2.4rem;
                text-align: center;
                color: var(--navy-text);
                text-transform: uppercase;
                margin-bottom: 5px;
                letter-spacing: 1px;
            }

        .subtitle {
            text-align: center;
            color: var(--gold-accent);
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 30px;
            font-weight: 700;
        }

        .form-group {
            margin-bottom: 20px;
        }

        label {
            font-family: 'Barlow Condensed', sans-serif;
            color: var(--navy-text);
            text-transform: uppercase;
            letter-spacing: 1px;
            font-size: 0.95rem;
            display: block;
            margin-bottom: 6px;
            font-weight: 700;
        }

        .form-control {
            width: 100%;
            padding: 12px;
            background: var(--off-white);
            border: 1px solid #ced4da;
            border-radius: 4px;
            color: var(--navy-text);
            font-size: 1rem;
            box-sizing: border-box;
            transition: 0.3s;
        }

            .form-control:focus {
                outline: none;
                border-color: var(--gold-accent);
                background: var(--pure-white);
                box-shadow: 0 0 8px rgba(197, 160, 89, 0.2);
            }

        .btn-register {
            width: 100%;
            padding: 14px;
            background: var(--navy-text);
            color: var(--gold-accent);
            border: 2px solid var(--navy-text);
            border-radius: 4px;
            cursor: pointer;
            font-family: 'Barlow Condensed', sans-serif;
            font-size: 1.2rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
            transition: 0.3s;
            margin-top: 10px;
        }

            .btn-register:hover {
                background: var(--pure-white);
                color: var(--navy-text);
                border-color: var(--navy-text);
                transform: translateY(-2px);
            }

        .alert-danger {
            background: #f8d7da;
            color: var(--danger);
            padding: 12px;
            border-radius: 4px;
            margin-bottom: 20px;
            font-size: 0.9rem;
            border: 1px solid #f5c6cb;
            text-align: center;
            font-weight: 600;
        }

        .text-danger {
            color: var(--danger);
            font-size: 0.8rem;
            margin-top: 5px;
            display: block;
            font-weight: 600;
        }

        .login-link {
            text-align: center;
            margin-top: 25px;
            font-size: 0.95rem;
            color: var(--gray-muted);
        }

            .login-link a {
                text-decoration: none;
                color: var(--gold-accent);
                font-weight: 700;
                transition: 0.2s;
            }

                .login-link a:hover {
                    color: var(--navy-text);
                    text-decoration: underline;
                }
    </style>
</head>
<body>

    <div class="page-bg-overlay"></div>

    <div class="register-container">
        <h2>Parent Account</h2>
        <div class="subtitle">Join our school community</div>

        @if (ViewBag.Error != null)
        {
            <div class="alert-danger">
                <i class="fas fa-exclamation-circle"></i> @ViewBag.Error
            </div>
        }

        @using (Html.BeginForm("Register", "Parents", FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label><i class="fas fa-user-circle"></i> Full Name</label>
                @Html.TextBoxFor(m => m.FullName, new { @class = "form-control", placeholder = "Enter your full name" })
                @Html.ValidationMessageFor(m => m.FullName, "", new { @class = "text-danger" })
            </div>

            <div class="form-group">
                <label><i class="fas fa-envelope"></i> Email Address</label>
                @Html.TextBoxFor(m => m.Email, new { @class = "form-control", type = "email", placeholder = "name@example.com" })
                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
            </div>

            <div class="form-group">
                <label><i class="fas fa-lock"></i> Password</label>
                @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "••••••••" })
                @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
            </div>

            <div class="form-group">
                <label><i class="fas fa-shield-alt"></i> Confirm Password</label>
                @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control", placeholder = "••••••••" })
                @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger" })
            </div>

            <button type="submit" class="btn-register">
                Create Account
            </button>
        }

        <div class="login-link">
            Already have an account?
            @Html.ActionLink("Login Here", "Login", "Teachers")
        </div>
    </div>

</body>
</html>