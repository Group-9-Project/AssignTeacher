@model SchoolTimetable.ViewModels.IssueBookViewModel
@{
    Layout = null; // Standalone mode
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Authorize Loan - DGSS Library</title>

    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@800&family=Barlow:wght@400;500;600;700&display=swap');

        :root {
            --navy-deep: #0a192f;
            --navy-accent: #112240;
            --white-bright: #ffffff;
            --white-muted: #f8fafc;
            --text-main: #1a202c;
            --text-muted: #64748b;
            --border-light: #e2e8f0;
            --gold-highlight: #b08d48;
        }

        body {
            background-color: var(--white-muted);
            color: var(--text-main);
            margin: 0;
            padding: 0;
            font-family: 'Barlow', sans-serif;
        }

        .issue-container {
            max-width: 700px;
            margin: 3rem auto;
            padding: 40px;
            background-color: var(--white-bright);
            border-radius: 8px;
            border: 1px solid var(--border-light);
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
        }

        .issue-header {
            font-family: 'Barlow Condensed', sans-serif;
            color: var(--navy-deep);
            font-size: 2.5rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 25px;
            border-bottom: 3px solid var(--navy-deep);
            padding-bottom: 10px;
            line-height: 1;
        }

        .book-box {
            background: var(--white-muted);
            border-left: 5px solid var(--navy-deep);
            padding: 20px;
            margin-bottom: 30px;
        }

        .form-label {
            display: block;
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 800;
            color: var(--navy-deep);
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 8px;
        }

        .form-control-fixed {
            width: 100%;
            padding: 12px 15px !important;
            font-size: 1rem !important;
            background-color: var(--white-bright) !important;
            border: 2px solid var(--border-light) !important;
            color: var(--text-main) !important;
            border-radius: 4px;
            box-sizing: border-box;
            height: auto !important;
            min-height: 50px !important;
            line-height: 1.5 !important;
            display: block;
            transition: border-color 0.2s, background-color 0.2s;
            font-family: inherit;
        }

            .form-control-fixed:focus {
                border-color: var(--navy-deep) !important;
                background-color: #fff !important;
                outline: none;
            }

        textarea.form-control-fixed {
            min-height: 120px !important;
            resize: vertical;
        }

        .btn-row {
            display: flex;
            justify-content: flex-end;
            gap: 15px;
            margin-top: 35px;
            padding-top: 25px;
            border-top: 1px solid var(--border-light);
        }

        .btn-issue {
            background: var(--navy-deep);
            color: var(--white-bright);
            padding: 14px 35px;
            border: none;
            border-radius: 4px;
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 800;
            text-transform: uppercase;
            cursor: pointer;
            transition: 0.2s;
            text-decoration: none;
        }

            .btn-issue:hover {
                background: var(--navy-accent);
                transform: translateY(-1px);
            }

        .btn-cancel {
            background: transparent;
            color: var(--text-muted);
            border: 2px solid var(--border-light);
            padding: 12px 30px;
            border-radius: 4px;
            cursor: pointer;
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 800;
            text-transform: uppercase;
            transition: 0.2s;
            text-decoration: none;
        }

            .btn-cancel:hover {
                background: var(--white-muted);
                border-color: var(--text-muted);
                color: var(--text-main);
            }
    </style>
</head>
<body>

    <div class="issue-container">
        <h2 class="issue-header">Authorize Loan</h2>

        <div class="book-box">
            <div style="font-family: 'Barlow Condensed', sans-serif; font-size: 1.5rem; color: var(--navy-deep); text-transform: uppercase; line-height: 1.2;">@Model.Book.Title</div>
            <div style="color: var(--text-muted); font-weight: 600; margin-top: 5px;">Asset Catalogued by @Model.Book.Author</div>
        </div>

        @using (Html.BeginForm("Issue", "Borrowings", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.BookId)
            @Html.HiddenFor(m => m.ReservationId)

            <div style="margin-bottom: 25px;">
                <label class="form-label">Assigned Student (Recipient)</label>
                @Html.DropDownListFor(m => m.StudentId,
                    new SelectList(Model.Students, "Id", "FullName"),
                    new { @class = "form-control-fixed" })
            </div>

            <div style="margin-bottom: 25px;">
                <label class="form-label">Mandatory Return Date</label>
                @Html.TextBoxFor(m => m.DueDate, "{0:yyyy-MM-dd}", new { @class = "form-control-fixed", type = "date" })
            </div>

            <div style="margin-bottom: 25px;">
                <label class="form-label">Asset Inspection & Condition Notes</label>
                @Html.TextAreaFor(m => m.Notes, new { @class = "form-control-fixed", rows = "4", placeholder = "Specify any existing damage or special notes before issuing..." })
            </div>

            <div class="btn-row">
                <button type="button" class="btn-cancel" data-dismiss="modal">Abandon</button>
                <button type="submit" class="btn-issue">Confirm Authorization</button>
            </div>
        }
    </div>

</body>
</html>