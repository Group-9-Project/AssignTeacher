@model SchoolTimetable.Models.Consultation

@{
    Layout = null;
    ViewBag.Title = "Request Consultation";
}

<style>
    :root {
        --dgss-navy: #1a237e;
        --dgss-gold: #ffd700;
        --dgss-light-gray: #f4f7f6;
    }

    body {
        background-color: var(--dgss-light-gray);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .form-card {
        border: none;
        border-radius: 20px;
        box-shadow: 0 15px 35px rgba(26, 35, 126, 0.1);
        overflow: hidden;
    }

    .form-header {
        background: linear-gradient(135deg, var(--dgss-navy) 0%, #283593 100%);
        color: white;
        padding: 2rem;
        border-bottom: 5px solid var(--dgss-gold);
    }

    .form-label {
        font-weight: 600;
        color: var(--dgss-navy);
        margin-bottom: 0.5rem;
        display: flex;
        align-items: center;
    }

        .form-label i {
            color: var(--dgss-gold);
            font-size: 1.1rem;
        }

    .form-control, .form-select {
        border-radius: 8px;
        padding: 0.6rem 1rem;
        border: 1px solid #dee2e6;
        transition: all 0.2s ease-in-out;
    }

        .form-control:focus, .form-select:focus {
            border-color: var(--dgss-navy);
            box-shadow: 0 0 0 0.25rem rgba(26, 35, 126, 0.15);
            transform: translateY(-1px);
        }

    .btn-submit {
        background-color: var(--dgss-navy);
        color: white;
        padding: 0.8rem 2.5rem;
        font-weight: bold;
        border-radius: 10px;
        border: none;
        transition: all 0.3s;
    }

        .btn-submit:hover {
            background-color: #0d1256;
            color: var(--dgss-gold);
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }

    .section-title {
        border-left: 5px solid var(--dgss-gold);
        padding-left: 12px;
        margin-bottom: 25px;
        color: var(--dgss-navy);
        font-weight: 800;
        text-transform: uppercase;
        font-size: 0.9rem;
        letter-spacing: 1px;
    }

    .btn-back-link {
        color: var(--dgss-navy);
        font-weight: 500;
        transition: 0.2s;
    }

        .btn-back-link:hover {
            color: #000;
            transform: translateX(-3px);
        }
</style>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">

<div class="container mt-5 pb-5">
    <!-- Back Link (Pure Styling) -->
    <div class="mb-4">
        <a href="@Url.Action("Index", "Consultation")" class="text-decoration-none btn-back-link d-inline-flex align-items-center">
            <i class="bi bi-arrow-left-circle-fill me-2 fs-5"></i> Back to My History
        </a>
    </div>

    <div class="card form-card">
        <div class="form-header text-center">
            <div class="bg-white d-inline-block rounded-circle p-3 mb-3 shadow-sm">
                <i class="bi bi-calendar-plus text-navy fs-2" style="color: var(--dgss-navy)"></i>
            </div>
            <h2 class="mb-1 fw-bold">Request a Consultation</h2>
            <p class="mb-0 opacity-75">Durban Girls Secondary School Parent Portal</p>
        </div>

        <div class="card-body p-4 p-md-5 bg-white">
            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()

                <div class="row">
                    <!-- Left Column: Details -->
                    <div class="col-md-6 border-end pe-md-5">
                        <h5 class="section-title">Meeting Details</h5>

                        <div class="form-group mb-4">
                            <label class="form-label"><i class="bi bi-person-video3 me-2"></i>Select Teacher & Subject</label>
                            @Html.DropDownList("TeacherSubjectId", (SelectList)ViewBag.TeacherSubjectId, "-- Choose Educator --", new { @class = "form-select shadow-sm" })
                        </div>

                        <div class="form-group mb-4">
                            <label class="form-label"><i class="bi bi-building me-2"></i>Select Class</label>
                            @Html.DropDownList("ClassId", (SelectList)ViewBag.ClassId, "-- Select Grade/Class --", new { @class = "form-select shadow-sm" })
                        </div>

                        <div class="row g-3">
                            <div class="col-sm-6">
                                <div class="form-group mb-4">
                                    <label class="form-label"><i class="bi bi-calendar-event me-2"></i>Date</label>
                                    <input type="date" name="date" class="form-control shadow-sm" required />
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="form-group mb-4">
                                    <label class="form-label"><i class="bi bi-clock me-2"></i>Time</label>
                                    <input type="time" name="time" class="form-control shadow-sm" required />
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Right Column: Reason -->
                    <div class="col-md-6 ps-md-5 mt-4 mt-md-0">
                        <h5 class="section-title">Context & Reason</h5>
                        <div class="form-group mb-3">
                            <label class="form-label"><i class="bi bi-chat-left-text me-2"></i>Reason for Consultation</label>
                            @Html.TextAreaFor(m => m.reason, new
                            {
                                @class = "form-control shadow-sm",
                                rows = "7",
                                placeholder = "Please provide details regarding what you would like to discuss..."
                            })
                        </div>

                        <div class="card border-0 bg-light p-3 rounded-3 shadow-sm">
                            <div class="d-flex">
                                <i class="bi bi-info-circle-fill text-primary me-3 fs-5"></i>
                                <p class="mb-0 small text-muted">
                                    <strong>Note:</strong> Your requested time is a proposal. Teachers will confirm or suggest an alternative based on the academic timetable.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <hr class="my-5 opacity-25">

                <div class="d-flex justify-content-between align-items-center">
                    <a href="@Url.Action("Index", "Consultation")" class="btn btn-link text-muted fw-bold text-decoration-none px-0">
                        <i class="bi bi-x-circle me-1"></i> Cancel
                    </a>
                    <button type="submit" class="btn btn-submit shadow">
                        Submit Request <i class="bi bi-send-check-fill ms-2"></i>
                    </button>
                </div>
            }
        </div>
    </div>

    <div class="text-center mt-5">
        <div class="small text-muted">
            <i class="bi bi-shield-check me-1"></i> Secure Teacher-Parent Communication Portal
            <br>
            <span class="opacity-50">DGSS Academic Management © 2026</span>
        </div>
    </div>
</div>