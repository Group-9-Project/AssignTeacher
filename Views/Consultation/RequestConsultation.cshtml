@model SchoolTimetable.Models.Consultation

@{
    Layout = null;
    ViewBag.Title = "Request Consultation";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h4>Request a Teacher Consultation</h4>
        </div>
        <div class="card-body">
            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label>Select Teacher & Subject</label>
                            @Html.DropDownList("TeacherSubjectId", (SelectList)ViewBag.TeacherSubjectId, "-- Select Teacher --", new { @class = "form-control" })
                        </div>

                        <div class="form-group mb-3">
                            <label>Select Class</label>
                            @Html.DropDownList("ClassId", (SelectList)ViewBag.ClassId, "-- Select Class --", new { @class = "form-control" })
                        </div>

                        <div class="form-group mb-3">
                            <label>Proposed Date</label>
                            <input type="date" name="date" class="form-control" required />
                        </div>

                        <div class="form-group mb-3">
                            <label>Proposed Time</label>
                            <input type="time" name="time" class="form-control" required />
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label>Reason for Consultation</label>
                            @Html.TextAreaFor(m => m.reason, new { @class = "form-control", rows = "8", placeholder = "Describe the purpose of the meeting..." })
                        </div>
                    </div>
                </div>

                <div class="mt-3 text-end">
                    <a href="@Url.Action("Index", "Parents")" class="btn btn-secondary">Cancel</a>
                    <button type="submit" class="btn btn-success">Submit Request</button>
                </div>
            }
        </div>
    </div>
</div>