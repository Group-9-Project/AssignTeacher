@model IEnumerable<SchoolTimetable.Models.Subject>
@{
    ViewBag.Title = "Subjects";
    Layout = null; // Explicitly disabling layout
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Subjects</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --navy-deep: #002147;
            --navy-muted: #003366;
            --white-bright: #ffffff;
            --success-green: #166534;
            --error-red: #be123c;
            --slate-50: #f8fafc;
            --slate-100: #f1f5f9;
            --slate-200: #e2e8f0;
            --slate-300: #cbd5e1;
            --slate-600: #475569;
        }

        body {
            background-color: var(--slate-50);
            font-family: 'Inter', sans-serif;
            color: var(--navy-deep);
            margin: 0;
            padding: 0;
        }

        .page-wrapper {
            max-width: 1100px;
            margin: 3rem auto;
            padding: 0 1.5rem;
        }

        /* Strict Navy Header */
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center; /* Adjusted for better button alignment */
            margin-bottom: 2rem;
            border-bottom: 4px solid var(--navy-deep);
            padding-bottom: 1rem;
        }

        .page-title {
            font-size: 1.8rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: -1px;
            margin: 0;
            color: var(--navy-deep);
        }

        /* Table Card Architecture */
        .card {
            background: var(--white-bright);
            border: 1px solid var(--slate-300);
            border-radius: 4px;
            overflow: hidden;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.04);
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }

            .data-table thead th {
                background: var(--navy-deep);
                color: white;
                text-transform: uppercase;
                font-size: 0.7rem;
                font-weight: 800;
                letter-spacing: 1px;
                padding: 18px 16px;
            }

            .data-table tbody tr {
                border-bottom: 1px solid var(--slate-100);
                transition: background 0.2s;
            }

                .data-table tbody tr:hover {
                    background: #fcfdfd;
                }

            .data-table td {
                padding: 16px;
                font-size: 0.9rem;
                vertical-align: middle;
                color: var(--navy-muted);
            }

        .subject-box {
            width: 42px;
            height: 42px;
            background: var(--slate-100);
            border-left: 4px solid var(--navy-deep);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            font-size: 0.75rem;
            color: var(--navy-deep);
        }

        .status-badge {
            font-size: 0.65rem;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            padding: 4px 8px;
            border-radius: 2px;
            border: 1px solid currentColor;
        }

        .status-active {
            color: var(--success-green);
            background: #f0fdf4;
        }

        .status-inactive {
            color: var(--error-red);
            background: #fff1f2;
        }

        /* Management Buttons */
        .btn {
            padding: 10px 18px;
            font-weight: 800;
            text-transform: uppercase;
            border-radius: 2px;
            cursor: pointer;
            font-size: 0.7rem;
            letter-spacing: 0.8px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            transition: all 0.2s ease;
            border: 2px solid var(--navy-deep);
        }

        .btn-primary {
            background: var(--navy-deep);
            color: white;
        }

            .btn-primary:hover {
                background: white;
                color: var(--navy-deep);
            }

        .btn-outline {
            background: transparent;
            border-color: var(--navy-deep);
            color: var(--navy-deep);
        }

            .btn-outline:hover {
                background: var(--navy-deep);
                color: white;
            }

        .btn-edit {
            background: transparent;
            border-color: var(--slate-300);
            color: var(--slate-600);
            margin-right: 4px;
        }

            .btn-edit:hover {
                border-color: var(--navy-deep);
                color: var(--navy-deep);
            }

        .btn-delete {
            background: transparent;
            color: var(--error-red);
            border-color: #fecaca;
        }

            .btn-delete:hover {
                background: var(--error-red);
                color: white;
                border-color: var(--error-red);
            }

        .empty-state {
            padding: 5rem 2rem;
            text-align: center;
            color: var(--slate-600);
            font-weight: 600;
        }
    </style>
</head>
<body>

    <div class="page-wrapper">
        <div class="page-header">
            <div style="display: flex; align-items: center; gap: 20px;">
                <a href="@Url.Action("ManageTeacherDashboard","Admin") " class="btn btn-outline">Back to Dashboard</a>
                <h1 class="page-title">Subject Registry</h1>
            </div>
            <a href="@Url.Action("Create")" class="btn btn-primary">Enroll New Subject</a>
        </div>

        <div class="card">
            @if (Model != null && Model.Any())
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Subject Details</th>
                            <th>Code</th>
                            <th>Assigned Staff</th>
                            <th>Status</th>
                            <th style="text-align:right">Management</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model)
                        {
                            <tr>
                                <td>
                                    <div style="display:flex; align-items:center; gap:15px">
                                        <div class="subject-box" style="border-left-color: @(string.IsNullOrEmpty(s.Color) ? "#002147" : s.Color)">
                                            @(string.IsNullOrEmpty(s.Code) ? "SUB" : s.Code.Substring(0, Math.Min(s.Code.Length, 2)).ToUpper())
                                        </div>
                                        <div>
                                            <div style="font-weight:800; color: var(--navy-deep);">@s.Name</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span style="font-family:monospace; font-weight:700; color: var(--slate-600)">@s.Code</span>
                                </td>
                                <td>
                                    @if (s.TeacherSubjects != null && s.TeacherSubjects.Any())
                                    {
                                        var teachers = s.TeacherSubjects.Select(ts => ts.Teacher.LastName).Take(2);
                                        <span style="font-weight:600">@string.Join(", ", teachers)</span>
                                        if (s.TeacherSubjects.Count > 2)
                                        {
                                            <span style="color:var(--slate-600); font-size:0.8rem"> +@(s.TeacherSubjects.Count - 2)</span>
                                        }
                                    }
                                    else
                                    {
                                        <span style="color:var(--slate-300); font-style: italic;">Unassigned</span>
                                    }
                                </td>
                                <td>
                                    <span class="status-badge @(s.IsActive ? "status-active" : "status-inactive")">
                                        @(s.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td style="text-align:right">
                                    <div style="display:flex; justify-content:flex-end; gap:6px">
                                        <a href="@Url.Action("Edit", new { id = s.Id })" class="btn btn-edit">update</a>

                                        @using (Html.BeginForm("Delete", "Subjects", new { id = s.Id }, FormMethod.Post, new { onsubmit = "return confirm('Archive this subject record?')" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-delete">Delete</button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-state">
                    <div style="font-size: 2rem; margin-bottom: 1rem;">??</div>
                    No subject records found in the institutional database.
                </div>
            }
        </div>
    </div>

</body>
</html>