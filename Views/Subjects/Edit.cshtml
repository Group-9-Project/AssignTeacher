@model SchoolTimetable.Models.Subject
@{
    ViewBag.Title = "Edit Subject";
    // Ensuring no layout is used as per your instruction
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Edit Subject</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --navy-primary: #002147;
            --navy-light: #003366;
            --white: #ffffff;
            --off-white: #f8fafc;
            --slate-border: #cbd5e1;
            --slate-text: #475569;
            --error: #be123c;
        }

        body {
            background-color: var(--off-white);
            font-family: 'Inter', sans-serif;
            color: var(--navy-primary);
            margin: 0;
            padding: 0;
            display: flex;
            justify-content: center;
        }

        .subject-wrapper {
            width: 100%;
            max-width: 700px;
            margin: 4rem 1rem;
        }

        /* Strict White and Navy Header */
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-bottom: 2rem;
            border-bottom: 4px solid var(--navy-primary);
            padding-bottom: 1rem;
        }

        .page-title {
            font-size: 1.6rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: -0.5px;
            margin: 0;
        }

        /* Container Card */
        .form-card {
            background: var(--white);
            border: 1px solid var(--slate-border);
            border-radius: 4px;
            padding: 3rem;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.04);
        }

        .form-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 1.5rem;
            margin-bottom: 0.5rem;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
            margin-bottom: 1.8rem;
        }

        .form-label {
            font-size: 0.7rem;
            font-weight: 800;
            text-transform: uppercase;
            color: var(--slate-text);
            letter-spacing: 0.8px;
        }

        .form-control {
            padding: 14px;
            border: 2px solid #e2e8f0;
            border-radius: 2px;
            font-family: inherit;
            font-size: 0.95rem;
            transition: all 0.2s ease;
            background: var(--white);
            color: var(--navy-primary);
        }

            .form-control:focus {
                outline: none;
                border-color: var(--navy-primary);
            }

        /* Code input styling */
        .code-input {
            font-family: monospace;
            text-transform: uppercase;
            font-weight: 700;
            background: #f1f5f9;
        }

        /* Buttons */
        .btn {
            padding: 12px 24px;
            font-weight: 800;
            text-transform: uppercase;
            border-radius: 2px;
            cursor: pointer;
            font-size: 0.75rem;
            letter-spacing: 1px;
            text-decoration: none;
            display: inline-block;
            transition: all 0.2s;
            text-align: center;
            border: 2px solid var(--navy-primary);
        }

        .btn-primary {
            background: var(--navy-primary);
            color: var(--white);
        }

            .btn-primary:hover {
                background: var(--white);
                color: var(--navy-primary);
            }

        .btn-outline {
            background: transparent;
            border-color: var(--slate-border);
            color: var(--slate-text);
        }

            .btn-outline:hover {
                border-color: var(--navy-primary);
                color: var(--navy-primary);
            }

        .form-footer {
            display: flex;
            gap: 12px;
            justify-content: flex-end;
            padding-top: 2rem;
            border-top: 1px solid #f1f5f9;
            margin-top: 1rem;
        }

        /* Error States */
        .validation-summary-errors {
            background: #fff1f2;
            color: var(--error);
            padding: 1.2rem;
            border-left: 5px solid var(--error);
            margin-bottom: 2rem;
            font-size: 0.85rem;
            font-weight: 600;
        }
    </style>
</head>
<body>
    <div class="subject-wrapper">
        <div class="page-header">
            <h1 class="page-title">Modify Subject Record</h1>
            <a href="@Url.Action("Index")" class="btn btn-outline">Archive</a>
        </div>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.Id)

            if (!ViewData.ModelState.IsValid)
            {
                <div class="validation-summary-errors">
                    @Html.ValidationSummary(true, "Action Required:")
                </div>
            }

            <div class="form-card">
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label">Subject Designation</label>
                        @Html.TextBoxFor(m => m.Name, new { @class = "form-control" })
                    </div>
                    <div class="form-group">
                        <label class="form-label">System Code</label>
                        @Html.TextBoxFor(m => m.Code, new { @class = "form-control code-input", maxlength = "10" })
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Operational Status</label>
                    @Html.DropDownListFor(m => m.IsActive, new[] {
                        new SelectListItem { Text = "ACTIVE STATUS", Value = "true" },
                        new SelectListItem { Text = "INACTIVE STATUS", Value = "false" }
                    }, new { @class = "form-control" })
                </div>

                <div class="form-footer">
                    <a href="@Url.Action("Index")" class="btn btn-outline">Discard</a>
                    <button type="submit" class="btn btn-primary">Update Subject</button>
                </div>
            </div>
        }
    </div>
</body>
</html>